From: Dory Engine <engine@dory.dev>
Subject: [PATCH] virtiofs: poll request completions after a synchronous kick

The dory-hv device handles request-queue kicks inline: virtqueue_notify
traps to the host and returns only after the request was processed, so
the completion is already in the used ring when the submitting task
resumes. Draining it at enqueue time lets request_wait_answer observe
FR_FINISHED without sleeping, eliminating the interrupt injection and
scheduler wake-up that dominate metadata-heavy bind-mount workloads.

Only the caller' own synchronous request is completed inline:
background requests are submitted from flush_bg_queue() under
fc->bg_lock, which fuse_request_end() re-takes for them (inline
completion of FUSE_INIT deadlocked the mount path), and a foreign
request' teardown must not run under this task' VFS locks. All other
completions keep their workqueue context. A poll miss re-arms callbacks
and falls back to the interrupt path, and queued requests are re-pushed
because no done_work fires for completions consumed here.

---
diff --git a/fs/fuse/virtio_fs.c b/fs/fuse/virtio_fs.c
--- a/fs/fuse/virtio_fs.c
+++ b/fs/fuse/virtio_fs.c
@@ -1722,6 +1722,67 @@
 		*len_used = len;
 
 	return total_sgs;
+}
+
+/*
+ * The device may process request-queue kicks synchronously: virtqueue_notify
+ * traps to the host and only returns once the request has been handled, so
+ * the completion is usually already in the used ring. Draining it here lets
+ * the submitting task observe FR_FINISHED without ever sleeping, skipping
+ * the interrupt injection and wake-up that dominate metadata-heavy
+ * workloads.
+ *
+ * Only the caller's own synchronous request may be completed in this
+ * context. Background requests are submitted from flush_bg_queue() under
+ * fc->bg_lock, which fuse_request_end() re-takes for them, and completing a
+ * foreign request here could run its teardown (fuse_put_request -> iput)
+ * under whatever VFS locks this task holds. Everything else keeps its
+ * existing workqueue completion context via virtio_fs_complete_req_work.
+ *
+ * Callbacks were disabled under fsvq->lock before the notify; a poll miss
+ * (asynchronous device) re-arms them via virtqueue_enable_cb and falls back
+ * to the normal interrupt path. Queued requests are re-pushed after a drain
+ * because no interrupt (and therefore no done_work) fires for completions
+ * consumed here.
+ */
+static void virtio_fs_poll_completions(struct virtio_fs_vq *fsvq,
+				       struct fuse_req *own_req)
+{
+	struct fuse_pqueue *fpq = &fsvq->fud->pq;
+	struct virtqueue *vq = fsvq->vq;
+	struct fuse_req *req;
+	struct fuse_req *next;
+	unsigned int len;
+	LIST_HEAD(reqs);
+
+	spin_lock(&fsvq->lock);
+	do {
+		while ((req = virtqueue_get_buf(vq, &len)) != NULL) {
+			spin_lock(&fpq->lock);
+			list_move_tail(&req->list, &reqs);
+			spin_unlock(&fpq->lock);
+		}
+	} while (!virtqueue_enable_cb(vq));
+	if (!list_empty(&fsvq->queued_reqs))
+		schedule_work(&fsvq->dispatch_work);
+	spin_unlock(&fsvq->lock);
+
+	list_for_each_entry_safe(req, next, &reqs, list) {
+		list_del_init(&req->list);
+
+		if (req == own_req && !test_bit(FR_BACKGROUND, &req->flags) &&
+		    !req->args->may_block) {
+			virtio_fs_request_complete(req, fsvq);
+		} else {
+			struct virtio_fs_req_work *w;
+
+			w = kzalloc(sizeof(*w), GFP_NOFS | __GFP_NOFAIL);
+			INIT_WORK(&w->done_work, virtio_fs_complete_req_work);
+			w->fsvq = fsvq;
+			w->req = req;
+			schedule_work(&w->done_work);
+		}
+	}
 }
 
 /* Add a request to a virtqueue and kick the device */
@@ -1809,11 +1870,20 @@
 	if (!in_flight)
 		inc_in_flight_req(fsvq);
 	notify = virtqueue_kick_prepare(vq);
+	/*
+	 * Suppress the completion interrupt before kicking: a synchronous
+	 * device has the reply in the used ring by the time the notify write
+	 * returns, and virtio_fs_poll_completions() consumes it inline.
+	 */
+	if (notify)
+		virtqueue_disable_cb(vq);
 
 	spin_unlock(&fsvq->lock);
 
-	if (notify)
+	if (notify) {
 		virtqueue_notify(vq);
+		virtio_fs_poll_completions(fsvq, req);
+	}
 
 out:
 	if (ret < 0 && req->argbuf) {
