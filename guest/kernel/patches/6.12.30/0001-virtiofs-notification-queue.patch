From bbddd6e16671c913feaa91235c28edde6bb91c18 Mon Sep 17 00:00:00 2001
From: Dory Kernel Port <dev@dory.local>
Date: Fri, 10 Jul 2026 00:55:52 +0000
Subject: [PATCH] virtiofs: add notification queue for cache invalidation

Port the notification-virtqueue design posted by Vivek Goyal in 2021 to
Linux 6.12.30. The VIRTIO 1.2 notification feature is standardized but
still absent from the upstream Linux virtio-fs driver.

Accept FUSE_NOTIFY_INVAL_INODE, FUSE_NOTIFY_INVAL_ENTRY, and
FUSE_NOTIFY_DELETE on a dedicated device-to-driver queue. DELETE carries
the cached child node ID as well as its name, so Linux can notify watches
installed on a matching deleted inode while invalidating the dentry.
Route matched deletes through VFS's regular delete-notify helper too.
This lets a parent watch receive the deleted child's name instead of an
unrelated event for the parent directory. Keep the feature negotiated so
unmodified devices and guests retain the existing queue layout.

This intentionally does not port the abandoned remote-fsnotify RFC: FUSE
cache invalidation does not synthesize inotify events. Dory layers watcher
event synthesis outside this kernel transport.

Link: https://lwn.net/ml/linux-fsdevel/20210930143850.1188628-6-vgoyal%40redhat.com/

Link: https://docs.oasis-open.org/virtio/virtio/v1.2/virtio-v1.2.html#x1-60500011

Signed-off-by: Dory Kernel Port <dev@dory.local>
---
 fs/fuse/dir.c                  |   9 +++++++--
 fs/fuse/virtio_fs.c            | 374 +++++++++++++++++++++++++++++++---
 include/uapi/linux/virtio_fs.h |   6 +
 3 files changed, 360 insertions(+), 29 deletions(-)

diff --git a/fs/fuse/dir.c b/fs/fuse/dir.c
--- a/fs/fuse/dir.c
+++ b/fs/fuse/dir.c
@@ -13,6 +13,7 @@
 #include <linux/fs_context.h>
 #include <linux/moduleparam.h>
 #include <linux/sched.h>
+#include <linux/fsnotify.h>
 #include <linux/namei.h>
 #include <linux/slab.h>
 #include <linux/xattr.h>
@@ -1413,7 +1414,11 @@ int fuse_reverse_inval_entry(struct fuse_conn *fc, u64 parent_nodeid,
  badentry:
 		inode_unlock(d_inode(entry));
-		if (!err)
-			d_delete(entry);
+		if (!err) {
+			if (child_nodeid)
+				d_delete_notify(parent, entry);
+			else
+				d_delete(entry);
+		}
 	} else {
 		err = 0;
 	}
diff --git a/fs/fuse/virtio_fs.c b/fs/fuse/virtio_fs.c
index 749c9f6..66df932 100644
--- a/fs/fuse/virtio_fs.c
+++ b/fs/fuse/virtio_fs.c
@@ -37,12 +37,23 @@ static LIST_HEAD(virtio_fs_instances);
 /* The /sys/fs/virtio_fs/ kset */
 static struct kset *virtio_fs_kset;
 
-enum {
-	VQ_HIPRIO,
-	VQ_REQUEST
+enum virtio_fs_vq_type {
+	VQ_TYPE_HIPRIO,
+	VQ_TYPE_REQUEST,
+	VQ_TYPE_NOTIFY,
 };
 
+#define VQ_HIPRIO_IDX	0
+#define VQ_NOTIFY_IDX	1
 #define VQ_NAME_LEN	24
+#define VQ_NOTIFY_ELEMS	16
+#define VQ_NOTIFY_BUF_MAX	PAGE_SIZE
+
+struct virtio_fs_notify_node {
+	struct list_head list;
+	void *buf;
+	unsigned int len;
+};
 
 /* Per-virtqueue state */
 struct virtio_fs_vq {
@@ -51,6 +62,8 @@ struct virtio_fs_vq {
 	struct work_struct done_work;
 	struct list_head queued_reqs;
 	struct list_head end_reqs;	/* End these requests */
+	struct virtio_fs_notify_node *notify_nodes;
+	struct list_head notify_reqs;
 	struct work_struct dispatch_work;
 	struct fuse_dev *fud;
 	bool connected;
@@ -69,6 +82,9 @@ struct virtio_fs {
 	struct virtio_fs_vq *vqs;
 	unsigned int nvqs;               /* number of virtqueues */
 	unsigned int num_request_queues; /* number of request queues */
+	unsigned int first_reqq_idx;     /* first request queue index */
+	unsigned int notify_buf_size;
+	bool notify_enabled;
 	struct dax_device *dax_dev;
 
 	unsigned int *mq_map; /* index = cpu id, value = request vq id */
@@ -98,6 +114,8 @@ struct virtio_fs_req_work {
 
 static int virtio_fs_enqueue_req(struct virtio_fs_vq *fsvq,
 				 struct fuse_req *req, bool in_flight);
+static int virtio_fs_enqueue_all_notify(struct virtio_fs_vq *fsvq);
+static void virtio_fs_stop_all_queues(struct virtio_fs *fs);
 
 static const struct constant_table dax_param_enums[] = {
 	{"always",	FUSE_DAX_ALWAYS },
@@ -156,6 +174,11 @@ static inline struct virtio_fs_vq *vq_to_fsvq(struct virtqueue *vq)
 	return &fs->vqs[vq->index];
 }
 
+static inline struct virtio_fs *fsvq_to_fs(struct virtio_fs_vq *fsvq)
+{
+	return fsvq->vq->vdev->priv;
+}
+
 /* Should be called with fsvq->lock held. */
 static inline void inc_in_flight_req(struct virtio_fs_vq *fsvq)
 {
@@ -187,10 +210,28 @@ static struct attribute *virtio_fs_attrs[] = {
 };
 ATTRIBUTE_GROUPS(virtio_fs);
 
+static void virtio_fs_free_notify_nodes(struct virtio_fs *fs)
+{
+	struct virtio_fs_notify_node *node;
+	unsigned int i;
+
+	if (fs->notify_enabled && fs->vqs) {
+		node = fs->vqs[VQ_NOTIFY_IDX].notify_nodes;
+		if (node) {
+			for (i = 0; i < VQ_NOTIFY_ELEMS; i++)
+				kfree(node[i].buf);
+			kfree(node);
+			fs->vqs[VQ_NOTIFY_IDX].notify_nodes = NULL;
+		}
+	}
+}
+
 static void virtio_fs_ktype_release(struct kobject *kobj)
 {
 	struct virtio_fs *vfs = container_of(kobj, struct virtio_fs, kobj);
 
+	virtio_fs_free_notify_nodes(vfs);
+
 	kfree(vfs->mq_map);
 	kfree(vfs->vqs);
 	kfree(vfs);
@@ -242,7 +283,8 @@ static ssize_t cpu_list_show(struct kobject *kobj,
 
 	qid = fsvq->vq->index;
 	for (cpu = 0; cpu < nr_cpu_ids; cpu++) {
-		if (qid < VQ_REQUEST || (fs->mq_map[cpu] == qid - VQ_REQUEST)) {
+		if (qid < fs->first_reqq_idx ||
+		    fs->mq_map[cpu] == qid - fs->first_reqq_idx) {
 			if (first)
 				ret = snprintf(buf + pos, size - pos, "%u", cpu);
 			else
@@ -319,6 +361,13 @@ static void virtio_fs_drain_all_queues_locked(struct virtio_fs *fs)
 	int i;
 
 	for (i = 0; i < fs->nvqs; i++) {
+		/* Notification buffers intentionally remain posted while the
+		 * device exists. There is no reply to wait for during unmount.
+		 */
+		if (fs->notify_enabled && i == VQ_NOTIFY_IDX) {
+			flush_work(&fs->vqs[i].done_work);
+			continue;
+		}
 		fsvq = &fs->vqs[i];
 		virtio_fs_drain_queue(fsvq);
 	}
@@ -347,6 +396,8 @@ static void virtio_fs_start_all_queues(struct virtio_fs *fs)
 		spin_lock(&fsvq->lock);
 		fsvq->connected = true;
 		spin_unlock(&fsvq->lock);
+		if (fs->notify_enabled && i == VQ_NOTIFY_IDX)
+			virtio_fs_enqueue_all_notify(fsvq);
 	}
 }
 
@@ -481,12 +532,16 @@ static void virtio_fs_free_devs(struct virtio_fs *fs)
 
 	for (i = 0; i < fs->nvqs; i++) {
 		struct virtio_fs_vq *fsvq = &fs->vqs[i];
+		struct fuse_dev *fud;
 
-		if (!fsvq->fud)
+		spin_lock(&fsvq->lock);
+		fud = fsvq->fud;
+		fsvq->fud = NULL;
+		spin_unlock(&fsvq->lock);
+		if (!fud)
 			continue;
 
-		fuse_dev_free(fsvq->fud);
-		fsvq->fud = NULL;
+		fuse_dev_free(fud);
 	}
 }
 
@@ -551,6 +606,221 @@ static void virtio_fs_hiprio_done_work(struct work_struct *work)
 	spin_unlock(&fsvq->lock);
 }
 
+static int virtio_fs_init_notify_vq(struct virtio_fs *fs,
+				    struct virtio_fs_vq *fsvq)
+{
+	struct virtio_fs_notify_node *node;
+	unsigned int i;
+
+	node = kcalloc(VQ_NOTIFY_ELEMS, sizeof(*node), GFP_KERNEL);
+	if (!node)
+		return -ENOMEM;
+
+	fsvq->notify_nodes = node;
+	for (i = 0; i < VQ_NOTIFY_ELEMS; i++) {
+		node[i].buf = kzalloc(fs->notify_buf_size, GFP_KERNEL);
+		if (!node[i].buf)
+			return -ENOMEM;
+		INIT_LIST_HEAD(&node[i].list);
+		list_add_tail(&node[i].list, &fsvq->notify_reqs);
+	}
+
+	return 0;
+}
+
+static int virtio_fs_enqueue_all_notify(struct virtio_fs_vq *fsvq)
+{
+	struct virtio_fs *fs = fsvq_to_fs(fsvq);
+	struct virtio_fs_notify_node *node, *next;
+	struct scatterlist sg;
+	bool kick = false;
+	int ret = 0;
+
+	spin_lock(&fsvq->lock);
+	if (!fsvq->connected) {
+		spin_unlock(&fsvq->lock);
+		return 0;
+	}
+
+	list_for_each_entry_safe(node, next, &fsvq->notify_reqs, list) {
+		list_del_init(&node->list);
+		sg_init_one(&sg, node->buf, fs->notify_buf_size);
+		ret = virtqueue_add_inbuf(fsvq->vq, &sg, 1, node, GFP_ATOMIC);
+		if (ret) {
+			list_add(&node->list, &fsvq->notify_reqs);
+			break;
+		}
+		inc_in_flight_req(fsvq);
+		kick = true;
+	}
+
+	if (kick)
+		kick = virtqueue_kick_prepare(fsvq->vq);
+	spin_unlock(&fsvq->lock);
+	if (kick)
+		virtqueue_notify(fsvq->vq);
+
+	return ret;
+}
+
+static int virtio_fs_notify_inval_inode(struct fuse_conn *fc,
+					const void *payload, unsigned int size)
+{
+	struct fuse_notify_inval_inode_out outarg;
+	int ret;
+
+	if (size != sizeof(outarg))
+		return -EINVAL;
+	memcpy(&outarg, payload, sizeof(outarg));
+
+	down_read(&fc->killsb);
+	ret = fuse_reverse_inval_inode(fc, outarg.ino, outarg.off, outarg.len);
+	up_read(&fc->killsb);
+	return ret;
+}
+
+static int virtio_fs_notify_inval_entry(struct fuse_conn *fc,
+					const void *payload, unsigned int size)
+{
+	struct fuse_notify_inval_entry_out outarg;
+	const unsigned char *name_buf;
+	struct qstr name;
+	int ret;
+
+	if (size < sizeof(outarg))
+		return -EINVAL;
+	memcpy(&outarg, payload, sizeof(outarg));
+	if (outarg.namelen > FUSE_NAME_MAX ||
+	    size != sizeof(outarg) + outarg.namelen + 1)
+		return -EINVAL;
+
+	name_buf = (const u8 *)payload + sizeof(outarg);
+	if (name_buf[outarg.namelen] != '\0' ||
+	    memchr(name_buf, '\0', outarg.namelen))
+		return -EINVAL;
+	name.name = name_buf;
+	name.len = outarg.namelen;
+	name.hash = 0;
+
+	down_read(&fc->killsb);
+	ret = fuse_reverse_inval_entry(fc, outarg.parent, 0, &name,
+				       outarg.flags);
+	up_read(&fc->killsb);
+	return ret;
+}
+
+static int virtio_fs_notify_delete(struct fuse_conn *fc,
+				   const void *payload, unsigned int size)
+{
+	struct fuse_notify_delete_out outarg;
+	const unsigned char *name_buf;
+	struct qstr name;
+	int ret;
+
+	if (size < sizeof(outarg))
+		return -EINVAL;
+	memcpy(&outarg, payload, sizeof(outarg));
+	if (outarg.namelen > FUSE_NAME_MAX ||
+	    size != sizeof(outarg) + outarg.namelen + 1)
+		return -EINVAL;
+
+	name_buf = (const u8 *)payload + sizeof(outarg);
+	if (name_buf[outarg.namelen] != '\0' ||
+	    memchr(name_buf, '\0', outarg.namelen))
+		return -EINVAL;
+	name.name = name_buf;
+	name.len = outarg.namelen;
+	name.hash = 0;
+
+	down_read(&fc->killsb);
+	ret = fuse_reverse_inval_entry(fc, outarg.parent, outarg.child,
+				       &name, 0);
+	up_read(&fc->killsb);
+	return ret;
+}
+
+static int virtio_fs_handle_notification(struct fuse_conn *fc,
+					 struct virtio_fs_notify_node *node,
+					 unsigned int buf_size)
+{
+	struct fuse_out_header out_hdr;
+	const void *payload;
+	unsigned int payload_size;
+
+	if (node->len < sizeof(out_hdr) || node->len > buf_size)
+		return -EINVAL;
+	memcpy(&out_hdr, node->buf, sizeof(out_hdr));
+	if (out_hdr.unique || out_hdr.len != node->len)
+		return -EINVAL;
+
+	payload = (const u8 *)node->buf + sizeof(out_hdr);
+	payload_size = node->len - sizeof(out_hdr);
+	switch (out_hdr.error) {
+	case FUSE_NOTIFY_INVAL_INODE:
+		return virtio_fs_notify_inval_inode(fc, payload, payload_size);
+	case FUSE_NOTIFY_INVAL_ENTRY:
+		return virtio_fs_notify_inval_entry(fc, payload, payload_size);
+	case FUSE_NOTIFY_DELETE:
+		return virtio_fs_notify_delete(fc, payload, payload_size);
+	default:
+		return -EOPNOTSUPP;
+	}
+}
+
+static void virtio_fs_notify_done_work(struct work_struct *work)
+{
+	struct virtio_fs_vq *fsvq = container_of(work, struct virtio_fs_vq,
+						 done_work);
+	struct virtqueue *vq = fsvq->vq;
+	struct virtio_fs_notify_node *node, *next;
+	struct virtio_fs *fs = fsvq_to_fs(fsvq);
+	struct fuse_conn *fc = NULL;
+	LIST_HEAD(done);
+	bool connected;
+
+	spin_lock(&fsvq->lock);
+	do {
+		unsigned int len;
+
+		virtqueue_disable_cb(vq);
+		while ((node = virtqueue_get_buf(vq, &len)) != NULL) {
+			node->len = len;
+			list_add_tail(&node->list, &done);
+			dec_in_flight_req(fsvq);
+		}
+	} while (!virtqueue_enable_cb(vq) && likely(!virtqueue_is_broken(vq)));
+
+	if (fsvq->connected && fsvq->fud && fsvq->fud->fc)
+		fc = fuse_conn_get(fsvq->fud->fc);
+	spin_unlock(&fsvq->lock);
+
+	list_for_each_entry_safe(node, next, &done, list) {
+		int ret = -ENOTCONN;
+
+		if (fc)
+			ret = virtio_fs_handle_notification(fc, node,
+							    fs->notify_buf_size);
+
+		if (ret && ret != -ENOENT)
+			dev_dbg(&vq->vdev->dev,
+				"virtio-fs notification rejected: %d\n", ret);
+	}
+	if (fc)
+		fuse_conn_put(fc);
+
+	spin_lock(&fsvq->lock);
+	list_splice_tail_init(&done, &fsvq->notify_reqs);
+	connected = fsvq->connected;
+	spin_unlock(&fsvq->lock);
+	if (connected)
+		virtio_fs_enqueue_all_notify(fsvq);
+}
+
+static void virtio_fs_notify_dispatch_work(struct work_struct *work)
+{
+	(void)work;
+}
+
 static void virtio_fs_request_dispatch_work(struct work_struct *work)
 {
 	struct fuse_req *req;
@@ -865,7 +1135,8 @@ static void virtio_fs_map_queues(struct virtio_device *vdev, struct virtio_fs *f
 		goto fallback;
 
 	for (q = 0; q < fs->num_request_queues; q++) {
-		mask = vdev->config->get_vq_affinity(vdev, VQ_REQUEST + q);
+		mask = vdev->config->get_vq_affinity(vdev,
+						     fs->first_reqq_idx + q);
 		if (!mask)
 			goto fallback;
 
@@ -901,24 +1172,34 @@ static void virtio_fs_vq_done(struct virtqueue *vq)
 	schedule_work(&fsvq->done_work);
 }
 
-static void virtio_fs_init_vq(struct virtio_fs_vq *fsvq, char *name,
-			      int vq_type)
+static int virtio_fs_init_vq(struct virtio_fs *fs,
+			     struct virtio_fs_vq *fsvq, char *name,
+			     enum virtio_fs_vq_type vq_type)
 {
+	int ret = 0;
+
 	strscpy(fsvq->name, name, VQ_NAME_LEN);
 	spin_lock_init(&fsvq->lock);
 	INIT_LIST_HEAD(&fsvq->queued_reqs);
 	INIT_LIST_HEAD(&fsvq->end_reqs);
+	INIT_LIST_HEAD(&fsvq->notify_reqs);
 	init_completion(&fsvq->in_flight_zero);
 
-	if (vq_type == VQ_REQUEST) {
+	if (vq_type == VQ_TYPE_REQUEST) {
 		INIT_WORK(&fsvq->done_work, virtio_fs_requests_done_work);
 		INIT_WORK(&fsvq->dispatch_work,
 				virtio_fs_request_dispatch_work);
+	} else if (vq_type == VQ_TYPE_NOTIFY) {
+		INIT_WORK(&fsvq->done_work, virtio_fs_notify_done_work);
+		INIT_WORK(&fsvq->dispatch_work, virtio_fs_notify_dispatch_work);
+		ret = virtio_fs_init_notify_vq(fs, fsvq);
 	} else {
 		INIT_WORK(&fsvq->done_work, virtio_fs_hiprio_done_work);
 		INIT_WORK(&fsvq->dispatch_work,
 				virtio_fs_hiprio_dispatch_work);
 	}
+
+	return ret;
 }
 
 /* Initialize virtqueues */
@@ -931,7 +1212,7 @@ static int virtio_fs_setup_vqs(struct virtio_device *vdev,
 	 * request queues (e.g. hiprio) don't claim any of the CPUs in
 	 * the multi-queue mapping and interrupt affinities
 	 */
-	struct irq_affinity desc = { .pre_vectors = VQ_REQUEST };
+	struct irq_affinity desc = {};
 	unsigned int i;
 	int ret = 0;
 
@@ -939,16 +1220,27 @@ static int virtio_fs_setup_vqs(struct virtio_device *vdev,
 			&fs->num_request_queues);
 	if (fs->num_request_queues == 0)
 		return -EINVAL;
+	if (virtio_has_feature(vdev, VIRTIO_FS_F_NOTIFICATION)) {
+		virtio_cread_le(vdev, struct virtio_fs_config, notify_buf_size,
+				&fs->notify_buf_size);
+		if (fs->notify_buf_size < sizeof(struct fuse_out_header) +
+					  sizeof(struct fuse_notify_inval_inode_out) ||
+		    fs->notify_buf_size > VQ_NOTIFY_BUF_MAX)
+			return -EINVAL;
+		fs->notify_enabled = true;
+	}
 
 	/* Truncate nr of request queues to nr_cpu_id */
 	fs->num_request_queues = min_t(unsigned int, fs->num_request_queues,
 					nr_cpu_ids);
-	fs->nvqs = VQ_REQUEST + fs->num_request_queues;
-	fs->vqs = kcalloc(fs->nvqs, sizeof(fs->vqs[VQ_HIPRIO]), GFP_KERNEL);
+	fs->first_reqq_idx = fs->notify_enabled ? VQ_NOTIFY_IDX + 1 : 1;
+	fs->nvqs = fs->first_reqq_idx + fs->num_request_queues;
+	desc.pre_vectors = fs->first_reqq_idx;
+	fs->vqs = kcalloc(fs->nvqs, sizeof(fs->vqs[VQ_HIPRIO_IDX]), GFP_KERNEL);
 	if (!fs->vqs)
 		return -ENOMEM;
 
-	vqs = kmalloc_array(fs->nvqs, sizeof(vqs[VQ_HIPRIO]), GFP_KERNEL);
+	vqs = kmalloc_array(fs->nvqs, sizeof(vqs[VQ_HIPRIO_IDX]), GFP_KERNEL);
 	fs->mq_map = kcalloc_node(nr_cpu_ids, sizeof(*fs->mq_map), GFP_KERNEL,
 					dev_to_node(&vdev->dev));
 	vqs_info = kcalloc(fs->nvqs, sizeof(*vqs_info), GFP_KERNEL);
@@ -958,16 +1250,32 @@ static int virtio_fs_setup_vqs(struct virtio_device *vdev,
 	}
 
 	/* Initialize the hiprio/forget request virtqueue */
-	vqs_info[VQ_HIPRIO].callback = virtio_fs_vq_done;
-	virtio_fs_init_vq(&fs->vqs[VQ_HIPRIO], "hiprio", VQ_HIPRIO);
-	vqs_info[VQ_HIPRIO].name = fs->vqs[VQ_HIPRIO].name;
+	vqs_info[VQ_HIPRIO_IDX].callback = virtio_fs_vq_done;
+	ret = virtio_fs_init_vq(fs, &fs->vqs[VQ_HIPRIO_IDX], "hiprio",
+				VQ_TYPE_HIPRIO);
+	if (ret)
+		goto out;
+	vqs_info[VQ_HIPRIO_IDX].name = fs->vqs[VQ_HIPRIO_IDX].name;
+
+	if (fs->notify_enabled) {
+		vqs_info[VQ_NOTIFY_IDX].callback = virtio_fs_vq_done;
+		ret = virtio_fs_init_vq(fs, &fs->vqs[VQ_NOTIFY_IDX],
+					"notification", VQ_TYPE_NOTIFY);
+		if (ret)
+			goto out;
+		vqs_info[VQ_NOTIFY_IDX].name = fs->vqs[VQ_NOTIFY_IDX].name;
+	}
 
 	/* Initialize the requests virtqueues */
-	for (i = VQ_REQUEST; i < fs->nvqs; i++) {
+	for (i = fs->first_reqq_idx; i < fs->nvqs; i++) {
 		char vq_name[VQ_NAME_LEN];
 
-		snprintf(vq_name, VQ_NAME_LEN, "requests.%u", i - VQ_REQUEST);
-		virtio_fs_init_vq(&fs->vqs[i], vq_name, VQ_REQUEST);
+		snprintf(vq_name, VQ_NAME_LEN, "requests.%u",
+			 i - fs->first_reqq_idx);
+		ret = virtio_fs_init_vq(fs, &fs->vqs[i], vq_name,
+					VQ_TYPE_REQUEST);
+		if (ret)
+			goto out;
 		vqs_info[i].callback = virtio_fs_vq_done;
 		vqs_info[i].name = fs->vqs[i].name;
 	}
@@ -979,13 +1287,15 @@ static int virtio_fs_setup_vqs(struct virtio_device *vdev,
 	for (i = 0; i < fs->nvqs; i++)
 		fs->vqs[i].vq = vqs[i];
 
-	virtio_fs_start_all_queues(fs);
 out:
 	kfree(vqs_info);
 	kfree(vqs);
 	if (ret) {
+		virtio_fs_free_notify_nodes(fs);
 		kfree(fs->vqs);
 		kfree(fs->mq_map);
+		fs->vqs = NULL;
+		fs->mq_map = NULL;
 	}
 	return ret;
 }
@@ -1142,6 +1452,7 @@ static int virtio_fs_probe(struct virtio_device *vdev)
