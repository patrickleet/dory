From 2b7f9076eaac234d1c7dfd5696698d6ff46bc983 Mon Sep 17 00:00:00 2001
From: Dory Kernel Port <dev@dory.local>
Date: Fri, 10 Jul 2026 03:30:00 +0000
Subject: [PATCH] virtiofs: quiesce and reclaim notification buffers

Notification buffers stay posted for the lifetime of a virtio-fs device.  A
device reset must therefore detach every unused token before del_vqs()
frees the vring, otherwise DMA API transports retain mappings to buffers
that are later freed.

Break the device and synchronize callbacks before reset, flush work once no
new callback can be queued, then reclaim the posted inbufs.  Also leave the
notification queue disconnected until fill_super() has installed every
fuse_dev, closing the publication race with notification completion work.

Signed-off-by: Dory Kernel Port <dev@dory.local>
---
 fs/fuse/virtio_fs.c | 46 ++++++++++++++++++++++++++++++++++++++++------
 1 file changed, 40 insertions(+), 6 deletions(-)

diff --git a/fs/fuse/virtio_fs.c b/fs/fuse/virtio_fs.c
--- a/fs/fuse/virtio_fs.c
+++ b/fs/fuse/virtio_fs.c
@@ -663,6 +663,29 @@ static int virtio_fs_enqueue_all_notify(struct virtio_fs_vq *fsvq)
 	return ret;
 }
 
+/* The device is reset and callbacks are synchronized before this runs, so
+ * every token still owned by the vring is unused and safe to detach.
+ */
+static void virtio_fs_reclaim_notify_bufs(struct virtio_fs *fs)
+{
+	struct virtio_fs_notify_node *node;
+	struct virtio_fs_vq *fsvq;
+
+	if (!fs->notify_enabled || !fs->vqs)
+		return;
+
+	fsvq = &fs->vqs[VQ_NOTIFY_IDX];
+	spin_lock(&fsvq->lock);
+	while ((node = virtqueue_detach_unused_buf(fsvq->vq)) != NULL) {
+		WARN_ON_ONCE(!list_empty(&node->list));
+		node->len = 0;
+		list_add_tail(&node->list, &fsvq->notify_reqs);
+		dec_in_flight_req(fsvq);
+	}
+	WARN_ON_ONCE(fsvq->in_flight);
+	spin_unlock(&fsvq->lock);
+}
+
 static int virtio_fs_notify_inval_inode(struct fuse_conn *fc,
 					const void *payload, unsigned int size)
 {
@@ -1452,7 +1475,6 @@ static int virtio_fs_probe(struct virtio_device *vdev)
 	 * requests need to be sent before we return.
 	 */
 	virtio_device_ready(vdev);
-	virtio_fs_start_all_queues(fs);
 
 	ret = virtio_fs_add_instance(vdev, fs);
 	if (ret < 0)
@@ -1461,9 +1483,16 @@ static int virtio_fs_probe(struct virtio_device *vdev)
 	return 0;
 
 out_vqs:
+	/* Stop producers first.  break+synchronize guarantees no callback can
+	 * queue work after the second drain or race the reset/reclaim sequence.
+	 */
 	virtio_fs_stop_all_queues(fs);
-	virtio_reset_device(vdev);
 	virtio_fs_drain_all_queues(fs);
+	virtio_break_device(vdev);
+	virtio_synchronize_cbs(vdev);
+	virtio_fs_drain_all_queues(fs);
+	virtio_reset_device(vdev);
+	virtio_fs_reclaim_notify_bufs(fs);
 	virtio_fs_cleanup_vqs(vdev);
 
 out:
@@ -1498,11 +1527,16 @@ static void virtio_fs_remove(struct virtio_device *vdev)
 	kobject_del(&fs->kobj);
 	virtio_fs_stop_all_queues(fs);
 	virtio_fs_drain_all_queues_locked(fs);
+
+	/* A callback can be raised between the first flush and reset.  Break the
+	 * device, synchronize the callback source, and flush any work it queued
+	 * before tearing down the vring or freeing notification storage.
+	 */
+	virtio_break_device(vdev);
+	virtio_synchronize_cbs(vdev);
+	virtio_fs_drain_all_queues_locked(fs);
 	virtio_reset_device(vdev);
-	/* No notification callback can be queued after reset. Flush a second
-	 * time before the notification buffers are eventually freed.
-	 */
-	virtio_fs_drain_all_queues_locked(fs);
+	virtio_fs_reclaim_notify_bufs(fs);
 	virtio_fs_cleanup_vqs(vdev);
 
 	vdev->priv = NULL;
-- 
