From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Augustus Otu <augustusotu@users.noreply.github.com>
Date: Fri, 10 Jul 2026 06:21:10 +0000
Subject: [PATCH] fuse: fail closed on dirty reverse invalidation

A same-inode host write can race a dirty guest MAP_SHARED folio. The
normal page-cache invalidator launders that folio, allowing stale guest
data to overwrite the host edit after the notification.

Add a clean-only invalidator that never waits for writeback and never
calls laundering or release callbacks. Dirty, writeback, private, and
DAX conflicts fail closed. Acquire only the VFS and page-cache locks with
fair blocking; Dory's host deadline supplies the hard bound and VM recovery.

FUSE writeback copies dirty data into a temporary folio before inserting
its request into fi->writepages. Track constructors before either
write_cache_pages() or launder_folio can clear dirtiness, and pair that
counter with a regular-file-only reverse-invalidation flag under
fi->lock. A nonblocking NOWRITE fence and complete pre/post checks then
cover both the pre-tree copy window and queued or sent writeback. Refuse
async direct I/O and passthrough because they can outlive or bypass the
FUSE inode lock.

Withhold a rejected virtio-fs notification token. Dory closes its host
request-publication gate before posting the notification and latches it
on failure, so releasing the temporary NOWRITE bias cannot publish a
stale write across the failed fence. Do not abort a live virtio
transport.

Signed-off-by: Augustus Otu <augustusotu@users.noreply.github.com>
---
 fs/fuse/file.c          | 108 +++++++++++++++++++++++++++-
 fs/fuse/fuse_i.h        |  12 ++++
 fs/fuse/inode.c         |  56 ++++++++++++++-
 fs/fuse/virtio_fs.c     |   9 ++-
 include/linux/pagemap.h |   2 +
 mm/truncate.c           | 146 ++++++++++++++++++++++++++++++++++++++
 6 files changed, 328 insertions(+), 5 deletions(-)

diff --git a/fs/fuse/file.c b/fs/fuse/file.c
index f597f7e..04904ec 100644
--- a/fs/fuse/file.c
+++ b/fs/fuse/file.c
@@ -470,6 +470,33 @@ static inline bool fuse_page_is_writeback(struct inode *inode, pgoff_t index)
 	return fuse_range_is_writeback(inode, index, index);
 }
 
+/*
+ * Pair writeback construction with reverse invalidation under fi->lock.
+ * The counter starts before write_cache_pages() can clear folio dirtiness and
+ * before fuse_writepage_locked() can allocate or copy a temporary folio.
+ */
+static bool fuse_writeback_inflight_start(struct fuse_inode *fi)
+{
+	bool started = false;
+
+	spin_lock(&fi->lock);
+	if (!fi->reverse_inval) {
+		fi->writeback_inflight++;
+		started = true;
+	}
+	spin_unlock(&fi->lock);
+
+	return started;
+}
+
+static void fuse_writeback_inflight_end(struct fuse_inode *fi)
+{
+	spin_lock(&fi->lock);
+	if (!WARN_ON_ONCE(!fi->writeback_inflight))
+		fi->writeback_inflight--;
+	spin_unlock(&fi->lock);
+}
+
 /*
  * Wait for page writeback to be completed.
  *
@@ -1896,6 +1923,73 @@ __acquires(fi->lock)
 	}
 }
 
+/*
+ * Fence FUSE writeback without waiting for an existing request. Checking the
+ * constructor counter and setting reverse_inval under the same lock proves
+ * that an empty writepages tree cannot hide a copied temporary folio.
+ */
+int fuse_reverse_inval_nowrite_start(struct inode *inode)
+{
+	struct fuse_inode *fi = get_fuse_inode(inode);
+	int ret = -EBUSY;
+
+	if (WARN_ON_ONCE(!S_ISREG(inode->i_mode)))
+		return -EINVAL;
+	if (WARN_ON_ONCE(!inode_is_locked(inode)))
+		return -EBUSY;
+	/* These modes can outlive or bypass the FUSE inode lock. */
+	if (get_fuse_conn(inode)->async_dio ||
+	    get_fuse_conn(inode)->passthrough)
+		return -EBUSY;
+
+	spin_lock(&fi->lock);
+	if (!fi->reverse_inval && !fi->writeback_inflight &&
+	    fi->iocachectr >= 0 &&
+	    fi->writectr == 0 && RB_EMPTY_ROOT(&fi->writepages) &&
+	    list_empty(&fi->queued_writes)) {
+		fi->reverse_inval = true;
+		fi->writectr = FUSE_NOWRITE;
+		ret = 0;
+	}
+	spin_unlock(&fi->lock);
+
+	return ret;
+}
+
+/*
+ * Check the complete writeback state before dropping the construction fence.
+ * The host request-publication gate is already closed at this point. On
+ * failure queued writes may be published after the bias is released, but the
+ * host keeps the gate latched and cannot process them.
+ */
+int fuse_reverse_inval_nowrite_end(struct inode *inode)
+{
+	struct fuse_inode *fi = get_fuse_inode(inode);
+	int ret = 0;
+
+	if (WARN_ON_ONCE(!S_ISREG(inode->i_mode)))
+		return -EINVAL;
+	if (WARN_ON_ONCE(!inode_is_locked(inode)))
+		return -EBUSY;
+
+	spin_lock(&fi->lock);
+	if (WARN_ON_ONCE(!fi->reverse_inval ||
+			 fi->writectr != FUSE_NOWRITE)) {
+		spin_unlock(&fi->lock);
+		return -EIO;
+	}
+	if (fi->writeback_inflight || fi->iocachectr < 0 ||
+	    !RB_EMPTY_ROOT(&fi->writepages) ||
+	    !list_empty(&fi->queued_writes))
+		ret = -EBUSY;
+	fi->reverse_inval = false;
+	fi->writectr = 0;
+	fuse_flush_writepages(inode);
+	spin_unlock(&fi->lock);
+
+	return ret;
+}
+
 static struct fuse_writepage_args *fuse_insert_writeback(struct rb_root *root,
 						struct fuse_writepage_args *wpa)
 {
@@ -2382,17 +2476,20 @@ static int fuse_writepages(struct address_space *mapping,
 			   struct writeback_control *wbc)
 {
 	struct inode *inode = mapping->host;
+	struct fuse_inode *fi = get_fuse_inode(inode);
 	struct fuse_conn *fc = get_fuse_conn(inode);
 	struct fuse_fill_wb_data data;
 	int err;
 
 	err = -EIO;
 	if (fuse_is_bad(inode))
-		goto out;
+		return err;
 
 	if (wbc->sync_mode == WB_SYNC_NONE &&
 	    fc->num_background >= fc->congestion_threshold)
 		return 0;
+	if (!fuse_writeback_inflight_start(fi))
+		return -EAGAIN;
 
 	data.inode = inode;
 	data.wpa = NULL;
@@ -2415,6 +2512,7 @@ static int fuse_writepages(struct address_space *mapping,
 
 	kfree(data.orig_pages);
 out:
+	fuse_writeback_inflight_end(fi);
 	return err;
 }
 
@@ -2500,7 +2598,12 @@ static int fuse_write_end(struct file *file, struct address_space *mapping,
 
 static int fuse_launder_folio(struct folio *folio)
 {
+	struct fuse_inode *fi = get_fuse_inode(folio->mapping->host);
 	int err = 0;
+
+	if (!fuse_writeback_inflight_start(fi))
+		return -EAGAIN;
+
 	if (folio_clear_dirty_for_io(folio)) {
 		struct inode *inode = folio->mapping->host;
 
@@ -2510,6 +2613,7 @@ static int fuse_launder_folio(struct folio *folio)
 		if (!err)
 			fuse_wait_on_page_writeback(inode, folio->index);
 	}
+	fuse_writeback_inflight_end(fi);
 	return err;
 }
 
@@ -3377,6 +3481,8 @@ void fuse_init_file_inode(struct inode *inode, unsigned int flags)
 	INIT_LIST_HEAD(&fi->write_files);
 	INIT_LIST_HEAD(&fi->queued_writes);
 	fi->writectr = 0;
+	fi->writeback_inflight = 0;
+	fi->reverse_inval = false;
 	fi->iocachectr = 0;
 	init_waitqueue_head(&fi->page_waitq);
 	init_waitqueue_head(&fi->direct_io_waitq);
diff --git a/fs/fuse/fuse_i.h b/fs/fuse/fuse_i.h
index 28cf319..6bca304 100644
--- a/fs/fuse/fuse_i.h
+++ b/fs/fuse/fuse_i.h
@@ -133,6 +133,15 @@ struct fuse_inode {
 			 * (FUSE_NOWRITE) means more writes are blocked */
 			int writectr;
 
+			/*
+			 * Constructors increment writeback_inflight before they may
+			 * copy a dirty folio into a temporary writeback folio.
+			 * reverse_inval is changed under the same lock, closing the
+			 * pre-writepages-tree construction window.
+			 */
+			unsigned int writeback_inflight;
+			bool reverse_inval;
+
 			/** Number of files/maps using page cache */
 			int iocachectr;
 
@@ -1285,6 +1294,9 @@ int fuse_update_attributes(struct inode *inode, struct file *file, u32 mask);
 
 void fuse_flush_writepages(struct inode *inode);
 
+int fuse_reverse_inval_nowrite_start(struct inode *inode);
+int fuse_reverse_inval_nowrite_end(struct inode *inode);
+
 void fuse_set_nowrite(struct inode *inode);
 void fuse_release_nowrite(struct inode *inode);
 
diff --git a/fs/fuse/inode.c b/fs/fuse/inode.c
index fd3321e..00117a9 100644
--- a/fs/fuse/inode.c
+++ b/fs/fuse/inode.c
@@ -519,12 +519,20 @@ int fuse_reverse_inval_inode(struct fuse_conn *fc, u64 nodeid,
 {
 	struct fuse_inode *fi;
 	struct inode *inode;
+	struct address_space *mapping;
 	pgoff_t pg_start;
 	pgoff_t pg_end;
+	const char *failure_stage = "none";
+	bool inode_locked = false;
+	bool mapping_locked = false;
+	bool nowrite = false;
+	int ret = 0;
+	int ret2;
 
 	inode = fuse_ilookup(fc, nodeid, NULL);
 	if (!inode)
 		return -ENOENT;
+	mapping = inode->i_mapping;
 
 	fi = get_fuse_inode(inode);
 	spin_lock(&fi->lock);
@@ -539,11 +547,53 @@ int fuse_reverse_inval_inode(struct fuse_conn *fc, u64 nodeid,
 			pg_end = -1;
 		else
 			pg_end = (offset + len - 1) >> PAGE_SHIFT;
-		invalidate_inode_pages2_range(inode->i_mapping,
-					      pg_start, pg_end);
+
+		/*
+		 * Writer acquisition is fair: once queued, new readers cannot starve a
+		 * host invalidation by repeatedly winning trylocks. Dory's host-side
+		 * deadline remains the hard upper bound and restarts the VM if a lock
+		 * owner cannot drain safely. No dirty or writeback state is ever waited
+		 * out below.
+		 */
+		inode_lock(inode);
+		inode_locked = true;
+
+		/* The FUSE writeback fields share a regular-file-only union. */
+		if (S_ISREG(inode->i_mode)) {
+			ret = fuse_reverse_inval_nowrite_start(inode);
+			if (ret) {
+				failure_stage = "nowrite_start";
+				goto out;
+			}
+			nowrite = true;
+		}
+
+		filemap_invalidate_lock(mapping);
+		mapping_locked = true;
+		ret = invalidate_inode_pages2_range_clean_only(mapping,
+							       pg_start, pg_end);
+		if (ret)
+			failure_stage = "page_cache";
 	}
+
+out:
+	/* Postcheck while page-cache fills are still excluded. */
+	if (nowrite) {
+		ret2 = fuse_reverse_inval_nowrite_end(inode);
+		if (ret2) {
+			ret = ret2;
+			failure_stage = "nowrite_postcheck";
+		}
+	}
+	if (mapping_locked)
+		filemap_invalidate_unlock(mapping);
+	if (inode_locked)
+		inode_unlock(inode);
+	if (ret)
+		pr_warn_ratelimited("fuse reverse invalidation rejected: nodeid=%llu stage=%s error=%d\n",
+				    (unsigned long long)nodeid, failure_stage, ret);
 	iput(inode);
-	return 0;
+	return ret;
 }
 
 bool fuse_lock_inode(struct inode *inode)
diff --git a/fs/fuse/virtio_fs.c b/fs/fuse/virtio_fs.c
index 8b116a8..8ae4fbf 100644
--- a/fs/fuse/virtio_fs.c
+++ b/fs/fuse/virtio_fs.c
@@ -824,9 +824,16 @@ static void virtio_fs_notify_done_work(struct work_struct *work)
 			ret = virtio_fs_handle_notification(fc, node,
 							    fs->notify_buf_size);
 
-		if (ret && ret != -ENOENT)
+		if (ret && ret != -ENOENT) {
 			dev_dbg(&vq->vdev->dev,
 				"virtio-fs notification rejected: %d\n", ret);
+			/*
+			 * Withhold the token. The host closes its request-publication
+			 * gate before posting notifications and latches it on failure,
+			 * so no queued stale write can cross the failed coherence fence.
+			 */
+			list_del_init(&node->list);
+		}
 	}
 	if (fc)
 		fuse_conn_put(fc);
diff --git a/include/linux/pagemap.h b/include/linux/pagemap.h
index 68a5f1f..ffbf6c2 100644
--- a/include/linux/pagemap.h
+++ b/include/linux/pagemap.h
@@ -30,6 +30,8 @@ static inline void invalidate_remote_inode(struct inode *inode)
 int invalidate_inode_pages2(struct address_space *mapping);
 int invalidate_inode_pages2_range(struct address_space *mapping,
 		pgoff_t start, pgoff_t end);
+int invalidate_inode_pages2_range_clean_only(struct address_space *mapping,
+					     pgoff_t start, pgoff_t end);
 int kiocb_invalidate_pages(struct kiocb *iocb, size_t count);
 void kiocb_invalidate_post_direct_write(struct kiocb *iocb, size_t count);
 int filemap_invalidate_pages(struct address_space *mapping,
diff --git a/mm/truncate.c b/mm/truncate.c
index 0668cd3..3fdba96 100644
--- a/mm/truncate.c
+++ b/mm/truncate.c
@@ -575,6 +575,41 @@ static int invalidate_complete_folio2(struct address_space *mapping,
 	return 0;
 }
 
+/*
+ * Remove a clean folio without invoking filesystem release or laundering
+ * callbacks. Reverse invalidation is a data-loss boundary: writing a dirty
+ * guest folio here could overwrite the host edit that triggered it.
+ */
+static int invalidate_complete_clean_folio2(struct address_space *mapping,
+					    struct folio *folio)
+{
+	if (folio->mapping != mapping)
+		return 1;
+
+	/* Unknown private state is a hard refusal, never a reason to run I/O. */
+	if (folio_needs_release(folio))
+		return -EBUSY;
+
+	spin_lock(&mapping->host->i_lock);
+	xa_lock_irq(&mapping->i_pages);
+	if (folio_test_dirty(folio) || folio_test_writeback(folio) ||
+	    folio_needs_release(folio))
+		goto failed;
+
+	__filemap_remove_folio(folio, NULL);
+	xa_unlock_irq(&mapping->i_pages);
+	if (mapping_shrinkable(mapping))
+		inode_add_lru(mapping->host);
+	spin_unlock(&mapping->host->i_lock);
+
+	filemap_free_folio(mapping, folio);
+	return 1;
+failed:
+	xa_unlock_irq(&mapping->i_pages);
+	spin_unlock(&mapping->host->i_lock);
+	return -EBUSY;
+}
+
 static int folio_launder(struct address_space *mapping, struct folio *folio)
 {
 	if (!folio_test_dirty(folio))
@@ -679,6 +714,117 @@ int invalidate_inode_pages2_range(struct address_space *mapping,
 }
 EXPORT_SYMBOL_GPL(invalidate_inode_pages2_range);
 
+/**
+ * invalidate_inode_pages2_range_clean_only - remove only clean page cache
+ * @mapping: the address_space
+ * @start: the page offset 'from' which to invalidate
+ * @end: the page offset 'to' which to invalidate (inclusive)
+ *
+ * This is the fail-safe counterpart to invalidate_inode_pages2_range(). It
+ * never waits for writeback and never calls ->launder_folio or
+ * ->release_folio. A dirty, writeback, private, or DAX mapping is a hard
+ * -EBUSY failure. Folio locks use fair blocking acquisition; the caller and
+ * host recovery boundary must bound lock acquisition. The caller must hold
+ * mapping->invalidate_lock for write. Filesystems whose write-begin or
+ * writeback paths bypass that lock must exclude those paths separately.
+ *
+ * Return: 0 on complete invalidation, or -EBUSY when discarding the cache
+ * could lose or write back guest data.
+ */
+int invalidate_inode_pages2_range_clean_only(struct address_space *mapping,
+					     pgoff_t start, pgoff_t end)
+{
+	pgoff_t indices[PAGEVEC_SIZE];
+	struct folio_batch fbatch;
+	pgoff_t index;
+	int i;
+	int ret = 0;
+	int ret2;
+	int did_range_unmap = 0;
+	bool xa_has_values = false;
+
+	lockdep_assert_held_write(&mapping->invalidate_lock);
+	/* DAX invalidation may wait for or write back a dirty entry. */
+	if (dax_mapping(mapping))
+		return -EBUSY;
+	if (mapping_empty(mapping))
+		return 0;
+
+	folio_batch_init(&fbatch);
+	index = start;
+	while (find_get_entries(mapping, &index, end, &fbatch, indices)) {
+		for (i = 0; i < folio_batch_count(&fbatch); i++) {
+			struct folio *folio = fbatch.folios[i];
+
+			if (xa_is_value(folio)) {
+				xa_has_values = true;
+				continue;
+			}
+
+			if (!did_range_unmap && folio_mapped(folio)) {
+				unmap_mapping_pages(mapping, indices[i],
+						    1 + end - indices[i], false);
+				did_range_unmap = 1;
+			}
+
+			/* Reject unsafe state before waiting for a clean folio lock. */
+			if (folio_test_dirty(folio) || folio_test_writeback(folio) ||
+			    folio_needs_release(folio)) {
+				ret = -EBUSY;
+				continue;
+			}
+			folio_lock(folio);
+			if (unlikely(folio->mapping != mapping)) {
+				folio_unlock(folio);
+				continue;
+			}
+			if (WARN_ON_ONCE(!folio_contains(folio, indices[i]))) {
+				ret = -EBUSY;
+				folio_unlock(folio);
+				continue;
+			}
+
+			/*
+			 * Never turn a host edit into permission to flush stale
+			 * guest data. Dirty and writeback folios fail closed.
+			 */
+			if (folio_test_dirty(folio) || folio_test_writeback(folio) ||
+			    folio_needs_release(folio)) {
+				ret = -EBUSY;
+				folio_unlock(folio);
+				continue;
+			}
+
+			if (folio_mapped(folio))
+				unmap_mapping_folio(folio);
+			if (WARN_ON_ONCE(folio_mapped(folio))) {
+				ret = -EBUSY;
+				folio_unlock(folio);
+				continue;
+			}
+
+			/*
+			 * A last CPU write can race PTE teardown. The remove helper
+			 * rechecks dirty, writeback, and private state under i_pages.
+			 */
+			ret2 = invalidate_complete_clean_folio2(mapping, folio);
+			if (ret2 < 0 && (ret2 == -EBUSY || !ret))
+				ret = ret2;
+			folio_unlock(folio);
+		}
+
+		if (xa_has_values)
+			clear_shadow_entries(mapping, &fbatch, indices);
+
+		folio_batch_remove_exceptionals(&fbatch);
+		folio_batch_release(&fbatch);
+		cond_resched();
+	}
+
+	return ret;
+}
+EXPORT_SYMBOL_GPL(invalidate_inode_pages2_range_clean_only);
+
 /**
  * invalidate_inode_pages2 - remove all pages from an address_space
  * @mapping: the address_space
-- 
