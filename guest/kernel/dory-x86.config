CONFIG_PVH=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_X86_MPPARSE=y
CONFIG_SERIO_I8042=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_PCI=y
CONFIG_VIRTIO_PCI=y
CONFIG_ACPI=y
CONFIG_UNWINDER_ORC=y

# x86_64 defconfig leaves these dependency roots off. Without them, Kconfig silently drops the
# common cgroup-v2 device policy and the xtables/bridge rules Docker networking asks for.
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_NETFILTER_ADVANCED=y

# Match the container ABI exposed by the arm64 guest. These are software interfaces used by
# rootless/user-namespaced workloads and filesystem event consumers, not physical-hardware drivers.
CONFIG_USER_NS=y
CONFIG_FANOTIFY=y
