#!/bin/bash
# `dory` — Dory's command-line companion (the analog of OrbStack's `orb`). Drives Dory's own engine,
# machines, and Kubernetes from the terminal. Install:  ln -sf "$PWD/scripts/dory" /usr/local/bin/dory
set -euo pipefail

# Resolve the real script directory THROUGH symlinks — `dory` is installed as a symlink at
# /usr/local/bin (or the Homebrew bin), and a plain `dirname "$0"` would then look for the
# dory-doctor helper and recipe dir next to the symlink instead of beside the
# real script. macOS ships no `readlink -f`, so follow the chain by hand.
DORY_SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$DORY_SCRIPT_SOURCE" ]; do
  DORY_SCRIPT_DIR="$(cd -P "$(dirname "$DORY_SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
  DORY_SCRIPT_SOURCE="$(readlink "$DORY_SCRIPT_SOURCE")"
  case "$DORY_SCRIPT_SOURCE" in /*) ;; *) DORY_SCRIPT_SOURCE="$DORY_SCRIPT_DIR/$DORY_SCRIPT_SOURCE" ;; esac
done
DORY_SCRIPT_DIR="$(cd -P "$(dirname "$DORY_SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"

DORY_CLI_VERSION="0.3.0"
DORY_SOCK="${DORY_SOCK:-$HOME/.dory/dory.sock}"
KUBECONFIG_DORY="$HOME/.kube/dory-config"
RECIPE_DIR="${DORY_RECIPE_DIR:-$HOME/.dory/recipes}"
BUILTIN_RECIPE_DIR="${DORY_BUILTIN_RECIPE_DIR:-$(cd "$DORY_SCRIPT_DIR/.." && pwd)/Dory/Resources/Recipes}"

first_executable() {
  local cand
  for cand in "$@"; do
    [ -n "$cand" ] && [ -x "$cand" ] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

resolve_cli() {
  local name="$1"
  first_executable \
    "$DORY_SCRIPT_DIR/$name" \
    "$DORY_SCRIPT_DIR/../Helpers/$name" \
    "$HOME/.dory/bin/$name" \
    "$(command -v "$name" 2>/dev/null || true)"
}

CONTAINER_BIN="${DORY_CONTAINER_BIN:-$(resolve_cli container || printf '%s\n' /opt/homebrew/bin/container)}"
DOCKER_BIN="${DORY_DOCKER_BIN:-$(resolve_cli docker || printf '%s\n' docker)}"
DOCKER_COMPOSE_BIN="${DORY_DOCKER_COMPOSE_BIN:-$(resolve_cli docker-compose || printf '%s\n' docker-compose)}"
KUBECTL_BIN="${DORY_KUBECTL_BIN:-$(resolve_cli kubectl || printf '%s\n' kubectl)}"

host_guest_arch() {
  [ "$(uname -m)" = "x86_64" ] && printf '%s\n' "amd64" || printf '%s\n' "arm64"
}

# The VMM helper bundled in the app and signed with the virtualization entitlement. Falls back to a
# local dev build for low-level debugging.
vmm_helper() {
  for p in "${DORY_VMM_HELPER:-}" \
           "$DORY_SCRIPT_DIR/../Helpers/dory-vmm" \
           "$DORY_SCRIPT_DIR/../dory-core-swift/.build/debug/dory-vmm"; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return; }
  done
}

hv_helper() {
  for p in "${DORY_HV_BIN:-}" \
           "$DORY_SCRIPT_DIR/../Helpers/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/debug/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/out/Products/Release/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/out/Products/Debug/dory-hv"; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return; }
  done
}

usage() {
  cat <<EOF
dory — Dory CLI

  dory <docker args...>        Run any docker command against Dory's engine
  dory install [--json] [--dry-run]
                               Manual recovery for doryd's per-user terminal integration for docker, compose, kubectl, and dory
  dory uninstall [--json] [--dry-run]
                               Remove Dory shell integration from ~/.dory/bin and shell profiles
  dory shell <container>       Open an interactive shell in a container
  dory debug <container> [-- cmd...]
                               Enter a container's namespaces through the Dory guest agent
  dory machine <args...>       Manage doryd Linux VM machines (ls, create, start, stop, delete, run)
  dory machine exec <name> [--json] -- <command...>
                               Run a command in a machine; --json emits schema v1 result metadata
  dory machine snapshot <name> Take a Dory machine snapshot
  dory machine restore <name> <tag|image>
                               Restore, clone, import, export, or delete snapshots
  dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>
                               Export a snapshot image and upload it with aws s3 cp
  dory doctor [--json] [--active] [--bundle [PATH]] [--diff]
                               Diagnose socket, CLI, network, mounts, disk, memory, and helpers
                               (--diff shows what changed since the last healthy run)
  dory support bundle [--json] [--active] [PATH]
                               Write one redacted support zip and print the path for GitHub issues
  dory logs collect [--json] [--active] [PATH]
                               Alias for support bundle; no screenshots needed
  dory network [--json] [--active] [--probe HOST[:PORT]]
  dory network --save-probe HOST[:PORT] | --list-probes | --remove-probe HOST[:PORT]
                               Diagnose DNS, registry, proxy, ports, and *.dory.local routing
  dory network authorization-plan [--json]
                               Print doryd's resolver, pf, TLS, and low-port authorization plan
  dory network authorize [--json] [--dry-run|--apply]
                               Dry-run or apply doryd's local-domain and privileged-port plan
  dory network --lan-visible on|off
                               Publish ports to the local network, or restrict to localhost
  dory mount [--json]           Validate bind mount read/write and host-edit visibility
  dory disk [--json]            Show host, Docker, Dory state, log, and VM disk usage
  dory cleanup [--json] [--apply] [--include-volumes]
                               Show or apply safe cleanup for stopped containers, cache, and logs
  dory routes [--json]          Show published ports and inferred *.dory.local routes
  dory compat [--json] [--only TOOLS]
                               Check tool compatibility (VS Code, Testcontainers, act, ...)
  dory compat --recipe [TOOL]  Show copy-paste setup recipes with verification commands
  dory repair [all|socket|context|dns|routes|domains|ports|dockerd|engine|guest-agent] [--apply]
                               Repair a subsystem; 'all' only acts on unhealthy ones with --apply
  dory mode [manual|auto-idle|always-on|battery-saver|show]
                               Show or set the runtime availability mode
  dory idle status [--json]     Explain whether Auto-Idle could sleep and what blocks it
  dory idle history [--json] [--limit N]
                               Show doryd Auto-Idle sleep/wake transitions
  dory engine sleep|wake|status
                               Stop, start, or check the headless engine
  dory agent guide [--json|--text]
                               Emit a versioned CLI capability map for coding agents
  dory mcp serve [--read-only]
                               Serve Dory tools over stdio MCP for Claude/Cursor-style clients
  dory sandbox run [--json] [--keep] [--network none|outbound|full] [--rollback] -- <command...>
                               Run a command in a dedicated Linux VM with no host sharing by default
                               (--network none blocks all egress; outbound currently grants full
                               egress — a scoped egress filter is reserved for a future release)
  dory wait engine|container|machine [NAME] --until STATE --timeout N [--json]
                               Wait for a runtime state without hand-written polling loops
  dory events [--json] [--follow] [--limit N]
                               Show or stream idle transitions and runtime incidents
  dory usb ls|attach|detach     Inspect USB candidates and request USB/IP attach/detach
  dory expose <port|machine> [--port P] [--hostname H] [--print-command]
                               Share a local port or machine endpoint through a public HTTPS tunnel
  dory k8s <kubectl args...>   Run kubectl against Dory's Kubernetes cluster
  dory ssh <machine>           SSH into a Linux machine as you (real ssh when available)
  dory vm [--image R] [--arch amd64|arm64] [--rosetta] [--mount h:g] -- <cmd>
                               Run a container on Dory's in-process framework engine
                               (Rosetta-fast x86 + host file mounts)
  dory vm --devices            Boot a VM with USB + audio passthrough and dynamic
                               memory ballooning (reclaims RAM to macOS)
  dory version                 Print the dory CLI version
  dory help                    Show this help
EOF
}

DORY_CLI_BEGIN="# >>> dory cli >>>"
DORY_CLI_END="# <<< dory cli <<<"
DORY_CLI_PROFILES=(".zprofile" ".zshrc" ".bash_profile" ".profile")

install_usage() {
  echo "usage: dory install|uninstall [--json] [--dry-run]" >&2
}

cli_tool_source() {
  local tool="$1"
  case "$tool" in
    docker)
      first_executable "${DORY_DOCKER_BIN:-}" "$DORY_SCRIPT_DIR/docker" "$DORY_SCRIPT_DIR/../Helpers/docker" "$HOME/.dory/bin/docker" "$(command -v docker 2>/dev/null || true)"
      ;;
    docker-compose)
      first_executable "${DORY_DOCKER_COMPOSE_BIN:-}" "$DORY_SCRIPT_DIR/docker-compose" "$DORY_SCRIPT_DIR/../Helpers/docker-compose" "$HOME/.docker/cli-plugins/docker-compose" "$HOME/.dory/bin/docker-compose" "$(command -v docker-compose 2>/dev/null || true)"
      ;;
    kubectl)
      first_executable "${DORY_KUBECTL_BIN:-}" "$DORY_SCRIPT_DIR/kubectl" "$DORY_SCRIPT_DIR/../Helpers/kubectl" "$HOME/.dory/bin/kubectl" "$(command -v kubectl 2>/dev/null || true)"
      ;;
    dory)
      first_executable "$DORY_SCRIPT_DIR/dory" "$DORY_SCRIPT_SOURCE" "$HOME/.dory/bin/dory" "$(command -v dory 2>/dev/null || true)"
      ;;
    dory-doctor)
      first_executable "${DORY_DOCTOR_BIN:-}" "$DORY_SCRIPT_DIR/dory-doctor" "$DORY_SCRIPT_DIR/../Helpers/dory-doctor" "$HOME/.dory/bin/dory-doctor" "$(command -v dory-doctor 2>/dev/null || true)"
      ;;
    dorydctl)
      first_executable "${DORYDCTL_BIN:-}" "$DORY_SCRIPT_DIR/dorydctl" "$DORY_SCRIPT_DIR/../Helpers/dorydctl" "$HOME/.dory/bin/dorydctl" "$(command -v dorydctl 2>/dev/null || true)"
      ;;
    *)
      return 1
      ;;
  esac
}

cli_path_block() {
  printf '%s\nexport PATH="%s:$PATH"\n%s\n' "$DORY_CLI_BEGIN" "$HOME/.dory/bin" "$DORY_CLI_END"
}

profile_contains_dory_block() {
  local profile="$1"
  [ -f "$profile" ] && grep -Fq "$DORY_CLI_BEGIN" "$profile"
}

install_path_block() {
  local dry_run="$1" profile content updated_any=0 saw_profile=0
  for name in "${DORY_CLI_PROFILES[@]}"; do
    profile="$HOME/$name"
    [ -e "$profile" ] || continue
    saw_profile=1
    profile_contains_dory_block "$profile" && continue
    updated_any=1
    if [ "$dry_run" -eq 1 ]; then
      continue
    fi
    content="$(cat "$profile" 2>/dev/null || true)"
    {
      printf '%s' "$content"
      case "$content" in ""|*$'\n') printf '\n' ;; *) printf '\n\n' ;; esac
      cli_path_block
    } > "$profile"
  done
  if [ "$saw_profile" -eq 0 ]; then
    updated_any=1
    [ "$dry_run" -eq 1 ] || cli_path_block > "$HOME/.zprofile"
  fi
  [ "$updated_any" -eq 1 ]
}

remove_path_blocks() {
  local dry_run="$1" profile tmp changed=0
  for name in "${DORY_CLI_PROFILES[@]}"; do
    profile="$HOME/$name"
    profile_contains_dory_block "$profile" || continue
    changed=1
    [ "$dry_run" -eq 1 ] && continue
    tmp="$(mktemp -t dory-profile.XXXXXX)"
    awk -v begin="$DORY_CLI_BEGIN" -v end="$DORY_CLI_END" '
      $0 == begin { skipping = 1; next }
      $0 == end { skipping = 0; next }
      !skipping { print }
    ' "$profile" > "$tmp"
    mv "$tmp" "$profile"
  done
  [ "$changed" -eq 1 ]
}

csv_append() {
  local list="$1" item="$2"
  [ -n "$list" ] && printf '%s,%s' "$list" "$item" || printf '%s' "$item"
}

install_emit_json() {
  local action="$1" dry_run="$2" path_changed="$3" compose_installed="$4" linked_csv="$5" missing_csv="$6"
  python3 - "$action" "$dry_run" "$HOME/.dory/bin" "$path_changed" "$compose_installed" "$linked_csv" "$missing_csv" <<'PY'
import json
import sys

action, dry_run, bin_dir, path_changed, compose_installed, linked_csv, missing_csv = sys.argv[1:8]
split = lambda value: [item for item in value.split(",") if item]
print(json.dumps({
    "schema": "dev.dory.cli.install",
    "version": 1,
    "action": action,
    "dryRun": dry_run == "1",
    "binDir": bin_dir,
    "linked": split(linked_csv),
    "missing": split(missing_csv),
    "pathProfileChanged": path_changed == "1",
    "composePluginInstalled": compose_installed == "1",
}, separators=(",", ":"), sort_keys=True))
PY
}

install_cmd() {
  local action="${1:-install}" json=0 dry_run=0
  case "$action" in install|uninstall) shift || true ;; *) install_usage; exit 2 ;; esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      -h|--help|help) install_usage; return 0 ;;
      *) echo "unknown install option: $1" >&2; install_usage; exit 2 ;;
    esac
  done

  local tools=(docker docker-compose kubectl dory dory-doctor dorydctl)
  local linked_csv="" linked_words="" missing_csv="" tool source dest path_changed=0 compose_installed=0

  if [ "$action" = "uninstall" ]; then
    if remove_path_blocks "$dry_run"; then path_changed=1; fi
    if [ "$dry_run" -eq 0 ]; then
      for tool in "${tools[@]}"; do rm -f "$HOME/.dory/bin/$tool"; done
      rm -f "$HOME/.docker/cli-plugins/docker-compose"
    fi
    [ "$json" -eq 1 ] && install_emit_json "$action" "$dry_run" "$path_changed" 0 "" "" || echo "Dory shell integration removed."
    return 0
  fi

  [ "$dry_run" -eq 1 ] || mkdir -p "$HOME/.dory/bin" "$HOME/.docker/cli-plugins"
  for tool in "${tools[@]}"; do
    source="$(cli_tool_source "$tool" 2>/dev/null || true)"
    if [ -n "$source" ]; then
      linked_csv="$(csv_append "$linked_csv" "$tool")"
      linked_words="$linked_words $tool"
      dest="$HOME/.dory/bin/$tool"
      if [ "$dry_run" -eq 0 ]; then
        if [ "$source" != "$dest" ]; then
          rm -f "$dest"
          ln -s "$source" "$dest"
        fi
      fi
      if [ "$tool" = "docker-compose" ]; then
        compose_installed=1
        if [ "$dry_run" -eq 0 ]; then
          if [ "$source" != "$HOME/.docker/cli-plugins/docker-compose" ]; then
            rm -f "$HOME/.docker/cli-plugins/docker-compose"
            ln -s "$source" "$HOME/.docker/cli-plugins/docker-compose"
          fi
        fi
      fi
    else
      missing_csv="$(csv_append "$missing_csv" "$tool")"
    fi
  done
  if install_path_block "$dry_run"; then path_changed=1; fi

  if [ "$json" -eq 1 ]; then
    install_emit_json "$action" "$dry_run" "$path_changed" "$compose_installed" "$linked_csv" "$missing_csv"
  else
    echo "Dory shell integration installed in $HOME/.dory/bin"
    echo "Open a new terminal, then run: docker version"
    [ -z "$missing_csv" ] || echo "Missing bundled helpers: $missing_csv" >&2
  fi
  case "$linked_words " in *" docker "*) return 0 ;; *) return 1 ;; esac
}

recipe_files() {
  [ -d "$BUILTIN_RECIPE_DIR" ] && find "$BUILTIN_RECIPE_DIR" -maxdepth 1 \( -name '*.yaml' -o -name '*.yml' \) -print
  [ -d "$RECIPE_DIR" ] && find "$RECIPE_DIR" -maxdepth 1 \( -name '*.yaml' -o -name '*.yml' \) -print
}

recipe_field() {
  awk -v key="$1" '
    {
      key_end = index($0, ":")
      if (key_end == 0) next
      name = substr($0, 1, key_end - 1)
      sub(/^[[:space:]]+/, "", name)
      sub(/[[:space:]]+$/, "", name)
      if (name != key) next
      value = substr($0, key_end + 1)
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      print value
      exit
    }' "$2"
}

recipe_path() {
  local name="$1" file id
  if [ -f "$name" ]; then echo "$name"; return 0; fi
  while IFS= read -r file; do
    id="$(recipe_field name "$file")"
    [ "$id" = "$name" ] && { echo "$file"; return 0; }
  done < <(recipe_files | sort)
  return 1
}

recipe_ls() {
  local file id summary distro arch source
  printf '%-18s %-14s %-7s %s\n' NAME DISTRO ARCH SUMMARY
  while IFS= read -r file; do
    id="$(recipe_field name "$file")"
    summary="$(recipe_field summary "$file")"
    distro="$(recipe_field distro "$file")"
    arch="$(recipe_field arch "$file")"; [ -n "$arch" ] || arch="$(host_guest_arch)"
    case "$file" in "$RECIPE_DIR"/*) source="user" ;; *) source="built-in" ;; esac
    [ -n "$id" ] && printf '%-18s %-14s %-7s %s [%s]\n' "$id" "$distro" "$arch" "$summary" "$source"
  done < <(recipe_files | sort)
}

recipe_show() {
  local path
  path="$(recipe_path "${1:?usage: dory recipe show <name|path>}")" || { echo "recipe not found: $1" >&2; exit 1; }
  cat "$path"
}

recipe_add() {
  local src="${1:?usage: dory recipe add <url|path>}" tmp name dest
  mkdir -p "$RECIPE_DIR"
  if [[ "$src" =~ ^https?:// ]]; then
    tmp="$(mktemp -t dory-recipe.XXXXXX.yaml)"
    curl -fsSL "$src" -o "$tmp"
  else
    tmp="$src"
  fi
  [ -f "$tmp" ] || { echo "recipe file not found: $src" >&2; exit 1; }
  name="$(recipe_field name "$tmp")"
  [ -n "$name" ] || { echo "recipe is missing top-level name:" >&2; exit 1; }
  # The name becomes a filename under $RECIPE_DIR; reject traversal/separators before writing.
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid recipe name: $name" >&2; exit 2; }
  dest="$RECIPE_DIR/$name.yaml"
  cp "$tmp" "$dest"
  echo "added recipe $name -> $dest"
}

recipe_new() {
  local name="${1:?usage: dory recipe new <name>}" path
  # The name becomes a filename under $RECIPE_DIR; reject traversal/separators before writing.
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid recipe name: $name" >&2; exit 2; }
  mkdir -p "$RECIPE_DIR"
  path="$RECIPE_DIR/$name.yaml"
  [ ! -e "$path" ] || { echo "recipe already exists: $path" >&2; exit 1; }
  cat > "$path" <<EOF
name: $name
summary: Custom development environment
distro: ubuntu:24.04
arch: arm64
resources: {cpus: 2, memory: 4GiB, disk: 40GiB}
packages: []
runcmd: []
mounts: []
ports: []
env: {}
ssh: {agent_forward: true}
docker: false
user: {name: "{{host_user}}", sudo: true, shell: /bin/bash}
EOF
  echo "$path"
}

machine_recipe_plan() {
  local recipe="$1" name="$2" out="$3"
  python3 - "$recipe" "$name" "$out" <<'PY'
import json, os, platform, shlex, sys, urllib.parse

recipe_path, machine_name, out_dir = sys.argv[1:4]
host_user = os.environ.get("USER") or os.environ.get("LOGNAME") or "dory"
host_home = os.path.expanduser("~")
host_uid = os.getuid()

def scalar(value):
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in "'\"":
        return value[1:-1]
    if value.lower() == "true":
        return True
    if value.lower() == "false":
        return False
    try:
        return int(value)
    except ValueError:
        return value

def parse_inline(value):
    value = value.strip()
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [scalar(part) for part in inner.split(",")]
    if value.startswith("{") and value.endswith("}"):
        inner = value[1:-1].strip()
        if not inner:
            return {}
        result = {}
        for part in inner.split(","):
            key, raw = part.split(":", 1)
            result[key.strip()] = scalar(raw)
        return result
    return scalar(value)

def load_simple_yaml(path):
    root = {}
    lines = path and open(path, encoding="utf-8").read().splitlines() or []
    i = 0
    while i < len(lines):
        raw = lines[i]
        stripped = raw.strip()
        if not stripped or stripped.startswith("#") or raw.startswith(" "):
            i += 1
            continue
        if ":" not in raw:
            i += 1
            continue
        key, value = raw.split(":", 1)
        key = key.strip()
        value = value.strip()
        if value:
            root[key] = parse_inline(value)
            i += 1
            continue
        items = []
        mapping = {}
        i += 1
        while i < len(lines) and (lines[i].startswith(" ") or not lines[i].strip()):
            child = lines[i].strip()
            if child.startswith("- "):
                items.append(scalar(child[2:]))
            elif child and ":" in child:
                ckey, cvalue = child.split(":", 1)
                mapping[ckey.strip()] = parse_inline(cvalue)
            i += 1
        root[key] = items if items else mapping
    return root

def sub(value, user):
    if isinstance(value, str):
        return value.replace("{{host_user}}", host_user).replace("{{user}}", user)
    if isinstance(value, list):
        return [sub(v, user) for v in value]
    if isinstance(value, dict):
        return {sub(k, user): sub(v, user) for k, v in value.items()}
    return value

catalog = {
    "ubuntu:24.04": ("ubuntu", "Ubuntu", "24.04 LTS", "apt", "systemd"),
    "ubuntu:22.04": ("ubuntu", "Ubuntu", "22.04 LTS", "apt", "systemd"),
    "ubuntu:20.04": ("ubuntu", "Ubuntu", "20.04 LTS", "apt", "systemd"),
    "debian:12": ("debian", "Debian", "12", "apt", "systemd"),
    "debian:11": ("debian", "Debian", "11", "apt", "systemd"),
    "fedora:41": ("fedora", "Fedora", "41", "dnf", "systemd"),
    "fedora:40": ("fedora", "Fedora", "40", "dnf", "systemd"),
    "alpine:3.21": ("alpine", "Alpine", "3.21", "apk", "shell"),
    "alpine:3.20": ("alpine", "Alpine", "3.20", "apk", "shell"),
    "alpine:3.19": ("alpine", "Alpine", "3.19", "apk", "shell"),
    "archlinux:latest": ("arch", "Arch Linux", "Rolling", "pacman", "systemd"),
}

recipe = load_simple_yaml(recipe_path)
recipe_id = str(recipe.get("name") or "").strip()
if not recipe_id:
    raise SystemExit("recipe is missing top-level name:")
user_cfg = recipe.get("user") or {}
guest_user_template = str(user_cfg.get("name", "{{host_user}}"))
guest_user = sub(guest_user_template, guest_user_template.replace("{{host_user}}", host_user))
recipe = sub(recipe, guest_user)
distro = str(recipe.get("distro") or "ubuntu:24.04")
arch = str(recipe.get("arch") or ("amd64" if platform.machine() == "x86_64" else "arm64"))
resources = recipe.get("resources") or {}
packages = recipe.get("packages") or []
runcmd = recipe.get("runcmd") or []
mounts = recipe.get("mounts") or []
ports = [int(p) for p in (recipe.get("ports") or [])]
env = recipe.get("env") or {}
docker_enabled = bool(recipe.get("docker", False))
user_cfg = recipe.get("user") or {}
guest_user = str(user_cfg.get("name") or host_user)
guest_shell = str(user_cfg.get("shell") or "/bin/bash")
if distro not in catalog:
    raise SystemExit(f"unsupported recipe distro {distro}")
if arch not in ("arm64", "amd64"):
    raise SystemExit(f"unsupported recipe arch {arch}")
family, display, version, pkg, boot = catalog[distro]
base_tag = f"dory-machine/{distro}-{arch}-v2"
recipe_tag = f"dory-recipe/{recipe_id}-{arch}"
container = f"dory-machine-{machine_name}"
platform = f"linux/{arch}"

def size_mb(value):
    text = str(value)
    for suffix, mult in (("TiB", 1024 * 1024), ("GiB", 1024), ("MiB", 1)):
        if text.endswith(suffix):
            return int(text[:-len(suffix)]) * mult
    return None

def quote(value):
    return shlex.quote(str(value))

def package_install(names):
    if not names:
        return ""
    joined = " ".join(quote(n) for n in names)
    if pkg == "apt":
        return f"apt-get update -qq && apt-get install -y --no-install-recommends {joined} && rm -rf /var/lib/apt/lists/*"
    if pkg == "dnf":
        return f"dnf install -y {joined} && dnf clean all"
    if pkg == "apk":
        return f"apk add --no-cache {joined}"
    if pkg == "pacman":
        return f"pacman -Sy --noconfirm --needed {joined}"
    return ""

def base_dockerfile():
    if pkg == "apt":
        return f"""FROM {distro}
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \\
 && apt-get install -y --no-install-recommends systemd systemd-sysv dbus dbus-user-session sudo bash openssh-server netcat-openbsd ca-certificates iproute2 iputils-ping curl \\
 && rm -rf /var/lib/apt/lists/* \\
 && (systemctl mask systemd-resolved.service systemd-networkd.service || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    if pkg == "dnf":
        return f"""FROM {distro}
RUN dnf -y install systemd sudo passwd iproute procps-ng openssh-server nmap-ncat \\
 && dnf clean all \\
 && (systemctl mask systemd-resolved.service || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    if pkg == "apk":
        return f"""FROM {distro}
RUN apk add --no-cache bash sudo shadow iproute2 ca-certificates openssh netcat-openbsd
CMD ["tail", "-f", "/dev/null"]
"""
    if pkg == "pacman":
        return f"""FROM {distro}
RUN pacman -Sy --noconfirm --disable-sandbox --needed sudo iproute2 openssh gnu-netcat \\
 && (pacman -Scc --noconfirm --disable-sandbox || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    raise SystemExit(f"unsupported package manager {pkg}")

provision = [package_install(packages), *[str(c) for c in runcmd]]
if docker_enabled:
    provision.append("install -d -m 755 /var/run/dory")
provision_script = "\n".join(line for line in provision if line.strip())
recipe_dockerfile = f"""FROM {base_tag}
RUN <<'DORY_RECIPE'
set -e
{provision_script}
DORY_RECIPE
"""

host_config = {
    "Privileged": True,
    "CgroupnsMode": "host",
    "Tmpfs": {"/run": "", "/run/lock": "", "/tmp": ""},
    "RestartPolicy": {"Name": "unless-stopped"},
}
cpus = int(resources.get("cpus") or 0)
memory = size_mb(resources.get("memory") or "")
if cpus > 0:
    host_config["NanoCpus"] = cpus * 1000000000
if memory:
    host_config["Memory"] = memory * 1024 * 1024
binds = []
for mount in mounts:
    parts = str(mount).split(":")
    if len(parts) >= 2:
        host = os.path.expanduser(parts[0])
        guest = parts[1].replace("~", f"/home/{guest_user}", 1) if parts[1].startswith("~") else parts[1]
        suffix = ":ro" if len(parts) >= 3 and parts[2] == "ro" else ""
        binds.append(f"{host}:{guest}{suffix}")
bridge = os.path.join(host_home, ".dory", "bridge", machine_name)
binds.append(f"{bridge}:/opt/dory/bridge")
host_config["Binds"] = binds
if ports:
    host_config["PortBindings"] = {f"{p}/tcp": [{"HostPort": str(p)}] for p in ports}

labels = {
    "dory.machine": family,
    "dory.machine.version": version,
    "dory.machine.arch": arch,
    "dory.recipe": recipe_id,
}
if guest_user != "root":
    guest_home = host_home if guest_user == host_user else f"/home/{guest_user}"
    labels.update({
        "dory.machine.user": guest_user,
        "dory.machine.uid": str(host_uid if guest_user == host_user else 1000),
        "dory.machine.home": guest_home,
        "dory.machine.shell": guest_shell,
    })
if 22 in ports:
    labels["dory.machine.sshPort"] = "22"
body = {
    "Hostname": machine_name,
    "Image": recipe_tag,
    "Cmd": ["/sbin/init"] if boot == "systemd" else ["tail", "-f", "/dev/null"],
    "Env": sorted([
        "BROWSER=dory-open",
        "container=docker",
        "SSH_AUTH_SOCK=/opt/dory/bridge/credentials/ssh-agent.sock",
        "GIT_ASKPASS=/usr/local/bin/dory-git-askpass",
        "DORY_GIT_ASKPASS_SOCK=/opt/dory/bridge/credentials/git-askpass.sock",
        *[f"{k}={v}" for k, v in env.items()],
    ]),
    "StopSignal": "SIGRTMIN+3",
    "Labels": labels,
    "HostConfig": host_config,
}
if ports:
    body["ExposedPorts"] = {f"{p}/tcp": {} for p in ports}

os.makedirs(out_dir, exist_ok=True)
open(os.path.join(out_dir, "base.Dockerfile"), "w", encoding="utf-8").write(base_dockerfile())
open(os.path.join(out_dir, "recipe.Dockerfile"), "w", encoding="utf-8").write(recipe_dockerfile)
open(os.path.join(out_dir, "create.json"), "w", encoding="utf-8").write(json.dumps(body, indent=2, sort_keys=True) + "\n")
create_path = "/containers/create?name=" + urllib.parse.quote(container, safe="") + "&platform=" + urllib.parse.quote(platform, safe="")
start_path = "/containers/" + urllib.parse.quote(container, safe="") + "/start"
env_path = os.path.join(out_dir, "plan.env")
with open(env_path, "w", encoding="utf-8") as f:
    for key, value in {
        "RECIPE_ID": recipe_id,
        "DISTRO": distro,
        "ARCH": arch,
        "PLATFORM": platform,
        "BASE_TAG": base_tag,
        "RECIPE_TAG": recipe_tag,
        "CONTAINER_NAME": container,
        "BRIDGE_DIR": bridge,
        "CREATE_PATH": create_path,
        "START_PATH": start_path,
    }.items():
        f.write(f"{key}={quote(value)}\n")
PY
}

machine_create_recipe() {
  local name="" recipe="" dry_run=0 tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --recipe) recipe="${2:?usage: dory machine create <name> --recipe <name|path> [--dry-run]}"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --*) echo "unknown machine create option: $1" >&2; exit 2 ;;
      *) if [ -z "$name" ]; then name="$1"; shift; else echo "unexpected argument: $1" >&2; exit 2; fi ;;
    esac
  done
  [ -n "$name" ] && [ -n "$recipe" ] || { echo "usage: dory machine create <name> --recipe <name|path> [--dry-run]" >&2; exit 2; }
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid machine name: $name" >&2; exit 2; }
  recipe="$(recipe_path "$recipe")" || { echo "recipe not found: $recipe" >&2; exit 1; }
  tmp="$(mktemp -d -t dory-machine-recipe.XXXXXX)"
  machine_recipe_plan "$recipe" "$name" "$tmp"
  # shellcheck disable=SC1091
  source "$tmp/plan.env"
  if [ "$dry_run" -eq 1 ]; then
    echo "recipe: $RECIPE_ID"
    echo "base image: $BASE_TAG"
    echo "recipe image: $RECIPE_TAG"
    echo "container: $CONTAINER_NAME"
    echo "create path: $CREATE_PATH"
    echo "start path: $START_PATH"
    echo "--- create.json ---"
    sed -n '1,220p' "$tmp/create.json"
    echo "--- recipe.Dockerfile ---"
    sed -n '1,220p' "$tmp/recipe.Dockerfile"
    return 0
  fi
  mkdir -p "$BRIDGE_DIR"
  if ! "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$BASE_TAG" >/dev/null 2>&1; then
    "$DOCKER_BIN" -H "unix://$DORY_SOCK" build --platform "$PLATFORM" -t "$BASE_TAG" -f "$tmp/base.Dockerfile" "$tmp"
  fi
  if ! "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$RECIPE_TAG" >/dev/null 2>&1; then
    "$DOCKER_BIN" -H "unix://$DORY_SOCK" build --platform "$PLATFORM" -t "$RECIPE_TAG" -f "$tmp/recipe.Dockerfile" "$tmp"
  fi
  curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' \
    --data-binary @"$tmp/create.json" "http://dory$CREATE_PATH" >/dev/null
  curl --unix-socket "$DORY_SOCK" -fsS -X POST "http://dory$START_PATH" >/dev/null
  echo "created machine $name from recipe $RECIPE_ID"
}

dory_urlencode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

machine_container_name() {
  printf 'dory-machine-%s' "$1"
}

machine_snapshot_ref() {
  local machine="$1" selector="$2"
  if [[ "$selector" == sha256:* || "$selector" == *"/"* || "$selector" == *":"* ]]; then
    printf '%s' "$selector"
  else
    printf 'dory-snapshot/%s:%s' "$machine" "$selector"
  fi
}

machine_snapshot_create() {
  local name="${1:?usage: dory machine snapshot <name> [--note text] [--tag tag]}" note="" tag="" cid labels body repo path id
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --note) note="${2:?--note requires text}"; shift 2 ;;
      --tag) tag="${2:?--tag requires tag}"; shift 2 ;;
      --*) echo "unknown snapshot option: $1" >&2; exit 2 ;;
      *) note="$1"; shift ;;
    esac
  done
  cid="$(machine_container_name "$name")"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect "$cid" >/dev/null
  [ -n "$tag" ] || tag="s$(date -u +%s)"
  repo="dory-snapshot/$name"
  labels="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{json .Config.Labels}}' "$cid")"
  body="$(mktemp -t dory-snapshot.XXXXXX.json)"
  python3 - "$labels" "$name" "$note" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$body" <<'PY'
import json, sys

labels = json.loads(sys.argv[1] or "{}")
machine, note, created = sys.argv[2:5]
out = {}
for key in ("dory.machine", "dory.machine.version", "dory.machine.arch", "dory.machine.boot",
            "dory.recipe", "dory.machine.user", "dory.machine.uid", "dory.machine.home",
            "dory.machine.shell", "dory.machine.sshPort"):
    if labels.get(key):
        out[key] = labels[key]
out.setdefault("dory.machine.boot", "systemd")
out["dory.snapshot.of"] = machine
out["dory.snapshot.note"] = note
out["dory.snapshot.created"] = created
print(json.dumps({"Labels": out}, separators=(",", ":")))
PY
  path="/commit?container=$(dory_urlencode "$cid")&repo=$(dory_urlencode "$repo")&tag=$(dory_urlencode "$tag")"
  id="$(curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' --data-binary @"$body" "http://dory$path" \
    | python3 -c 'import json,sys; print(json.load(sys.stdin).get("Id",""))')"
  rm -f "$body"
  echo "snapshot $repo:$tag ${id:+($id)}"
}

machine_snapshot_list() {
  local machine="${1:-}" filter ids inspect
  filter="label=dory.snapshot.of"
  [ -z "$machine" ] || filter="label=dory.snapshot.of=$machine"
  ids="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" image ls -q --filter "$filter" | sort -u)"
  printf '%-32s %-20s %-19s %s\n' IMAGE MACHINE CREATED NOTE
  [ -n "$ids" ] || return 0
  inspect="$(mktemp -t dory-snapshots.XXXXXX.json)"
  # shellcheck disable=SC2086
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect $ids > "$inspect"
  python3 - "$inspect" <<'PY'
import json, sys

for image in json.load(open(sys.argv[1])):
    labels = image.get("Config", {}).get("Labels") or {}
    tags = [t for t in image.get("RepoTags") or [] if t != "<none>:<none>"]
    ref = tags[0] if tags else image.get("Id", "")
    print(f"{ref[:31]:<32} {labels.get('dory.snapshot.of','')[:19]:<20} {labels.get('dory.snapshot.created','')[:19]:<19} {labels.get('dory.snapshot.note','')}")
PY
  rm -f "$inspect"
}

machine_snapshot_create_body() {
  local image="$1" name="$2" out="$3" bridge="$4" inspect
  inspect="$(mktemp -t dory-snapshot-image.XXXXXX.json)"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$image" > "$inspect"
  python3 - "$inspect" "$image" "$name" "$bridge" > "$out" <<'PY'
import json, sys

inspect_path, image_ref, name, bridge = sys.argv[1:5]
image = json.load(open(inspect_path))[0]
labels = image.get("Config", {}).get("Labels") or {}
boot = labels.get("dory.machine.boot", "systemd")
arch = labels.get("dory.machine.arch", "amd64" if __import__("platform").machine() == "x86_64" else "arm64")
container_labels = {
    "dory.machine": labels.get("dory.machine", labels.get("dory.snapshot.of", name)),
    "dory.machine.version": labels.get("dory.machine.version", ""),
    "dory.machine.arch": arch,
    "dory.machine.boot": boot,
}
for key in ("dory.recipe", "dory.machine.user", "dory.machine.uid", "dory.machine.home", "dory.machine.shell", "dory.machine.sshPort"):
    if labels.get(key):
        container_labels[key] = labels[key]
cmd = ["/sbin/init"] if boot == "systemd" else ["tail", "-f", "/dev/null"]
body = {
    "Hostname": name,
    "Image": image_ref,
    "Cmd": cmd,
    "Env": [
        "BROWSER=dory-open",
        "container=docker",
        "SSH_AUTH_SOCK=/opt/dory/bridge/credentials/ssh-agent.sock",
        "GIT_ASKPASS=/usr/local/bin/dory-git-askpass",
        "DORY_GIT_ASKPASS_SOCK=/opt/dory/bridge/credentials/git-askpass.sock",
    ],
    "StopSignal": "SIGRTMIN+3",
    "Labels": container_labels,
    "HostConfig": {
        "Privileged": True,
        "CgroupnsMode": "host",
        "Tmpfs": {"/run": "", "/run/lock": "", "/tmp": ""},
        "RestartPolicy": {"Name": "unless-stopped"},
        "Binds": [f"{bridge}:/opt/dory/bridge"],
    },
}
print(json.dumps({"platform": f"linux/{arch}", "body": body}, separators=(",", ":")))
PY
  rm -f "$inspect"
}

machine_run_snapshot_image() {
  local name="$1" image="$2" cid bridge tmp platform create_path
  cid="$(machine_container_name "$name")"
  bridge="$HOME/.dory/bridge/$name"
  mkdir -p "$bridge"
  tmp="$(mktemp -t dory-machine-restore.XXXXXX.json)"
  machine_snapshot_create_body "$image" "$name" "$tmp" "$bridge"
  platform="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["platform"])' "$tmp")"
  python3 -c 'import json,sys; print(json.dumps(json.load(open(sys.argv[1]))["body"]))' "$tmp" > "$tmp.body"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" rm -f "$cid" >/dev/null 2>&1 || true
  create_path="/containers/create?name=$(dory_urlencode "$cid")&platform=$(dory_urlencode "$platform")"
  curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' --data-binary @"$tmp.body" "http://dory$create_path" >/dev/null
  curl --unix-socket "$DORY_SOCK" -fsS -X POST "http://dory/containers/$(dory_urlencode "$cid")/start" >/dev/null
  rm -f "$tmp" "$tmp.body"
  echo "started $name from $image"
}

machine_snapshot_restore() {
  local name="${1:?usage: dory machine restore <name> <tag|image>}" selector="${2:?usage: dory machine restore <name> <tag|image>}" image
  image="$(machine_snapshot_ref "$name" "$selector")"
  machine_run_snapshot_image "$name" "$image"
}

machine_snapshot_clone() {
  local source="${1:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" selector="${2:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" name="${3:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" image
  image="$(machine_snapshot_ref "$source" "$selector")"
  machine_run_snapshot_image "$name" "$image"
}

machine_snapshot_export() {
  local image dest
  if [ "$#" -eq 3 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
    dest="$3"
  else
    image="${1:?usage: dory machine export [machine] <tag|image> <file>}"
    dest="${2:?usage: dory machine export [machine] <tag|image> <file>}"
  fi
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" save -o "$dest" "$image"
  echo "$dest"
}

machine_snapshot_backup() {
  local image dest tmp filename
  if [ "$#" -eq 3 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
    dest="$3"
  else
    image="${1:?usage: dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>}"
    dest="${2:?usage: dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>}"
  fi
  command -v aws >/dev/null 2>&1 || { echo "aws CLI not found; install and configure aws first" >&2; exit 1; }
  case "$dest" in s3://*) ;; *) echo "backup destination must be s3://bucket/key-or-prefix" >&2; exit 2 ;; esac
  filename="$(printf '%s' "$image" | sed 's#[/:]#-#g' | tr -cd '[:alnum:]_.-').tar"
  case "$dest" in
    */) dest="$dest$filename" ;;
  esac
  tmp="$(mktemp -t dory-machine-backup.XXXXXX.tar)"
  trap 'rm -f "$tmp"' RETURN
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" save -o "$tmp" "$image"
  aws s3 cp "$tmp" "$dest"
  echo "$dest"
}

machine_snapshot_import() {
  local src="${1:?usage: dory machine import <file>}"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" load -i "$src"
}

machine_snapshot_delete() {
  local image
  if [ "$#" -eq 2 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
  else
    image="${1:?usage: dory machine delete-snapshot [machine] <tag|image>}"
  fi
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" rmi "$image"
}

dorydctl_bin() {
  first_executable \
    "${DORYDCTL_BIN:-}" \
    "$DORY_SCRIPT_DIR/dorydctl" \
    "$DORY_SCRIPT_DIR/../Helpers/dorydctl" \
    "$HOME/.dory/bin/dorydctl" \
    "$(command -v dorydctl 2>/dev/null || true)"
}

network_helper_bin() {
  first_executable \
    "${DORY_NETWORK_HELPER_BIN:-}" \
    "$DORY_SCRIPT_DIR/dory-network-helper" \
    "$DORY_SCRIPT_DIR/../Helpers/dory-network-helper" \
    "$HOME/.dory/bin/dory-network-helper" \
    "$(command -v dory-network-helper 2>/dev/null || true)"
}

network_authorization_usage() {
  cat >&2 <<'EOF'
usage:
  dory network authorization-plan [--json]
  dory network authorize [--json] [--dry-run|--apply] [--plan-json PATH] [--file-system-root PATH]

`authorize` defaults to --dry-run. Use --apply only when you intend to write /etc/resolver,
install Dory's pf anchor, enable pf, and trust the local CA. Applying requires admin privileges;
use the Settings button for the guided macOS prompt, or run from an already-root shell.
EOF
}

network_plan_text() {
  python3 -c '
import json, sys
plan = json.load(sys.stdin)
print(f"Domain suffix: {plan.get(\"suffix\", \"unknown\")}")
print(f"Mode: {plan.get(\"degradedMode\", \"unknown\")} -> {plan.get(\"authorizedMode\", \"unknown\")}")
print(f"Resolver: {plan.get(\"dnsBindAddress\", \"127.0.0.1\")}:{plan.get(\"dnsPort\", \"?\")}")
print(f"HTTP/HTTPS: 80->{plan.get(\"httpProxyPort\", \"?\")} 443->{plan.get(\"httpsProxyPort\", \"?\")}")
for forward in plan.get("privilegedTCPForwards") or []:
    print(f"Low TCP: {forward.get(\"listenPort\")}->{forward.get(\"targetPort\")}")
print("Requests:")
for request in plan.get("requests") or []:
    command = " ".join(request.get("command") or [])
    print(f"  - {request.get(\"kind\", \"unknown\")}: {request.get(\"title\", request.get(\"id\", \"?\"))} [{command}]")
'
}

network_authorize_json() {
  local plan_path="$1" dry_run="$2" results_path="$3"
  python3 - "$plan_path" "$dry_run" "$results_path" <<'PY'
import json
import sys

plan_path = sys.argv[1]
dry_run = sys.argv[2] == "1"
results_path = sys.argv[3]
plan = json.load(open(plan_path, encoding="utf-8"))
results = json.load(open(results_path, encoding="utf-8"))
print(json.dumps({
    "schema": "dev.dory.network.authorization",
    "version": 1,
    "dryRun": dry_run,
    "applied": not dry_run,
    "suffix": plan.get("suffix"),
    "degradedMode": plan.get("degradedMode"),
    "authorizedMode": plan.get("authorizedMode"),
    "privilegedTCPForwards": plan.get("privilegedTCPForwards") or [],
    "results": results,
}, separators=(",", ":"), sort_keys=True))
PY
}

network_authorize_text() {
  local plan_path="$1" dry_run="$2" results_path="$3"
  python3 - "$plan_path" "$dry_run" "$results_path" <<'PY'
import json
import sys

plan_path = sys.argv[1]
dry_run = sys.argv[2] == "1"
results_path = sys.argv[3]
plan = json.load(open(plan_path, encoding="utf-8"))
results = json.load(open(results_path, encoding="utf-8"))
mode = "dry-run" if dry_run else "applied"
print(f"Dory networking authorization {mode} for {plan.get('suffix', 'unknown')}:")
for item in results:
    print(f"  - {item.get('action', '?')} {item.get('target', '?')}")
forwards = plan.get("privilegedTCPForwards") or []
if forwards:
    shown = ", ".join(f"{item.get('listenPort')}->{item.get('targetPort')}" for item in forwards[:6])
    extra = len(forwards) - 6
    print("Low TCP forwards: " + shown + (f", +{extra} more" if extra > 0 else ""))
else:
    print("Low TCP forwards: standard 80/443 only")
PY
}

network_authorization_plan_cmd() {
  local json=0 ctl out
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) network_authorization_usage; return 0 ;;
      *) echo "unknown network authorization-plan option: $1" >&2; network_authorization_usage; exit 2 ;;
    esac
  done
  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; start Dory/doryd before inspecting networking authorization." >&2; exit 1; }
  out="$("$ctl" --timeout 10 network authorization-plan)"
  if [ "$json" -eq 1 ]; then
    printf '%s\n' "$out"
  else
    printf '%s\n' "$out" | network_plan_text
  fi
}

network_authorize_cmd() {
  local json=0 dry_run=1 apply=0 plan_path="" fs_root="" helper ctl tmp="" results_tmp="" out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --dry-run) dry_run=1; apply=0; shift ;;
      --apply) dry_run=0; apply=1; shift ;;
      --plan-json|--plan) plan_path="${2:?$1 requires a path}"; shift 2 ;;
      --file-system-root) fs_root="${2:?--file-system-root requires a path}"; shift 2 ;;
      -h|--help) network_authorization_usage; return 0 ;;
      *) echo "unknown network authorize option: $1" >&2; network_authorization_usage; exit 2 ;;
    esac
  done

  helper="$(network_helper_bin 2>/dev/null)" || { echo "dory-network-helper not found; reinstall Dory or run dory support bundle for diagnostics." >&2; exit 1; }
  if [ -z "$plan_path" ]; then
    ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; start Dory/doryd before authorizing networking." >&2; exit 1; }
    tmp="$(mktemp -t dory-network-plan.XXXXXX.json)"
    "$ctl" --timeout 10 network authorization-plan > "$tmp"
    plan_path="$tmp"
  fi

  if [ "$apply" -eq 1 ] && [ "$(id -u)" -ne 0 ]; then
    [ -z "$tmp" ] || rm -f "$tmp"
    echo "dory network authorize --apply needs admin privileges. Use Dory Settings > Network > Authorize, or rerun from an already-root shell." >&2
    exit 1
  fi

  args=(--plan-json "$plan_path")
  [ "$dry_run" -eq 1 ] && args+=(--dry-run)
  [ -n "$fs_root" ] && args+=(--file-system-root "$fs_root")
  set +e
  out="$("$helper" "${args[@]}" 2>&1)"
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    [ -z "$tmp" ] || rm -f "$tmp"
    printf '%s\n' "$out" >&2
    exit "$rc"
  fi
  results_tmp="$(mktemp -t dory-network-results.XXXXXX.json)"
  printf '%s\n' "$out" > "$results_tmp"
  if [ "$json" -eq 1 ]; then
    network_authorize_json "$plan_path" "$dry_run" "$results_tmp"
  else
    network_authorize_text "$plan_path" "$dry_run" "$results_tmp"
  fi
  rm -f "$results_tmp"
  [ -z "$tmp" ] || rm -f "$tmp"
}

network_cmd() {
  case "${1:-}" in
    authorization-plan|auth-plan) shift || true; network_authorization_plan_cmd "$@" ;;
    authorize) shift || true; network_authorize_cmd "$@" ;;
    -h|--help) doctor_cmd network --help ;;
    *) doctor_cmd network "$@" ;;
  esac
}

doryd_machine_cmd() {
  local ctl="$1" sub name args=()
  shift
  sub="${1:-list}"
  case "$sub" in
    ls|list)
      exec "$ctl" machine list
      ;;
    run|exec)
      shift
      name="${1:?usage: dory machine run <name> -- <command...>}"
      shift
      while [ "$#" -gt 0 ] && [ "${1:-}" != "--" ]; do
        args+=("$1")
        shift
      done
      [ "${1:-}" != "--" ] || shift
      [ "$#" -gt 0 ] || { echo "usage: dory machine run <name> -- <command...>" >&2; exit 2; }
      exec "$ctl" machine exec "$name" "${args[@]}" -- "$@"
      ;;
    ssh|shell)
      shift
      name="${1:?usage: dory machine shell <name>}"
      exec "$ctl" machine shell "$name"
      ;;
    clone)
      shift
      exec "$ctl" machine clone-snapshot "$@"
      ;;
    restore)
      shift
      exec "$ctl" machine restore-snapshot "$@"
      ;;
    export)
      shift
      exec "$ctl" machine export-snapshot "$@"
      ;;
    import)
      shift
      exec "$ctl" machine import-snapshot "$@"
      ;;
    delete-snapshot|rm-snapshot)
      shift
      exec "$ctl" machine delete-snapshot "$@"
      ;;
    create|update|start|stop|delete|rm|status|provision|snapshots|snapshot)
      exec "$ctl" machine "$@"
      ;;
    *)
      exec "$ctl" machine "$@"
      ;;
  esac
}

legacy_machine_cmd() {
  case "${1:-ls}" in
    create)
      shift
      if printf '%s\n' "$*" | grep -q -- '--recipe'; then
        machine_create_recipe "$@"
      else
        exec "$CONTAINER_BIN" machine create "$@"
      fi ;;
    snapshot) shift; machine_snapshot_create "$@" ;;
    snapshots|list-snapshots) shift; machine_snapshot_list "$@" ;;
    restore) shift; machine_snapshot_restore "$@" ;;
    clone) shift; machine_snapshot_clone "$@" ;;
    export) shift; machine_snapshot_export "$@" ;;
    backup) shift; machine_snapshot_backup "$@" ;;
    import) shift; machine_snapshot_import "$@" ;;
    delete-snapshot|rm-snapshot) shift; machine_snapshot_delete "$@" ;;
    *) exec "$CONTAINER_BIN" machine "$@" ;;
  esac
}

machine_cmd() {
  local ctl
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    doryd_machine_cmd "$ctl" "$@"
  fi
  if [ "${DORY_LEGACY_DOCKER_MACHINES:-0}" = "1" ]; then
    # Snapshot-family helpers return normally instead of exec'ing; propagate their status rather
    # than falling through to the "requires dorydctl" error after a successful legacy dispatch.
    local legacy_status=0
    legacy_machine_cmd "$@" || legacy_status=$?
    exit "$legacy_status"
  fi
  echo "dory machine requires dorydctl and Dory's daemon-managed VM machine runtime. Start Dory's engine; set DORY_LEGACY_DOCKER_MACHINES=1 only to inspect old container-backed machines." >&2
  exit 1
}

sandbox_usage() {
  echo "usage: dory sandbox run [--json] [--keep] [--name NAME] [--mount HOST[:GUEST[:ro|rw]]] [--network none|outbound|full] [--rollback] [--ttl-seconds N] [--memory-mb N] [--cpus N] [--kernel PATH] [--rootfs PATH] -- <command...>" >&2
  echo "  --network none disables the guest network interfaces (all egress blocked); full grants full egress." >&2
  echo "  --network outbound currently grants full egress too; a scoped egress filter is reserved for a future release, so it is reported with networkPolicyEnforced=false." >&2
}

first_file() {
  local cand
  for cand in "$@"; do
    [ -n "$cand" ] && [ -f "$cand" ] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

sandbox_default_kernel() {
  local arch repo
  arch="$(host_guest_arch)"
  repo="$(cd "$DORY_SCRIPT_DIR/.." >/dev/null 2>&1 && pwd || true)"
  first_file \
    "${DORY_SANDBOX_KERNEL:-}" \
    "${DORYD_MACHINE_KERNEL:-}" \
    "${DORYD_GUEST_KERNEL:-}" \
    "$DORY_SCRIPT_DIR/../Resources/dory-hv-kernel-$arch" \
    "$DORY_SCRIPT_DIR/../Resources/dory-hv-kernel" \
    "$repo/guest/out/Image" \
    "$repo/guest/out/bzImage-x86"
}

sandbox_default_rootfs() {
  local arch repo
  arch="$(host_guest_arch)"
  repo="$(cd "$DORY_SCRIPT_DIR/.." >/dev/null 2>&1 && pwd || true)"
  first_file \
    "${DORY_SANDBOX_ROOTFS:-}" \
    "${DORYD_MACHINE_ROOTFS:-}" \
    "${DORYD_GUEST_ROOTFS:-}" \
    "$DORY_SCRIPT_DIR/../Resources/dory-machine-rootfs-$arch.ext4" \
    "$DORY_SCRIPT_DIR/../Resources/dory-machine-rootfs.ext4" \
    "$repo/guest/out/initfs-$arch.ext4"
}

sandbox_error_json() {
  python3 - "$1" "$2" <<'PY'
import json
import sys
print(json.dumps({
    "schema": "dev.dory.sandbox.error",
    "version": 1,
    "code": sys.argv[1],
    "message": sys.argv[2],
}, separators=(",", ":"), sort_keys=True))
PY
}

sandbox_parse_mount() {
  python3 - "$1" "$2" <<'PY'
import os
import sys

raw, index = sys.argv[1], int(sys.argv[2])
mode = "rw"
parts = raw.split(":")
if parts and parts[-1] in ("ro", "rw"):
    mode = parts.pop()
if len(parts) == 1:
    host = parts[0]
    guest = ""
elif len(parts) >= 2:
    guest = parts.pop()
    host = ":".join(parts)
else:
    print("empty mount", file=sys.stderr)
    sys.exit(2)

host = os.path.abspath(os.path.expanduser(host))
if not os.path.isdir(host):
    print(f"sandbox mount host path must be an existing directory: {host}", file=sys.stderr)
    sys.exit(2)
if not guest:
    base = os.path.basename(os.path.realpath(host).rstrip(os.sep)) or "project"
    guest = f"/workspace/{base}"
if not guest.startswith("/") or guest == "/":
    print(f"sandbox mount guest path must be absolute and not /: {guest}", file=sys.stderr)
    sys.exit(2)
tag = f"dorysb{index}"
print("\t".join([tag, host, guest, mode]))
PY
}

sandbox_emit_run_result() {
  local name="$1" kept="$2" exit_code="$3" json="$4" tmp="$5" network="$6" rollback="$7" ttl_seconds="$8" snapshot_id="$9"
  python3 - "$name" "$kept" "$exit_code" "$json" "$tmp" "$network" "$rollback" "$ttl_seconds" "$snapshot_id" <<'PY'
import json
import pathlib
import sys

name, kept, exit_code, as_json, tmp, network, rollback, ttl_seconds, snapshot_id = sys.argv[1:10]
root = pathlib.Path(tmp)

def read_json(name: str, default):
    path = root / name
    try:
        return json.loads(path.read_text(encoding="utf-8") or "null")
    except Exception:
        return default

exec_result = read_json("exec.json", {})
mounts = read_json("mounts.json", [])
cleanup = {
    "stopped": (root / "stop.json").exists(),
    "deleted": (root / "delete.json").exists(),
}
rollback_result = {
    "requested": rollback == "1",
    "snapshotID": snapshot_id or None,
    "created": (root / "snapshot.json").exists(),
    "restored": (root / "rollback.json").exists(),
    "snapshotDeleted": (root / "delete-snapshot.json").exists(),
}
ttl = {
    "seconds": int(ttl_seconds),
    "scheduled": (root / "ttl.json").exists(),
}
result = {
    "schema": "dev.dory.sandbox.run",
    "version": 1,
    "sandbox": name,
    "machine": name,
    "isolation": "dedicated-vm",
    "networkPolicy": network,
    "networkPolicyEnforced": network != "outbound",
    "hostFileSharing": "scoped" if mounts else "none",
    "mounts": mounts,
    "rollback": rollback_result,
    "ttl": ttl,
    "kept": kept == "1",
    "exitCode": int(exit_code),
    "exec": exec_result,
    "cleanup": cleanup,
}
if as_json == "1":
    print(json.dumps(result, separators=(",", ":"), sort_keys=True))
else:
    stdout = exec_result.get("stdout", "")
    stderr = exec_result.get("stderr", "")
    if stdout:
        print(stdout, end="")
    if stderr:
        print(stderr, end="", file=sys.stderr)
PY
}

sandbox_run_cmd() {
  local ctl name="" keep=0 json=0 memory=2048 cpus=2 kernel="" rootfs="" tmp exec_rc=0 created=0 cwd=""
  local network="outbound" rollback=0 ttl_seconds=0 snapshot_id="" rollback_failed=0
  local mounts=() mount_tags=() mount_guests=() mount_modes=() mount_rows=() create_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --keep) keep=1; shift ;;
      --name) name="${2:?--name requires a value}"; shift 2 ;;
      --memory-mb) memory="${2:?--memory-mb requires a value}"; shift 2 ;;
      --cpus) cpus="${2:?--cpus requires a value}"; shift 2 ;;
      --kernel) kernel="${2:?--kernel requires a value}"; shift 2 ;;
      --rootfs) rootfs="${2:?--rootfs requires a value}"; shift 2 ;;
      --mount) mounts+=("${2:?--mount requires a path}"); shift 2 ;;
      --network) network="${2:?--network requires none, outbound, or full}"; shift 2 ;;
      --rollback) rollback=1; shift ;;
      --ttl-seconds) ttl_seconds="${2:?--ttl-seconds requires a value}"; shift 2 ;;
      --) shift; break ;;
      -h|--help) sandbox_usage; return 0 ;;
      --*) echo "unknown sandbox option: $1" >&2; sandbox_usage; exit 2 ;;
      *) break ;;
    esac
  done
  [ "$#" -gt 0 ] || { sandbox_usage; exit 2; }
  [[ "$memory" =~ ^[0-9]+$ ]] && [ "$memory" -gt 0 ] || { echo "invalid --memory-mb: $memory" >&2; exit 2; }
  [[ "$cpus" =~ ^[0-9]+$ ]] && [ "$cpus" -gt 0 ] || { echo "invalid --cpus: $cpus" >&2; exit 2; }
  case "$network" in
    none|outbound|full) ;;
    *) echo "invalid --network: $network (expected none, outbound, or full)" >&2; exit 2 ;;
  esac
  [[ "$ttl_seconds" =~ ^[0-9]+$ ]] || { echo "invalid --ttl-seconds: $ttl_seconds" >&2; exit 2; }

  local parsed tag host guest mode mount_index=0
  if [ "${#mounts[@]}" -gt 0 ]; then
    for raw_mount in "${mounts[@]}"; do
      if ! parsed="$(sandbox_parse_mount "$raw_mount" "$mount_index")"; then
        if [ "$json" -eq 1 ]; then sandbox_error_json "sandbox.invalid_mount" "invalid sandbox mount: $raw_mount"; fi
        exit 2
      fi
      IFS=$'\t' read -r tag host guest mode <<<"$parsed"
      mount_tags+=("$tag")
      mount_guests+=("$guest")
      mount_modes+=("$mode")
      mount_rows+=("$tag" "$host" "$guest" "$mode")
      create_args+=(--share "$tag=$host:$guest:$mode")
      [ -n "$cwd" ] || cwd="$guest"
      mount_index=$((mount_index + 1))
    done
  fi

  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; build/install doryd before using sandboxes" >&2; exit 1; }
  [ -n "$name" ] || name="dory-sandbox-$(date +%Y%m%d%H%M%S)-$RANDOM"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid sandbox name: $name" >&2; exit 2; }
  kernel="${kernel:-$(sandbox_default_kernel || true)}"
  rootfs="${rootfs:-$(sandbox_default_rootfs || true)}"
  [ -n "$kernel" ] && [ -f "$kernel" ] || { echo "sandbox kernel not found; set DORY_SANDBOX_KERNEL or build guest assets" >&2; exit 1; }
  [ -n "$rootfs" ] && [ -f "$rootfs" ] || { echo "sandbox rootfs not found; set DORY_SANDBOX_ROOTFS or build guest assets" >&2; exit 1; }

  tmp="$(mktemp -d -t dory-sandbox.XXXXXX)"
  if [ "${#mount_rows[@]}" -gt 0 ]; then
    python3 - "$tmp/mounts.json" "${mount_rows[@]}" <<'PY'
import json
import sys

path = sys.argv[1]
rows = sys.argv[2:]
mounts = []
for index in range(0, len(rows), 4):
    tag, host, guest, mode = rows[index:index + 4]
    mounts.append({
        "tag": tag,
        "hostPath": host,
        "guestPath": guest,
        "mode": mode,
        "readOnly": mode == "ro",
    })
with open(path, "w", encoding="utf-8") as handle:
    json.dump(mounts, handle, separators=(",", ":"), sort_keys=True)
PY
  fi
  if [ "${#create_args[@]}" -gt 0 ]; then
    if ! "$ctl" --timeout 120 machine create "$name" --kernel "$kernel" --rootfs "$rootfs" --memory-mb "$memory" --cpus "$cpus" "${create_args[@]}" > "$tmp/create.json"; then
      rm -rf "$tmp"
      exit 1
    fi
  else
    if ! "$ctl" --timeout 120 machine create "$name" --kernel "$kernel" --rootfs "$rootfs" --memory-mb "$memory" --cpus "$cpus" > "$tmp/create.json"; then
      rm -rf "$tmp"
      exit 1
    fi
  fi
  created=1
  if ! "$ctl" --timeout 120 machine start "$name" > "$tmp/start.json"; then
    [ "$keep" -eq 1 ] || "$ctl" --timeout 30 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
    rm -rf "$tmp"
    exit 1
  fi

  if [ "$network" = "none" ]; then
    if ! "$ctl" --timeout 120 machine exec "$name" --json -- /bin/sh -lc 'for iface in $(ls /sys/class/net 2>/dev/null || true); do [ "$iface" = lo ] && continue; ip link set "$iface" down 2>/dev/null || true; done; true' > "$tmp/network.json"; then
      [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"
      exit 1
    fi
  fi

  local idx=0
  while [ "$idx" -lt "${#mount_tags[@]}" ]; do
    if ! "$ctl" --timeout 120 machine exec "$name" --json -- /bin/sh -lc 'mkdir -p "$1" && if [ "$3" = ro ]; then mount -t virtiofs -o ro "$2" "$1"; else mount -t virtiofs "$2" "$1"; fi' sh "${mount_guests[$idx]}" "${mount_tags[$idx]}" "${mount_modes[$idx]}" > "$tmp/mount-$idx.json"; then
      [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"
      exit 1
    fi
    idx=$((idx + 1))
  done

  if [ "$rollback" -eq 1 ]; then
    snapshot_id="dory-sandbox-pre-$(date +%s)-$RANDOM"
    if ! "$ctl" --timeout 120 machine snapshot "$name" --id "$snapshot_id" --note "pre-sandbox-run" > "$tmp/snapshot.json"; then
      [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"
      exit 1
    fi
  fi

  set +e
  if [ -n "$cwd" ]; then
    "$ctl" --timeout 900 machine exec "$name" --json --cwd "$cwd" -- "$@" > "$tmp/exec.json"
  else
    "$ctl" --timeout 900 machine exec "$name" --json -- "$@" > "$tmp/exec.json"
  fi
  exec_rc=$?
  set -e

  if [ "$rollback" -eq 1 ]; then
    if ! "$ctl" --timeout 180 machine restore-snapshot "$name" "$snapshot_id" > "$tmp/rollback.json"; then
      rollback_failed=1
    fi
    "$ctl" --timeout 60 machine delete-snapshot "$name" "$snapshot_id" > "$tmp/delete-snapshot.json" 2>/dev/null || true
    if [ "$rollback_failed" -eq 1 ] && [ "$exec_rc" -eq 0 ]; then
      exec_rc=1
    fi
  fi

  if [ "$keep" -eq 1 ] && [ "$ttl_seconds" -gt 0 ]; then
    printf '{"seconds":%s,"sandbox":"%s"}\n' "$ttl_seconds" "$name" > "$tmp/ttl.json"
    if [ "${DORY_SANDBOX_DISABLE_TTL_SCHEDULER:-0}" != "1" ]; then
      (
        sleep "$ttl_seconds"
        "$ctl" --timeout 60 machine stop "$name" >/dev/null 2>&1 || true
        "$ctl" --timeout 60 machine delete "$name" >/dev/null 2>&1 || true
      ) >/dev/null 2>&1 &
    fi
  fi

  if [ "$keep" -eq 0 ] && [ "$created" -eq 1 ]; then
    "$ctl" --timeout 60 machine stop "$name" > "$tmp/stop.json" 2>/dev/null || true
    "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
  fi
  sandbox_emit_run_result "$name" "$keep" "$exec_rc" "$json" "$tmp" "$network" "$rollback" "$ttl_seconds" "$snapshot_id"
  rm -rf "$tmp"
  exit "$exec_rc"
}

sandbox_cmd() {
  case "${1:-run}" in
    run) shift || true; sandbox_run_cmd "$@" ;;
    -h|--help|help) sandbox_usage; return 0 ;;
    *) echo "usage: dory sandbox run [options] -- <command...>" >&2; exit 2 ;;
  esac
}

agent_rpc() {
  local sock="$1" method="$2" payload="$3"
  [ -n "$sock" ] && [ -S "$sock" ] || { echo "set DORY_AGENT_SOCK to a dory agent bridge socket" >&2; return 2; }
  python3 - "$sock" "$method" "$payload" <<'PY'
import json, socket, struct, sys

def recv_exactly(s, count):
    buf = b""
    while len(buf) < count:
        chunk = s.recv(count - len(buf))
        if not chunk:
            return buf
        buf += chunk
    return buf

sock_path, method, payload = sys.argv[1], sys.argv[2], json.loads(sys.argv[3])
request = json.dumps({"id": 1, "method": method, "params": payload}, separators=(",", ":")).encode()
with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
    s.connect(sock_path)
    s.sendall(struct.pack(">I", len(request)) + request)
    header = recv_exactly(s, 4)
    if len(header) != 4:
        raise SystemExit("agent closed before response")
    length = struct.unpack(">I", header)[0]
    data = recv_exactly(s, length)
    if len(data) != length:
        raise SystemExit("agent closed mid-response")
response = json.loads(data)
if response.get("error"):
    print(response["error"].get("message", "agent request failed"), file=sys.stderr)
    raise SystemExit(1)
print(json.dumps(response.get("result", {}), sort_keys=True))
PY
}

usb_rpc() {
  local method="$1" payload="$2"
  local sock="${DORY_USB_AGENT_SOCK:-${DORY_AGENT_SOCK:-}}"
  agent_rpc "$sock" "$method" "$payload"
}

debug_payload() {
  local container="$1"
  shift
  python3 - "$container" "$@" <<'PY'
import json, sys

container = sys.argv[1]
argv = sys.argv[2:]
payload = {"containerID": container}
if argv:
    payload["argv"] = argv
print(json.dumps(payload, separators=(",", ":")))
PY
}

debug_cmd() {
  local container="${1:?usage: dory debug <container> [-- cmd...]}"
  shift
  [ "${1:-}" != "--" ] || shift
  local sock="${DORY_DEBUG_AGENT_SOCK:-${DORY_AGENT_SOCK:-}}"
  local result
  result="$(agent_rpc "$sock" "debug.shell" "$(debug_payload "$container" "$@")")"
  if [ "$#" -eq 0 ]; then
    printf '%s\n' "$result"
  else
    python3 - "$result" <<'PY'
import base64, json, sys

result = json.loads(sys.argv[1])
if result.get("stdout_b64"):
    sys.stdout.buffer.write(base64.b64decode(result["stdout_b64"]))
if result.get("stderr_b64"):
    sys.stderr.buffer.write(base64.b64decode(result["stderr_b64"]))
raise SystemExit(int(result.get("exit_code", 0)))
PY
  fi
}

usb_cmd() {
  case "${1:-ls}" in
    ls)
      local hv
      hv="$(hv_helper || true)"
      if [ -n "$hv" ]; then
        "$hv" usb list
      else
        system_profiler SPUSBDataType 2>/dev/null || ioreg -p IOUSB -l
      fi
      ;;
    attach)
      shift
      local busid="" mode=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --mode) mode="${2:?usage: dory usb attach <busid> [--mode userAuthorized|seize|capture]}"; shift 2 ;;
          --*) echo "unknown usb attach option: $1" >&2; exit 2 ;;
          *) if [ -z "$busid" ]; then busid="$1"; fi; shift ;;
        esac
      done
      [ -n "$busid" ] || { echo "usage: dory usb attach <busid> [--mode userAuthorized|seize|capture]" >&2; exit 2; }
      local hv; hv="$(hv_helper || true)"
      [ -n "$hv" ] || { echo "dory usb attach needs the dory-hv engine running" >&2; exit 2; }
      # The engine (which owns the device claim + guest agent) does the claim, registers the usbip
      # export, and tells the guest to dial. Mode defaults to userAuthorized (driverless devices);
      # capture (driver-owned devices, e.g. mass storage) needs the notarized com.apple.vm.device-access.
      if [ -n "$mode" ]; then "$hv" usb attach "$busid" "$mode"; else "$hv" usb attach "$busid"; fi
      ;;
    detach)
      shift
      local busid=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --*) echo "unknown usb detach option: $1" >&2; exit 2 ;;
          *) if [ -z "$busid" ]; then busid="$1"; fi; shift ;;
        esac
      done
      [ -n "$busid" ] || { echo "usage: dory usb detach <busid>" >&2; exit 2; }
      local hv; hv="$(hv_helper || true)"
      [ -n "$hv" ] || { echo "dory usb detach needs the dory-hv engine running" >&2; exit 2; }
      "$hv" usb detach "$busid"
      ;;
    *) echo "usage: dory usb ls|attach|detach" >&2; exit 2 ;;
  esac
}

expose_cmd() {
  local target="" port="" hostname="" scheme="http" print_command=0 cloudflared url
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --port) port="${2:?usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]}"; shift 2 ;;
      --hostname) hostname="${2:?usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]}"; shift 2 ;;
      --scheme) scheme="${2:?usage: dory expose <port|machine> [--scheme http|https]}"; shift 2 ;;
      --print-command) print_command=1; shift ;;
      --*) echo "unknown expose option: $1" >&2; exit 2 ;;
      *) if [ -z "$target" ]; then target="$1"; shift; else echo "unexpected argument: $1" >&2; exit 2; fi ;;
    esac
  done
  [ -n "$target" ] || { echo "usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]" >&2; exit 2; }
  [[ "$scheme" == "http" || "$scheme" == "https" ]] || { echo "invalid expose scheme: $scheme" >&2; exit 2; }
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    port="$target"
    [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || { echo "invalid expose port: $port" >&2; exit 2; }
    url="$scheme://127.0.0.1:$port"
  else
    [[ "$target" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$ ]] || { echo "invalid machine name: $target" >&2; exit 2; }
    port="${port:-80}"
    [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || { echo "invalid expose port: $port" >&2; exit 2; }
    url="$scheme://$target.dory.local:$port"
  fi
  if [ -n "$hostname" ]; then
    [[ "$hostname" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]] || {
      echo "invalid expose hostname: $hostname" >&2; exit 2
    }
  fi
  cloudflared="${DORY_CLOUDFLARED_BIN:-$(command -v cloudflared || true)}"
  [ -n "$cloudflared" ] || { echo "cloudflared not found; install it or set DORY_CLOUDFLARED_BIN" >&2; exit 1; }
  if [ -n "$hostname" ]; then
    local tunnel="${DORY_CLOUDFLARED_TUNNEL:-}"
    [ -n "$tunnel" ] || {
      echo "exposing on a named hostname requires a pre-created cloudflared tunnel with ingress mapping $hostname -> $url" >&2
      echo "create it with: cloudflared tunnel create <name> && cloudflared tunnel route dns <name> $hostname" >&2
      echo "then set DORY_CLOUDFLARED_TUNNEL=<name> and re-run" >&2
      exit 2
    }
    local cmd=("$cloudflared" tunnel run "$tunnel")
  else
    local cmd=("$cloudflared" tunnel --url "$url")
  fi
  if [ "$print_command" -eq 1 ]; then
    printf '%q ' "${cmd[@]}"
    printf '\n'
  else
    exec "${cmd[@]}"
  fi
}

doctor_cmd() {
  local helper="${DORY_DOCTOR_BIN:-$DORY_SCRIPT_DIR/dory-doctor}"
  [ -x "$helper" ] || { echo "dory-doctor helper not found: $helper" >&2; exit 1; }
  exec "$helper" "$@"
}

support_usage() {
  echo "usage: dory support bundle [--json] [--active] [PATH]" >&2
}

support_bundle_json() {
  python3 - "$1" <<'PY'
import json
import sys

path = sys.argv[1]
print(json.dumps({
    "schema": "dev.dory.support.bundle",
    "version": 1,
    "path": path,
    "redacted": True,
    "share": "Attach this zip to your GitHub issue instead of screenshots.",
}, separators=(",", ":"), sort_keys=True))
PY
}

support_cmd() {
  local action="${1:-bundle}" json=0 active=0 path="" helper out
  case "$action" in
    bundle|collect) shift || true ;;
    -h|--help|help) support_usage; return 0 ;;
    *) support_usage; exit 2 ;;
  esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --active) active=1; shift ;;
      -h|--help) support_usage; return 0 ;;
      --*) echo "unknown support option: $1" >&2; support_usage; exit 2 ;;
      *)
        [ -z "$path" ] || { echo "support bundle accepts at most one path" >&2; support_usage; exit 2; }
        path="$1"
        shift
        ;;
    esac
  done
  helper="${DORY_DOCTOR_BIN:-$DORY_SCRIPT_DIR/dory-doctor}"
  [ -x "$helper" ] || { echo "dory-doctor helper not found: $helper" >&2; exit 1; }
  local args=(bundle)
  [ "$active" -eq 1 ] && args+=(--active)
  [ -n "$path" ] && args+=("$path")
  out="$("$helper" "${args[@]}")" || exit $?
  if [ "$json" -eq 1 ]; then
    support_bundle_json "$out"
  else
    printf 'Dory support bundle: %s\n' "$out"
    printf 'Attach this redacted zip to your GitHub issue instead of screenshots.\n'
  fi
}

logs_cmd() {
  case "${1:-collect}" in
    collect|bundle) shift || true; support_cmd bundle "$@" ;;
    -h|--help|help) echo "usage: dory logs collect [--json] [--active] [PATH]" >&2 ;;
    *) echo "usage: dory logs collect [--json] [--active] [PATH]" >&2; exit 2 ;;
  esac
}

idle_proxy_cmd() {
  local helper="${DORY_IDLE_PROXY_BIN:-$DORY_SCRIPT_DIR/dory-idle-proxy}"
  [ -x "$helper" ] || { echo "dory-idle-proxy helper not found: $helper" >&2; exit 1; }
  exec "$helper" "$@"
}

idle_history_cmd() {
  local json=0 limit=40 ctl out rc args
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --limit) limit="${2:?--limit requires a count}"; shift 2 ;;
      -h|--help) echo "usage: dory idle history [--json] [--limit N]"; return 0 ;;
      *) echo "unknown idle history option: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$limit" =~ ^[0-9]+$ ]] && [ "$limit" -ge 1 ] || { echo "invalid --limit: $limit" >&2; exit 2; }
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle history --limit "$limit" 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out"
      else
        printf '%s\n' "$out" | python3 -c '
import json, sys
rows = json.load(sys.stdin)
if not rows:
    print("No Auto-Idle transitions recorded yet.")
for row in rows:
    print("{:20} {:18} {}".format(row.get("at", "?"), row.get("state") or row.get("type", "?"), row.get("detail", "")))
'
      fi
      return 0
    fi
  fi
  args=(history --limit "$limit")
  [ "$json" -eq 1 ] && args+=(--json)
  idle_proxy_cmd "${args[@]}"
}

idle_proxy_status_cmd() {
  local json=0 ctl out rc args
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle proxy-status [--json]"; return 0 ;;
      *) echo "unknown idle proxy-status option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle status 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out" | python3 -c 'import json,sys; print(json.dumps((json.load(sys.stdin).get("proxy_state") or {}), indent=2, sort_keys=True))'
      else
        printf '%s\n' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin).get("proxy_state") or {}; print(f"Doryd idle state: {data.get(\"state\", \"unknown\")} ({data.get(\"detail\", \"no state\")})")'
      fi
      return 0
    fi
  fi
  args=(status)
  [ "$json" -eq 1 ] && args+=(--json)
  idle_proxy_cmd "${args[@]}"
}

idle_retired_cmd() {
  local action="$1"
  cat >&2 <<EOF
dory idle $action is retired. doryd owns Auto-Idle automatically while dev.dory.doryd is running.
Use: dory idle status, dory idle history, dory mode auto-idle, or dory engine sleep|wake.
EOF
  return 64
}

print_idle_status_json() {
  local json="$1"
  if [ "$json" -eq 1 ]; then
    cat
  else
    python3 -c '
import json, sys
data = json.load(sys.stdin)
print("Mode: {}".format(data.get("mode", "unknown")))
print("Auto-Idle enabled: {}".format("yes" if data.get("auto_idle_enabled") else "no"))
print("Can sleep now: {}".format("yes" if data.get("can_sleep") else "no"))
state = data.get("proxy_state") or {}
print("Doryd idle state: {} ({})".format(state.get("state", "unknown"), state.get("detail", "no state")))
blockers = data.get("blockers") or []
if blockers:
    print("Sleep blockers:")
    for blocker in blockers:
        print("  " + ", ".join(f"{key}={value}" for key, value in blocker.items()))
'
  fi
}

mode_cmd() {
  local mode="show" json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory mode [manual|auto-idle|always-on|battery-saver|show] [--json]"; return 0 ;;
      manual|auto-idle|always-on|battery-saver|show) mode="$1"; shift ;;
      *) echo "unknown mode option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    if [ "$mode" = "show" ]; then
      out="$("$ctl" --timeout 5 idle status 2>/dev/null)"
    else
      out="$("$ctl" --timeout 5 idle mode "$mode" 2>/dev/null)"
    fi
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      printf '%s\n' "$out" | print_idle_status_json "$json"
      return 0
    fi
  fi
  args=("$mode")
  [ "$json" -eq 1 ] && args+=(--json)
  doctor_cmd mode "${args[@]}"
}

idle_status_cmd() {
  local json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle status [--json]"; return 0 ;;
      *) echo "unknown idle status option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle status 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      printf '%s\n' "$out" | print_idle_status_json "$json"
      return 0
    fi
  fi
  args=(status)
  [ "$json" -eq 1 ] && args+=(--json)
  doctor_cmd idle "${args[@]}"
}

idle_set_cmd() {
  local key="" value="" json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle set KEY VALUE [--json]"; return 0 ;;
      *)
        if [ -z "$key" ]; then
          key="$1"
        elif [ -z "$value" ]; then
          value="$1"
        else
          echo "too many idle set arguments" >&2
          exit 2
        fi
        shift
        ;;
    esac
  done
  [ -n "$key" ] && [ -n "$value" ] || { echo "usage: dory idle set KEY VALUE [--json]" >&2; exit 2; }
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle set "$key" "$value" 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out"
      else
        printf '%s\n' "$out" | python3 -c '
import json, sys
data = json.load(sys.stdin)
policy = data.get("policy") or {}
print("Set idle policy. Mode: {}".format(data.get("mode", "unknown")))
print("Sleep after idle: {} minutes".format(policy.get("sleepAfterMinutes")))
print("Keep published ports awake: {}".format(policy.get("keepPublishedPortsAwake")))
print("Keep Kubernetes awake: {}".format(policy.get("keepKubernetesAwake")))
'
      fi
      return 0
    fi
  fi
  args=(set "$key" "$value")
  [ "$json" -eq 1 ] && args+=(--json)
  doctor_cmd idle "${args[@]}"
}

_engine_socket_up() { curl -sf --max-time "${2:-3}" --unix-socket "$1" http://d/_ping >/dev/null 2>&1; }

engine_cmd() {
  local action="${1:-status}" json=0 ctl out state detail message rc esock="$HOME/.dory/engine.sock" dsock="$HOME/.dory/dory.sock"
  [ "$#" -eq 0 ] || shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory engine status|wake|sleep [--json]"; return 0 ;;
      *) echo "unknown engine option: $1" >&2; exit 2 ;;
    esac
  done

  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    case "$action" in
      status)
        set +e
        out="$("$ctl" --timeout 5 engine status 2>/dev/null)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
          if [ "$json" -eq 1 ]; then
            printf '%s\n' "$out"
          else
            state="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("state","unknown"))' 2>/dev/null || printf '%s' "unknown")"
            detail="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("detail",""))' 2>/dev/null || true)"
            if [ -n "$detail" ]; then
              echo "Dory engine: $state — $detail"
            else
              echo "Dory engine: $state"
            fi
          fi
          return 0
        fi
        ;;
      wake|start)
        if [ "$json" -eq 1 ]; then exec "$ctl" --timeout 90 engine wake; fi
        set +e
        out="$("$ctl" --timeout 90 engine wake 2>&1)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ]; then
          message="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("message") or "wake requested")' 2>/dev/null || printf '%s' "wake requested")"
          echo "Dory engine: $message"
        else
          printf '%s\n' "$out" >&2
        fi
        return "$rc"
        ;;
      sleep|stop)
        if [ "$json" -eq 1 ]; then exec "$ctl" --timeout 90 engine sleep; fi
        set +e
        out="$("$ctl" --timeout 90 engine sleep 2>&1)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ]; then
          message="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("message") or "sleep requested")' 2>/dev/null || printf '%s' "sleep requested")"
          echo "Dory engine: $message"
        else
          printf '%s\n' "$out" >&2
        fi
        return "$rc"
        ;;
    esac
  fi

  # Legacy app-shim fallback: engine.sock answers only when awake; dory.sock answers while the app is
  # up and can wake the old app-owned engine on a real API call.
  case "$action" in
    status)
      if [ "$json" -eq 1 ]; then
        local fallback_state fallback_detail
        if _engine_socket_up "$esock"; then
          fallback_state="running"; fallback_detail=""
        elif _engine_socket_up "$dsock"; then
          fallback_state="sleeping"; fallback_detail="legacy app shim is reachable"
        else
          fallback_state="not-running"; fallback_detail="open the Dory app or start doryd"
        fi
        python3 - "$fallback_state" "$fallback_detail" <<'PY'
import json, sys
print(json.dumps({"state": sys.argv[1], "detail": sys.argv[2]}, separators=(",", ":"), sort_keys=True))
PY
        return 0
      fi
      if _engine_socket_up "$esock"; then
        echo "Dory engine: running"
      elif _engine_socket_up "$dsock"; then
        echo "Dory engine: sleeping (idle) — docker use or 'dory engine wake' resumes it"
      else
        echo "Dory engine: not running — open the Dory app to start it"
      fi
      ;;
    wake|start)
      if _engine_socket_up "$esock"; then
        echo "Dory engine: already running"
      elif _engine_socket_up "$dsock"; then
        # A real API call through the app's shim triggers the wake, but the shim answers /version
        # even while the engine is down, so that response is NOT proof. Confirm by the real engine
        # socket coming up.
        curl -s --max-time 90 --unix-socket "$dsock" http://d/version >/dev/null 2>&1 || true
        local waited=0
        while [ "$waited" -lt 30 ]; do
          if _engine_socket_up "$esock"; then
            echo "Dory engine: awake"
            return 0
          fi
          sleep 1
          waited=$((waited + 1))
        done
        echo "Dory engine: wake requested but the engine did not come up — see ~/.dory/engine.log" >&2
        exit 1
      else
        echo "Dory's engine is managed by the Dory app. Open Dory to start it." >&2
        exit 1
      fi
      ;;
    sleep|stop)
      echo "dorydctl not found; Dory's legacy app-owned engine sleeps on its own when idle. Open the Dory app Settings to enable Auto-Idle." >&2
      exit 1
      ;;
    *)
      echo "usage: dory engine status|wake|sleep [--json]" >&2
      exit 64
      ;;
  esac
}

wait_emit_json() {
  python3 - "$1" "$2" "$3" "$4" "$5" "$6" "$7" <<'PY'
import json
import sys

kind, target, desired, state, matched, elapsed, timeout = sys.argv[1:8]
ok = matched == "1"
print(json.dumps({
    "schema": "dev.dory.wait",
    "version": 1,
    "ok": ok,
    "status": "matched" if ok else "timeout",
    "code": "wait.matched" if ok else "wait.timeout",
    "kind": kind,
    "target": target,
    "desiredState": desired,
    "state": state,
    "matched": ok,
    "elapsedSeconds": int(elapsed),
    "timeoutSeconds": int(timeout),
}, separators=(",", ":"), sort_keys=True))
PY
}

engine_current_state() {
  local ctl out state
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    out="$("$ctl" --timeout 2 engine status 2>/dev/null || true)"
    state="$(printf '%s' "$out" | python3 -c 'import json,sys
try:
    print(json.load(sys.stdin).get("state", ""))
except Exception:
    pass' 2>/dev/null || true)"
    [ -n "$state" ] && { printf '%s\n' "$state"; return 0; }
  fi
  if _engine_socket_up "$HOME/.dory/engine.sock" 1; then
    printf '%s\n' "running"
  elif _engine_socket_up "$HOME/.dory/dory.sock" 1; then
    printf '%s\n' "sleeping"
  else
    printf '%s\n' "not-running"
  fi
}

container_current_state() {
  local target="$1" state
  state="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{.State.Status}}' "$target" 2>/dev/null || true)"
  [ -n "$state" ] && printf '%s\n' "$state" || printf '%s\n' "missing"
}

machine_current_state() {
  local target="$1" ctl out state cid
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    out="$("$ctl" --timeout 2 machine status "$target" 2>/dev/null || true)"
    state="$(printf '%s' "$out" | python3 -c 'import json,sys
try:
    print(json.load(sys.stdin).get("state", ""))
except Exception:
    pass' 2>/dev/null || true)"
    [ -n "$state" ] && { printf '%s\n' "$state"; return 0; }
  fi
  cid="$(machine_container_name "$target")"
  state="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || true)"
  [ -n "$state" ] && printf '%s\n' "$state" || printf '%s\n' "missing"
}

wait_state_matches() {
  local kind="$1" state="$2" desired="$3"
  case "$desired:$state" in
    running:running|running:awake|awake:running|awake:awake) return 0 ;;
    sleeping:sleeping|idle:sleeping) return 0 ;;
    stopped:stopped|stopped:exited|exited:exited|exited:stopped) return 0 ;;
    missing:missing|removed:missing|not-running:not-running) return 0 ;;
  esac
  [ "$state" = "$desired" ] && return 0
  if [ "$kind" = "engine" ] && [ "$desired" = "stopped" ] && [ "$state" = "not-running" ]; then
    return 0
  fi
  return 1
}

wait_usage() {
  echo "usage: dory wait engine|container|machine [NAME] --until STATE --timeout N [--interval N] [--json]" >&2
}

wait_cmd() {
  local kind="${1:-}" target="" desired="" timeout=60 interval=1 json=0 start now elapsed state
  [ -n "$kind" ] || { wait_usage; exit 2; }
  shift
  case "$kind" in
    engine) target="engine" ;;
    container|machine)
      target="${1:-}"
      [ -n "$target" ] || { wait_usage; exit 2; }
      shift
      ;;
    *) wait_usage; exit 2 ;;
  esac

  case "$kind" in
    engine) desired="running" ;;
    container|machine) desired="running" ;;
  esac

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --until) desired="${2:?--until requires a state}"; shift 2 ;;
      --timeout) timeout="${2:?--timeout requires seconds}"; shift 2 ;;
      --interval) interval="${2:?--interval requires seconds}"; shift 2 ;;
      --json) json=1; shift ;;
      -h|--help) wait_usage; return 0 ;;
      *) echo "unknown wait option: $1" >&2; wait_usage; exit 2 ;;
    esac
  done
  [[ "$timeout" =~ ^[0-9]+$ ]] || { echo "invalid --timeout: $timeout" >&2; exit 2; }
  [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -ge 1 ] || { echo "invalid --interval: $interval" >&2; exit 2; }
  [ -n "$desired" ] || { wait_usage; exit 2; }

  start="$(date +%s)"
  while :; do
    case "$kind" in
      engine) state="$(engine_current_state)" ;;
      container) state="$(container_current_state "$target")" ;;
      machine) state="$(machine_current_state "$target")" ;;
    esac
    now="$(date +%s)"
    elapsed=$((now - start))
    if wait_state_matches "$kind" "$state" "$desired"; then
      if [ "$json" -eq 1 ]; then
        wait_emit_json "$kind" "$target" "$desired" "$state" 1 "$elapsed" "$timeout"
      else
        echo "$kind $target reached $state"
      fi
      return 0
    fi
    if [ "$elapsed" -ge "$timeout" ]; then
      if [ "$json" -eq 1 ]; then
        wait_emit_json "$kind" "$target" "$desired" "$state" 0 "$elapsed" "$timeout"
      else
        echo "timed out waiting for $kind $target to reach $desired (last state: $state)" >&2
      fi
      return 1
    fi
    sleep "$interval"
  done
}

events_cmd() {
  local follow=0 json=0 limit=50 interval=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --follow) follow=1; shift ;;
      --json) json=1; shift ;;
      --limit) limit="${2:?--limit requires a count}"; shift 2 ;;
      --interval) interval="${2:?--interval requires seconds}"; shift 2 ;;
      -h|--help) echo "usage: dory events [--json] [--follow] [--limit N] [--interval N]"; return 0 ;;
      *) echo "unknown events option: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$limit" =~ ^[0-9]+$ ]] && [ "$limit" -ge 1 ] || { echo "invalid --limit: $limit" >&2; exit 2; }
  [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -ge 1 ] || { echo "invalid --interval: $interval" >&2; exit 2; }

  python3 - "$follow" "$json" "$limit" "$interval" <<'PY'
import json
import os
import sys
import time
from pathlib import Path

follow = sys.argv[1] == "1"
as_json = sys.argv[2] == "1"
limit = int(sys.argv[3])
interval = int(sys.argv[4])
home = Path.home()
idle_state = Path(os.environ.get("DORY_IDLE_STATE", str(home / ".dory" / "idle-state.json"))).expanduser()
idle_history = idle_state.with_name("idle-history.jsonl")
incidents = Path(os.environ.get("DORY_INCIDENTS", str(home / ".dory" / "incidents.jsonl"))).expanduser()


def read_jsonl(path: Path) -> list[dict]:
    out: list[dict] = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                value = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(value, dict):
                out.append(value)
    except FileNotFoundError:
        pass
    except OSError:
        pass
    return out


def idle_event(record: dict) -> dict:
    state = str(record.get("state") or "unknown")
    return {
        "schema": "dev.dory.event",
        "version": 1,
        "source": "idle",
        "type": f"idle.{state}",
        "at": record.get("at") or record.get("updated_at") or "",
        "state": state,
        "detail": record.get("detail") or "",
        "raw": record,
    }


def incident_event(record: dict) -> dict:
    event_type = str(record.get("type") or "incident")
    return {
        "schema": "dev.dory.event",
        "version": 1,
        "source": "incident",
        "type": event_type,
        "at": record.get("at") or "",
        "detail": record.get("detail") or "",
        "raw": record,
    }


def snapshot() -> list[dict]:
    events = [idle_event(item) for item in read_jsonl(idle_history)]
    events.extend(incident_event(item) for item in read_jsonl(incidents))
    events.sort(key=lambda item: (str(item.get("at") or ""), item["source"], item["type"]))
    return events[-limit:]


def emit_event(event: dict) -> None:
    if as_json:
        print(json.dumps(event, separators=(",", ":"), sort_keys=True), flush=True)
    else:
        print(f"{event.get('at') or '?':20} {event['source']:<8} {event['type']:<24} {event.get('detail', '')}", flush=True)


if not follow:
    events = snapshot()
    if as_json:
        print(json.dumps({"schema": "dev.dory.events", "version": 1, "events": events}, separators=(",", ":"), sort_keys=True))
    elif events:
        for event in events:
            emit_event(event)
    else:
        print("No Dory events recorded yet.")
    raise SystemExit(0)

for event in snapshot():
    emit_event(event)

offsets: dict[Path, int] = {}
for path in (idle_history, incidents):
    try:
        offsets[path] = path.stat().st_size
    except FileNotFoundError:
        offsets[path] = 0

while True:
    for path, convert in ((idle_history, idle_event), (incidents, incident_event)):
        try:
            size = path.stat().st_size
        except FileNotFoundError:
            offsets[path] = 0
            continue
        if size < offsets.get(path, 0):
            offsets[path] = 0
        with path.open("r", encoding="utf-8") as handle:
            handle.seek(offsets.get(path, 0))
            lines = handle.readlines()
            offsets[path] = handle.tell()
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                record = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(record, dict):
                emit_event(convert(record))
    time.sleep(interval)
PY
}

mcp_cmd() {
  local sub="${1:-serve}" read_only="${DORY_MCP_READ_ONLY:-0}"
  case "$sub" in
    serve) shift || true ;;
    -h|--help)
      echo "usage: dory mcp serve [--read-only]"
      return 0
      ;;
    *)
      echo "usage: dory mcp serve [--read-only]" >&2
      exit 2
      ;;
  esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --read-only) read_only=1; shift ;;
      --write) read_only=0; shift ;;
      -h|--help) echo "usage: dory mcp serve [--read-only]"; return 0 ;;
      *) echo "unknown mcp option: $1" >&2; exit 2 ;;
    esac
  done

  python3 /dev/fd/3 "$DORY_SCRIPT_SOURCE" "$read_only" "$DORY_CLI_VERSION" 3<<'PY'
import json
import os
import subprocess
import sys
from typing import Any, Optional

CLI = sys.argv[1]
READ_ONLY = sys.argv[2] in ("1", "true", "yes", "on")
SERVER_VERSION = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else "0.0.0"
PROTOCOL = "2025-11-25"
SUPPORTED_PROTOCOLS = {PROTOCOL, "2025-06-18"}


class ToolExecutionError(Exception):
    pass


def schema_object(properties: Optional[dict[str, Any]] = None, required: Optional[list[str]] = None) -> dict[str, Any]:
    schema: dict[str, Any] = {
        "type": "object",
        "additionalProperties": False,
    }
    if properties:
        schema["properties"] = properties
    if required:
        schema["required"] = required
    return schema


