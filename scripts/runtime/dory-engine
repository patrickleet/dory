#!/bin/bash
# dory-engine — Dory's container engine as a standalone, Colima-style runtime.
#
#   dory-engine start [--mem-mb N] [--cpus N] [--data-drive PATH]
#                     [--amd64|--no-amd64]
#                     [--gpu venus|--no-gpu] [--lan-visible|--no-lan-visible]
#   dory-engine stop
#   dory-engine status
#   dory-engine env
#
# Runs the same dory-hv engine the Dory app bundles, headless: one shared Linux VM with dockerd and
# guest free-page reporting. Pressure-triggered target reclaim is opt-in experimental behavior,
# not a comparative memory claim. The docker socket is published at
# ~/.dory/engine.sock; `dory-engine start` also creates and can switch to a `dory-engine`
# docker context so plain `docker` works.
set -euo pipefail
umask 077

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="$HERE/bin"
SHARE="$HERE/share/dory"
DORY_ROOT="$HOME/.dory"
STATE="$DORY_ROOT/standalone"
DATA_DRIVE="${DORY_DATA_DRIVE:-$HOME/Library/Application Support/Dory/Dory.dorydrive}"
SOCK="$DORY_ROOT/engine.sock"
BACKEND_SOCK="$STATE/hv/docker-backend.sock"
PIDFILE="$STATE/engine-cli.pid"
DATAPLANE_PIDFILE="$STATE/dataplane-cli.pid"
DRIVEFILE="$STATE/data-drive.path"
DRIVEIDFILE="$STATE/data-drive.id"
SETTINGSFILE="$STATE/engine-settings"
LOGFILE="$STATE/engine.log"
if [ "$(uname -m)" = "x86_64" ]; then
  GUEST_ARCH="amd64"
else
  GUEST_ARCH="arm64"
fi
KERNEL="$STATE/vm/dory-hv-kernel-$GUEST_ARCH"
KERNEL_ASSET="$SHARE/dory-hv-kernel-$GUEST_ARCH.lzfse"
ROOTFS="$STATE/vm/dory-engine-rootfs.ext4"
ROOTFS_ASSET="$SHARE/dory-engine-rootfs.ext4.lzfse"
AGENT_ASSET="$SHARE/dory-agent-linux-$GUEST_ARCH"
AGENT_OUTPUT="$STATE/bin/dory-agent-linux-$GUEST_ARCH"

LOG_MAX_BYTES="${DORY_LOG_MAX_BYTES:-8388608}"

note() { printf 'dory-engine: %s\n' "$*"; }
die() { printf 'dory-engine: %s\n' "$*" >&2; exit 1; }

remove_owned_socket_path() {
  local path="$1"
  [ ! -e "$path" ] && [ ! -L "$path" ] && return 0
  [ ! -L "$path" ] && [ -S "$path" ] \
    || die "refusing to replace non-socket or symlink path: $path"
  rm -f "$path"
}

validate_owned_socket_path() {
  local path="$1"
  [ ! -e "$path" ] && [ ! -L "$path" ] && return 0
  [ ! -L "$path" ] && [ -S "$path" ] \
    || die "refusing to replace non-socket or symlink path: $path"
}

pid_alive() {
  local pid="$1" state
  case "$pid" in ''|*[!0-9]*) return 1 ;; esac
  kill -0 "$pid" 2>/dev/null || return 1
  state="$(ps -p "$pid" -o state= 2>/dev/null | tr -d '[:space:]')"
  case "$state" in ''|Z*) return 1 ;; esac
  return 0
}

owned_pid() {
  local pidfile="$1" expected="$2" pid command
  [ -f "$pidfile" ] || return 1
  pid="$(cat "$pidfile" 2>/dev/null)" || return 1
  case "$pid" in ''|*[!0-9]*) return 1 ;; esac
  pid_alive "$pid" || return 1
  command="$(ps -p "$pid" -o command= 2>/dev/null)" || return 1
  case "$command" in *"$expected"*) printf '%s' "$pid" ;; *) return 1 ;; esac
}

rotate_log() {
  local file="$1" max="${2:-$LOG_MAX_BYTES}" size
  [ -f "$file" ] || return 0
  size="$(stat -f%z "$file" 2>/dev/null || echo 0)"
  if [ "$size" -gt "$max" ]; then
    # `tail -c` cuts on a byte boundary, so drop the partial first line (tail -n +2) and prepend a
    # marker — matching the Python/Swift rotators so the leading log entry is never garbled.
    if { printf '[log rotated to cap size; older lines dropped]\n'; tail -c "$max" "$file" | tail -n +2; } > "$file.rot" 2>/dev/null; then
      mv "$file.rot" "$file"
    else
      rm -f "$file.rot"
    fi
  fi
}

require_layout() {
  [ -x "$BIN/dory-hv" ] || die "missing $BIN/dory-hv (run from the extracted release directory)"
  [ -x "$BIN/gvproxy" ] || die "missing $BIN/gvproxy"
  [ -x "$BIN/dory-dataplane-proxy" ] || die "missing $BIN/dory-dataplane-proxy"
  [ -f "$KERNEL_ASSET" ] || [ -f "$KERNEL" ] \
    || die "missing $GUEST_ARCH kernel source and prepared cache"
}

engine_pid() {
  local pid
  if pid="$(owned_pid "$PIDFILE" "$BIN/dory-hv")"; then
    printf '%s' "$pid"
    return 0
  fi
  owned_dory_hv_pids
}

dataplane_pid() {
  local pid
  if pid="$(owned_pid "$DATAPLANE_PIDFILE" "$BIN/dory-dataplane-proxy")"; then
    printf '%s' "$pid"
    return 0
  fi
  owned_dataplane_pids
}

# A fast host shutdown can remove or fail to flush a pidfile while a helper survives. Recover only
# processes whose command carries this standalone runtime's exact private paths; helpers owned by
# doryd use ~/.dory/hv and cannot match. This is the same rule used for reparented gvproxy below.
owned_dory_hv_pids() {
  ps -axo pid=,command= 2>/dev/null | awk \
    -v state="$STATE/hv" -v backend="$BACKEND_SOCK" '
      index($0, "/awk ") == 0 && index($0, "/dory-hv engine") && index($0, "--state-dir " state) &&
      index($0, "--engine-sock " backend) && !found { print $1; found=1 }
      END { exit found ? 0 : 1 }
    '
}

# Bind a recovered process to the selected durable drive before reporting it as healthy. The
# launcher deliberately puts --kernel immediately after --data-drive, so matching both tokens
# gives the path an unambiguous right boundary even when it contains spaces. A missing/stale
# data-drive.path file must never make a running engine silently adopt a caller's requested root.
running_dory_hv_uses_drive() {
  local wanted_pid="$1" wanted_drive="$2"
  ps -axo pid=,command= 2>/dev/null | awk \
    -v wanted_pid="$wanted_pid" \
    -v state="$STATE/hv" \
    -v backend="$BACKEND_SOCK" \
    -v drive="$wanted_drive" '
      $1 == wanted_pid && index($0, "/awk ") == 0 && index($0, "/dory-hv engine") &&
      index($0, "--state-dir " state) && index($0, "--engine-sock " backend) &&
      index($0, "--data-drive " drive " --kernel ") { found=1 }
      END { exit found ? 0 : 1 }
    '
}

owned_dataplane_pids() {
  ps -axo pid=,command= 2>/dev/null | awk \
    -v public="$SOCK" -v backend="$BACKEND_SOCK" '
      index($0, "/awk ") == 0 && index($0, "/dory-dataplane-proxy") && index($0, "--listen " public) &&
      index($0, "--backend " backend) && !found { print $1; found=1 }
      END { exit found ? 0 : 1 }
    '
}

# dory-hv normally owns and reaps gvproxy. If dory-hv itself must be SIGKILLed, gvproxy is
# reparented and no pidfile exists for it. The executable path may retain redundant path components
# after launch, so match its basename plus both private sockets in one per-launch n<PID> directory.
# That stable identity prevents cleanup from affecting another engine or a newer gvproxy instance
# that reused the same state root.
owned_gvproxy_pids() {
  ps -axo pid=,command= 2>/dev/null | awk \
    -v root="$STATE/hv/" '
      index($0, "/awk ") == 0 && index($0, "/gvproxy ") {
        vfkit = "-listen-vfkit unixgram://" root
        start = index($0, vfkit)
        if (!start) next
        remainder = substr($0, start + length(vfkit))
        finish = index(remainder, "/d.sock ")
        if (!finish) next
        scope = substr(remainder, 1, finish - 1)
        if (scope !~ /^n[0-9]+$/) next
        api = "-listen unix://" root scope "/a.sock "
        if (index($0, api)) print $1
      }
    '
}

pid_list_alive() {
  local pid
  for pid in $1; do
    pid_alive "$pid" && return 0
  done
  return 1
}

signal_pid_list() {
  local signal="$1" pids="$2" pid
  for pid in $pids; do
    kill "-$signal" "$pid" 2>/dev/null || true
  done
}

reap_owned_gvproxy() {
  local pids waited=0
  pids="$(owned_gvproxy_pids)"
  [ -n "$pids" ] || return 0
  signal_pid_list TERM "$pids"
  while pid_list_alive "$pids"; do
    waited=$((waited + 1))
    if [ "$waited" -ge 20 ]; then
      signal_pid_list KILL "$pids"
      break
    fi
    sleep 0.1
  done
}

socket_ready_at() {
  local socket="$1"
  [ -S "$socket" ] || return 1
  curl -sf --max-time 2 --unix-socket "$socket" http://d/_ping >/dev/null 2>&1
}

socket_ready() {
  socket_ready_at "$SOCK"
}

write_drive_identity() {
  local path="$1" id="$2" path_tmp id_tmp
  path_tmp="$(mktemp "$STATE/.data-drive.path.XXXXXX")" \
    || die "cannot create data-drive path identity transaction"
  id_tmp="$(mktemp "$STATE/.data-drive.id.XXXXXX")" || {
    rm -f "$path_tmp"
    die "cannot create data-drive UUID identity transaction"
  }
  printf '%s\n' "$path" > "$path_tmp"
  printf '%s\n' "$id" > "$id_tmp"
  chmod 0600 "$path_tmp" "$id_tmp"
  mv -f "$path_tmp" "$DRIVEFILE"
  mv -f "$id_tmp" "$DRIVEIDFILE"
}

cmd_start() {
  require_layout
  validate_owned_socket_path "$SOCK"
  validate_owned_socket_path "$BACKEND_SOCK"
  local mem_mb=2048 cpus=4 amd64_enabled=0 gpu_mode=none lan_visible=0
  local orphaned_gvproxy key value selected_drive data_drive_explicit=0 extra=()
  local pid="" dataplane="" runtime_running=0
  # An environment-selected drive is just as explicit as the CLI flag. A durable remembered
  # selection may supply the default only when neither interface requested a path for this start.
  [ -z "${DORY_DATA_DRIVE:-}" ] || data_drive_explicit=1
  if [ "$(uname -m)" != "x86_64" ]; then
    # Apple Silicon releases advertise the bundled FEX path as ready on first launch. Persisted or
    # explicit settings may opt out, but a plain start must never strand existing dory-runc
    # containers by silently omitting the runtime after a restart.
    amd64_enabled=1
  fi
  if [ -s "$SETTINGSFILE" ]; then
    while IFS='=' read -r key value; do
      case "$key" in
        mem_mb) mem_mb="$value" ;;
        cpus) cpus="$value" ;;
        amd64_enabled) amd64_enabled="$value" ;;
        gpu_mode) gpu_mode="$value" ;;
        lan_visible) lan_visible="$value" ;;
        ''|'#'*) ;;
        *) die "invalid persisted engine setting: $key" ;;
      esac
    done < "$SETTINGSFILE"
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --mem-mb) [ "$#" -ge 2 ] || die "$1 requires a value"; mem_mb="$2"; shift 2 ;;
      --cpus) [ "$#" -ge 2 ] || die "$1 requires a value"; cpus="$2"; shift 2 ;;
      --data-drive) [ "$#" -ge 2 ] || die "$1 requires a value"; DATA_DRIVE="$2"; data_drive_explicit=1; shift 2 ;;
      --amd64) amd64_enabled=1; shift ;;
      --no-amd64) amd64_enabled=0; shift ;;
      --gpu) [ "$#" -ge 2 ] || die "$1 requires a value"; gpu_mode="$2"; shift 2 ;;
      --no-gpu) gpu_mode=none; shift ;;
      --lan-visible) lan_visible=1; shift ;;
      --no-lan-visible) lan_visible=0; shift ;;
      *) die "unknown option $1" ;;
    esac
  done

  case "$mem_mb" in ''|*[!0-9]*) die "--mem-mb must be a positive integer" ;; esac
  [ "$mem_mb" -gt 0 ] || die "--mem-mb must be a positive integer"
  case "$cpus" in ''|*[!0-9]*) die "--cpus must be a positive integer" ;; esac
  [ "$cpus" -gt 0 ] || die "--cpus must be a positive integer"
  case "$amd64_enabled" in 0|1) ;; *) die "invalid persisted amd64 setting: $amd64_enabled" ;; esac
  case "$lan_visible" in 0|1) ;; *) die "invalid persisted LAN setting: $lan_visible" ;; esac
  case "$gpu_mode" in none|venus) ;; *) die "invalid GPU mode: $gpu_mode" ;; esac
  [ "$amd64_enabled" -eq 0 ] || extra+=(--amd64)
  [ "$gpu_mode" = none ] || extra+=(--gpu "$gpu_mode")
  [ "$lan_visible" -eq 0 ] || extra+=(--direct-ip --publish-host 0.0.0.0)

  if [ "$data_drive_explicit" -eq 0 ]; then
    selected_drive="$("$BIN/dory-hv" data-drive selected-path 2>/dev/null || true)"
    [ -z "$selected_drive" ] || DATA_DRIVE="$selected_drive"
  fi

  # Recover incomplete prior ownership before depending on the replacement helper. This keeps a
  # damaged or interrupted upgrade from stranding the old VM/gvproxy processes indefinitely.
  if pid="$(engine_pid)" && dataplane="$(dataplane_pid)" && socket_ready; then
    runtime_running=1
  else
    orphaned_gvproxy="$(owned_gvproxy_pids)"
    if engine_pid >/dev/null || dataplane_pid >/dev/null || [ -n "$orphaned_gvproxy" ]; then
      note "stopping incomplete previous runtime…"
      cmd_stop
    fi
  fi

  # Resolve policy and filesystem aliases through the same Swift storage library used by both
  # VMMs. This is read-only: a wrong drive requested while another engine is live must not create
  # even an empty alternate bundle.
  DATA_DRIVE="$("$BIN/dory-hv" data-drive resolve "$DATA_DRIVE")" \
    || die "cannot resolve requested data drive"

  local recorded_drive="" recorded_drive_id="" drive_id=""
  [ ! -s "$DRIVEFILE" ] || IFS= read -r recorded_drive < "$DRIVEFILE"
  [ ! -s "$DRIVEIDFILE" ] || IFS= read -r recorded_drive_id < "$DRIVEIDFILE"
  if [ -n "$recorded_drive" ]; then
    recorded_drive="$("$BIN/dory-hv" data-drive resolve "$recorded_drive")" \
      || die "recorded data drive path is invalid"
  fi
  if [ "$data_drive_explicit" -eq 0 ] && [ -n "$recorded_drive" ]; then
    DATA_DRIVE="$recorded_drive"
  fi
  if [ "$runtime_running" -eq 1 ]; then
    if [ -z "$recorded_drive" ]; then
      running_dory_hv_uses_drive "$pid" "$DATA_DRIVE" \
        || die "running engine data drive does not match requested $DATA_DRIVE; stop it before selecting another drive"
      recorded_drive="$DATA_DRIVE"
    else
      [ "$recorded_drive" = "$DATA_DRIVE" ] \
        || die "already running with data drive $recorded_drive (requested $DATA_DRIVE)"
      running_dory_hv_uses_drive "$pid" "$recorded_drive" \
        || die "running engine data drive does not match recorded drive $recorded_drive; stop it before recovery"
    fi
    drive_id="$("$BIN/dory-hv" data-drive recover-existing "$recorded_drive")" \
      || die "running engine data-drive identity is unreadable"
    [ -z "$recorded_drive_id" ] || [ "$recorded_drive_id" = "$drive_id" ] \
      || die "running engine data-drive UUID does not match recorded identity"
    write_drive_identity "$recorded_drive" "$drive_id"
    # Repair metadata lost during an abrupt host shutdown so later status/stop operations retain
    # their normal fast path instead of depending on process-table recovery.
    printf '%s\n' "$pid" > "$PIDFILE"
    printf '%s\n' "$dataplane" > "$DATAPLANE_PIDFILE"
    note "already running (pid $pid)"
    cmd_env
    return 0
  fi

  drive_id="$("$BIN/dory-hv" data-drive select "$DATA_DRIVE")" \
    || die "cannot select data drive $DATA_DRIVE"
  [ -z "$recorded_drive_id" ] || [ -z "$recorded_drive" ] \
    || [ "$recorded_drive" != "$DATA_DRIVE" ] || [ "$recorded_drive_id" = "$drive_id" ] \
    || die "selected data-drive UUID does not match recorded runtime identity"

  mkdir -p "$STATE/vm" "$STATE/bin"
  if [ ! -f "$KERNEL" ] || [ "$KERNEL_ASSET" -nt "$KERNEL" ]; then
    note "preparing kernel (one-time)…"
    "$BIN/dory-hv" lzfse decompress "$KERNEL_ASSET" "$KERNEL"
  fi
  local rootfs_args=()
  if [ -f "$ROOTFS_ASSET" ]; then
    if [ ! -f "$ROOTFS" ] || [ "$ROOTFS_ASSET" -nt "$ROOTFS" ]; then
      note "preparing engine rootfs (one-time, offline)…"
      "$BIN/dory-hv" lzfse decompress "$ROOTFS_ASSET" "$ROOTFS"
    fi
    rootfs_args+=(--rootfs "$ROOTFS")
  fi
  # The guest agent rides the home share; the boot script prefers this copy so upgrades apply.
  if [ -f "$AGENT_ASSET" ]; then
    cp "$AGENT_ASSET" "$AGENT_OUTPUT"
    chmod 0755 "$AGENT_OUTPUT"
    # The home share uses the sensitive-name denylist, so ~/.dory is deliberately invisible to
    # the guest. Stage the exact bundled agent through dory-hv's read-only boot-config share rather
    # than silently falling back to the potentially older copy baked into the rootfs.
    rootfs_args+=(--guest-agent "$AGENT_OUTPUT")
  fi
  if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
    rootfs_args+=(--ssh-agent-socket "$SSH_AUTH_SOCK")
  fi

  note "starting engine (${mem_mb} MiB ceiling, $cpus cpus, amd64=$amd64_enabled, gpu=$gpu_mode, lan-visible=$lan_visible)…"
  rotate_log "$LOGFILE"
  remove_owned_socket_path "$SOCK"
  remove_owned_socket_path "$BACKEND_SOCK"
  nohup "$BIN/dory-hv" engine \
    --engine-sock "$BACKEND_SOCK" \
    --state-dir "$STATE/hv" \
    --data-drive "$DATA_DRIVE" \
    --kernel "$KERNEL" \
    --gvproxy "$BIN/gvproxy" \
    --mem-mb "$mem_mb" --cpus "$cpus" --direct-ipv6 \
    ${rootfs_args[@]+"${rootfs_args[@]}"} \
    ${extra[@]+"${extra[@]}"} \
    --share "home=$HOME:rw:at=$HOME:safe" \
    --share "volumes=/Volumes:rw:at=/Volumes:safe" \
    >> "$LOGFILE" 2>&1 &
  echo $! > "$PIDFILE"

  local waited=0
  until socket_ready_at "$BACKEND_SOCK"; do
    kill -0 "$(cat "$PIDFILE")" 2>/dev/null || { cmd_stop >/dev/null 2>&1 || true; die "engine exited during start — see $LOGFILE"; }
    waited=$((waited + 1))
    [ "$waited" -ge 120 ] && { cmd_stop >/dev/null 2>&1 || true; die "engine did not become ready in 120s — see $LOGFILE"; }
    sleep 1
  done

  # Keep the public socket behind the same request dataplane used by Dory.app. In particular this
  # normalizes loopback HostIp bindings before dockerd sees them, making TCP and UDP `-p
  # 127.0.0.1:…` work through gvproxy without widening the host-side listener.
  nohup "$BIN/dory-dataplane-proxy" --listen "$SOCK" --backend "$BACKEND_SOCK" \
    >> "$LOGFILE" 2>&1 &
  echo $! > "$DATAPLANE_PIDFILE"
  until socket_ready; do
    kill -0 "$(cat "$PIDFILE")" 2>/dev/null || { cmd_stop >/dev/null 2>&1 || true; die "engine exited while starting dataplane — see $LOGFILE"; }
    kill -0 "$(cat "$DATAPLANE_PIDFILE")" 2>/dev/null || { cmd_stop >/dev/null 2>&1 || true; die "dataplane exited during start — see $LOGFILE"; }
    waited=$((waited + 1))
    [ "$waited" -ge 120 ] && { cmd_stop >/dev/null 2>&1 || true; die "dataplane did not become ready in 120s — see $LOGFILE"; }
    sleep 1
  done
  note "ready in ${waited}s"
  write_drive_identity "$DATA_DRIVE" "$drive_id"
  local settings_tmp="$SETTINGSFILE.tmp.$$"
  {
    printf 'mem_mb=%s\n' "$mem_mb"
    printf 'cpus=%s\n' "$cpus"
    printf 'amd64_enabled=%s\n' "$amd64_enabled"
    printf 'gpu_mode=%s\n' "$gpu_mode"
    printf 'lan_visible=%s\n' "$lan_visible"
  } > "$settings_tmp"
  chmod 0600 "$settings_tmp"
  mv -f "$settings_tmp" "$SETTINGSFILE"

  if command -v docker >/dev/null 2>&1; then
    docker context inspect dory-engine >/dev/null 2>&1 \
      || docker context create dory-engine --docker "host=unix://$SOCK" >/dev/null 2>&1 || true
    note "docker context 'dory-engine' targets this engine (docker context use dory-engine)"
  fi
  cmd_env
}

cmd_stop() {
  local pid dataplane gvproxy_pids
  dataplane="$(dataplane_pid 2>/dev/null || true)"
  pid="$(engine_pid 2>/dev/null || true)"
  gvproxy_pids="$(owned_gvproxy_pids)"
  if [ -z "$pid" ] && [ -z "$dataplane" ] && [ -z "$gvproxy_pids" ]; then
    note "not running"
    rm -f "$PIDFILE" "$DATAPLANE_PIDFILE"
    [ ! -S "$SOCK" ] || rm -f "$SOCK"
    [ ! -S "$BACKEND_SOCK" ] || rm -f "$BACKEND_SOCK"
    return 0
  fi
  note "stopping (graceful)…"
  [ -z "$dataplane" ] || kill "$dataplane" 2>/dev/null || true
  [ -z "$pid" ] || kill "$pid" 2>/dev/null || true
  # Keep gvproxy alive while dory-hv asks the guest shutdown listener to stop dockerd, sync,
  # unmount the data drive, and power off. Killing gvproxy here races that forwarded request and
  # makes dory-hv exit as a network-helper crash before Docker metadata is durable; deleted objects
  # can then reappear on the next boot. Once dory-hv is gone, reap any surviving/reparented gvproxy.
  local waited=0
  while { [ -n "$pid" ] && pid_alive "$pid"; } || \
        { [ -n "$dataplane" ] && pid_alive "$dataplane"; }; do
    waited=$((waited + 1))
    if [ "$waited" -ge 20 ]; then
      note "forcing shutdown"
      [ -z "$dataplane" ] || kill -9 "$dataplane" 2>/dev/null || true
      [ -z "$pid" ] || kill -9 "$pid" 2>/dev/null || true
      break
    fi
    sleep 1
  done
  # Rescan after dory-hv exits in case gvproxy was reparented during the stop race.
  reap_owned_gvproxy
  rm -f "$PIDFILE" "$DATAPLANE_PIDFILE"
  [ ! -S "$SOCK" ] || rm -f "$SOCK"
  [ ! -S "$BACKEND_SOCK" ] || rm -f "$BACKEND_SOCK"
  note "stopped"
}

cmd_status() {
  if pid="$(engine_pid)" && dataplane="$(dataplane_pid)"; then
    if socket_ready; then
      local api_version
      api_version="$(curl -sf --max-time 2 --unix-socket "$SOCK" http://d/version 2>/dev/null | sed -n 's/.*"ApiVersion":"\([^"]*\)".*/\1/p' | head -1)"
      local active_drive="$DATA_DRIVE"
      local active_drive_id="unknown"
      [ ! -s "$DRIVEFILE" ] || IFS= read -r active_drive < "$DRIVEFILE"
      [ ! -s "$DRIVEIDFILE" ] || IFS= read -r active_drive_id < "$DRIVEIDFILE"
      note "running (engine pid $pid, dataplane pid $dataplane, docker api ${api_version:-unknown}) at unix://$SOCK"
      note "data drive: $active_drive (id $active_drive_id)"
    else
      note "starting (pid $pid) — socket not ready yet"
    fi
  else
    note "not running"
    return 1
  fi
}

cmd_env() {
  printf 'export DOCKER_HOST="unix://%s"\n' "$SOCK"
}

case "${1:-}" in
  start) shift; cmd_start "$@" ;;
  stop) cmd_stop ;;
  status) cmd_status ;;
  env) cmd_env ;;
  *) sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'; exit 64 ;;
esac
