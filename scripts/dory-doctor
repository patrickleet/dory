def run_compat(tools: set[str] | None = None) -> list[CheckResult]:
    state = compat_socket_state()
    results: list[CheckResult] = []
    for entry in COMPAT_TOOLS:
        if tools and entry["tool"] not in tools:
            continue
        try:
            results.extend(entry["check"](state))
        except Exception as exc:
            results.append(CheckResult(f"compat.{entry['tool']}", "fail", f"compat.{entry['tool']}.probe_exception", entry["title"], str(exc)))
    return results


def print_compat(results: list[CheckResult], as_json: bool) -> None:
    if as_json:
        print(json.dumps({"generated_at": now_iso(), "results": [r.as_dict() for r in results]}, indent=2, sort_keys=True))
        return
    counts: dict[str, int] = {}
    for result in results:
        counts[result.status] = counts.get(result.status, 0) + 1
        label = result.status.upper().ljust(4)
        print(f"{label} {result.id}: {result.title}")
        print(f"     {result.detail}")
        if result.action:
            print(f"     action: {result.action}")
    print("")
    print("Summary: " + ", ".join(f"{status}={count}" for status, count in sorted(counts.items())))
    print("Recipes: `dory compat recipe <tool>` (tools: " + ", ".join(entry["tool"] for entry in COMPAT_TOOLS) + ")")


def print_compat_recipe(tool: str | None, as_json: bool) -> int:
    recipes = compat_recipes()
    if tool is None:
        if as_json:
            print(json.dumps({"tools": recipes}, indent=2, sort_keys=True))
        else:
            for name, recipe in recipes.items():
                print(f"{name}: {recipe['title']} — {recipe['summary']}")
            print("\nShow one with `dory compat recipe <tool>`.")
        return 0
    recipe = recipes.get(tool)
    if not recipe:
        print(f"No recipe for '{tool}'. Known: {', '.join(recipes)}", file=sys.stderr)
        return 2
    if as_json:
        print(json.dumps({tool: recipe}, indent=2, sort_keys=True))
        return 0
    print(f"# {recipe['title']}")
    print(recipe["summary"])
    print("")
    for step in recipe["steps"]:
        print(step)
    print("")
    print(f"Verify: {recipe['verify']}")
    return 0


def cmd_doctor(args: argparse.Namespace) -> int:
    only = set(args.only.split(",")) if args.only else None
    doctor = Doctor(timeout=args.timeout, active=args.active)
    results = doctor.run_all(only=only)
    diff = diff_last_good(results) if getattr(args, "diff", False) else None
    # Refresh the healthy baseline only after a FULL run, and compute the diff against the PREVIOUS
    # baseline first so `--diff` shows what changed since it last worked.
    if only is None:
        save_last_good(results)
    bundle_path = None
    if args.bundle is not None:
        target = None if args.bundle == "" else Path(args.bundle).expanduser()
        bundle_path = bundle(target, active=args.active)
    if args.json:
        payload: dict[str, Any] = {"generated_at": now_iso(), "results": [r.as_dict() for r in results]}
        if diff is not None:
            payload["diff"] = diff
        if bundle_path:
            payload["bundle"] = str(bundle_path)
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_results(results, False)
        if diff is not None:
            print_diff(diff)
        if bundle_path:
            print(f"Diagnostic bundle: {bundle_path}")
    return exit_code(results)


def print_diff(diff: dict[str, Any]) -> None:
    baseline_at = diff.get("baseline_saved_at")
    print("")
    if not baseline_at:
        print("Diff: no healthy baseline saved yet (run `dory doctor` once while healthy).")
        return
    print(f"Diff vs last healthy run ({baseline_at}):")
    regressions = diff.get("regressions") or []
    resolved = diff.get("resolved") or []
    new = diff.get("new") or []
    if not regressions and not resolved and not new:
        print("  no changes since the last healthy run")
        return
    for item in regressions:
        print(f"  REGRESSED {item['id']}: {item['from']} -> {item['to']} ({item['title']})")
    for item in new:
        print(f"  NEW       {item['id']}: {item['status']} ({item['title']})")
    for item in resolved:
        print(f"  RESOLVED  {item['id']}: {item['from']} -> {item['to']} ({item['title']})")


def cmd_network(args: argparse.Namespace) -> int:
    if args.list_probes:
        probes = network_probes(args.probe)
        if args.json:
            print(json.dumps({"generated_at": now_iso(), "probes": probes}, indent=2, sort_keys=True))
        else:
            for probe in probes:
                print(f"{probe['name']}: {probe['host']}:{probe['port']}")
        return 0
    if args.save_probe:
        try:
            probe = save_network_probe(args.save_probe)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2
        if args.json:
            print(json.dumps({"saved": probe, "config_path": str(config_path())}, indent=2, sort_keys=True))
        else:
            print(f"Saved probe {probe['name']}: {probe['host']}:{probe['port']}")
        return 0
    if args.remove_probe:
        try:
            removed = remove_network_probe(args.remove_probe)
        except ValueError as exc:
            print(str(exc), file=sys.stderr)
            return 2
        if args.json:
            print(json.dumps({"removed": removed, "config_path": str(config_path())}, indent=2, sort_keys=True))
        else:
            print("Removed probe" if removed else "No matching probe")
        return 0
    if args.lan_visible is not None:
        want = parse_bool_arg(args.lan_visible)
        if want is None:
            print("usage: dory network --lan-visible on|off", file=sys.stderr)
            return 2
        config = load_config()
        network = dict(config.get("network") or {})
        network["lanVisible"] = want
        config["network"] = network
        save_config(config)
        if args.json:
            print(json.dumps({"lanVisible": want, "config_path": str(config_path())}, indent=2, sort_keys=True))
        else:
            print(f"LAN visibility {'ON — published ports reachable from the local network' if want else 'OFF — published ports are localhost-only'}")
            print("Restart the engine (or republish ports) for the change to take effect.")
        return 0
    only = {"socket", "api", "registry", "proxy", "exposure", "network", "ports", "domains"}
    doctor = Doctor(timeout=args.timeout, active=args.active, network_probes=args.probe)
    results = doctor.run_all(only=only)
    print_results(results, args.json)
    return exit_code(results)


def cmd_mount(args: argparse.Namespace) -> int:
    report = mount_report()
    doctor = Doctor(timeout=args.timeout, active=True)
    results = doctor.run_all(only={"socket", "api", "mounts", "filelock", "watch"})
    if args.json:
        print(json.dumps({
            "generated_at": now_iso(),
            "shares": report["shares"],
            "policy_note": report["policy_note"],
            "results": [r.as_dict() for r in results],
        }, indent=2, sort_keys=True))
    else:
        print("File sharing")
        for share in report["shares"]:
            print(f"  {share['host_path']} -> {share['guest_path']}  ({share['mode']}, {share['policy']}, {share['backend']})")
        print(f"  {report['policy_note']}")
        print("")
        print_results(results, False)
    return exit_code(results)


def cmd_disk(args: argparse.Namespace) -> int:
    report = disk_report()
    print_disk(report, args.json)
    return 0


def cmd_cleanup(args: argparse.Namespace) -> int:
    report = cleanup_report(apply=args.apply, include_volumes=args.include_volumes, log_max_bytes=args.log_max_bytes)
    print_cleanup(report, args.json)
    return 1 if any(action.get("status") == "fail" for action in report.get("actions", [])) else 0


def cmd_routes(args: argparse.Namespace) -> int:
    table = route_table()
    print_routes(table, args.json)
    return 1 if table.get("error") else 0


def cmd_repair(args: argparse.Namespace) -> int:
    handlers = {
        "socket": repair_socket,
        "context": repair_context,
        "engine": repair_engine,
        "routes": repair_routes,
        "dns": repair_dns,
        "domains": repair_domains,
        "ports": repair_ports,
        "dockerd": repair_dockerd,
        "guest-agent": repair_guest_agent,
    }
    actions: list[dict[str, Any]] = []
    applied_targets: list[str] = []
    all_targets = ["socket", "context", "dns", "routes", "ports", "domains", "dockerd", "guest-agent"]
    fan_out = args.target == "all"
    targets = all_targets if fan_out else [args.target]
    restart_engine = getattr(args, "restart_engine", False)
    for target in targets:
        handler = handlers.get(target)
        if handler is None:
            continue
        # Bouncing the engine stops running containers, so the engine restart is opt-in: `repair all`
        # never escalates to it (allow_engine_escalation=False), and a direct engine/dockerd repair
        # only performs it when --restart-engine is set.
        extra: dict[str, Any] = {}
        if target == "engine":
            extra["restart_engine"] = restart_engine
        elif target == "dockerd":
            extra["restart_engine"] = restart_engine
            extra["allow_engine_escalation"] = not fan_out
        # `repair all --apply` must not run side effects (DNS flush, SIGUSR1 to the engine) on a
        # healthy subsystem: probe each one dry first and only apply where it reports a problem.
        # A single explicit `dory repair <target> --apply` still forces the action.
        if fan_out and args.apply:
            probe = handler(False, **extra)
            if probe.get("status") in {"pass", "skip"}:
                actions.append(probe)
                continue
        result = handler(args.apply, **extra)
        actions.append(result)
        if args.apply and result.get("status") != "fail":
            applied_targets.append(target)
    if applied_targets:
        record_incident(
            "repair",
            f"applied repair: {', '.join(applied_targets)}",
            targets=applied_targets,
            requested=args.target,
        )
    if args.json:
        print(json.dumps({"generated_at": now_iso(), "apply": args.apply, "actions": actions}, indent=2, sort_keys=True))
    else:
        for action in actions:
            status = action.get("status", "info").upper()
            print(f"{status} {action.get('target')}: {action.get('detail')}")
            if action.get("next"):
                print(f"     next: {action['next']}")
        if not args.apply:
            print("Dry run. Re-run with --apply for actions that change local state.")
    return 1 if any(action.get("status") == "fail" for action in actions) else 0


def repair_socket(apply: bool) -> dict[str, Any]:
    sock = socket_path()
    if not sock.exists():
        return {"target": "socket", "status": "pass", "detail": f"{sock} does not exist; no stale file to move"}
    try:
        mode = sock.stat().st_mode
    except OSError as exc:
        return {"target": "socket", "status": "fail", "detail": str(exc)}
    if stat.S_ISSOCK(mode):
        return {"target": "socket", "status": "pass", "detail": f"{sock} is a socket"}
    backup = sock.with_name(sock.name + f".stale-{int(time.time())}")
    if apply:
        os.replace(sock, backup)
        return {"target": "socket", "status": "pass", "detail": f"moved stale socket path to {backup}"}
    return {"target": "socket", "status": "warn", "detail": f"{sock} is not a socket", "next": f"would move it to {backup}"}


def repair_context(apply: bool) -> dict[str, Any]:
    binary = docker_bin()
    if not binary:
        return {"target": "context", "status": "fail", "detail": "docker CLI not found"}
    host = f"unix://{socket_path()}"
    if not apply:
        return {"target": "context", "status": "warn", "detail": "Dory Docker context may need repair", "next": f"would create/update context dory -> {host} and activate it"}
    inspect = subprocess.run([binary, "context", "inspect", "dory"], text=True, capture_output=True)
    if inspect.returncode == 0:
        update = subprocess.run([binary, "context", "update", "dory", "--docker", f"host={host}"], text=True, capture_output=True)
        if update.returncode != 0:
            return {"target": "context", "status": "fail", "detail": compact(update.stderr or update.stdout)}
    else:
        create = subprocess.run([binary, "context", "create", "dory", "--description", "Dory", "--docker", f"host={host}"], text=True, capture_output=True)
        if create.returncode != 0:
            return {"target": "context", "status": "fail", "detail": compact(create.stderr or create.stdout)}
    use = subprocess.run([binary, "context", "use", "dory"], text=True, capture_output=True)
    if use.returncode != 0:
        return {"target": "context", "status": "fail", "detail": compact(use.stderr or use.stdout)}
    return {"target": "context", "status": "pass", "detail": f"docker context dory now targets {host}"}


def dockerd_ping_ok(timeout: float = 10.0) -> bool:
    try:
        status_code, _, body = unix_http(socket_path(), "GET", "/_ping", timeout=timeout)
    except Exception:
        return False
    return status_code == 200 and body.strip() == b"OK"


def repair_engine(apply: bool, restart_engine: bool = False) -> dict[str, Any]:
    script = dory_engine_script()
    if not script.exists():
        return {"target": "engine", "status": "skip", "detail": f"{script} not found"}
    if not apply:
        # Only advertise a restart when the engine actually looks wedged; a healthy engine needs none.
        if dockerd_ping_ok():
            return {"target": "engine", "status": "pass", "detail": "engine reachable; no restart needed"}
        return {
            "target": "engine",
            "status": "warn",
            "detail": "Headless engine restart available (disruptive: stops running containers)",
            "next": f"run `dory repair engine --restart-engine` to bounce the engine ({script} stop && {script} start)",
            "dataPlaneDisruptive": True,
        }
    if not restart_engine:
        # Restarting stops running containers, so --apply alone must not bounce the engine.
        return {
            "target": "engine",
            "status": "warn",
            "detail": "engine restart is available but disruptive (stops running containers); not performed without --restart-engine",
            "next": f"re-run `dory repair engine --apply --restart-engine` to bounce the engine ({script} stop && {script} start)",
            "dataPlaneDisruptive": True,
        }
    stop = subprocess.run([str(script), "stop"], text=True, capture_output=True, timeout=60)
    start = subprocess.run([str(script), "start"], text=True, capture_output=True, timeout=180)
    if start.returncode != 0:
        return {"target": "engine", "status": "fail", "detail": compact(start.stderr or start.stdout), "dataPlaneDisruptive": True}
    return {"target": "engine", "status": "pass", "detail": compact(stop.stdout + " " + start.stdout), "dataPlaneDisruptive": True}


def repair_routes(apply: bool) -> dict[str, Any]:
    table = route_table()
    if table.get("error"):
        return {"target": "routes", "status": "fail", "detail": table["error"]}
    conflicts = [row for row in table["ports"] if row.get("conflict")]
    if conflicts:
        return {
            "target": "routes",
            "status": "warn",
            "detail": f"{len(conflicts)} conflicting published port rows found",
            "next": "stop one of the containers using the same host port, then rerun `dory routes`",
        }
    return {"target": "routes", "status": "pass", "detail": f"{len(table['ports'])} port route(s), {len(table['domains'])} domain route(s) readable"}


def repair_dns(apply: bool) -> dict[str, Any]:
    resolver = Path(f"/etc/resolver/{DOMAIN_SUFFIX}")
    detail = f"resolver={resolver} exists={resolver.exists()}"
    if not apply:
        # A merely-absent resolver means networking was never enabled — a system-wide DNS flush would
        # fix nothing, so `repair all` must skip it (a direct `dory repair dns --apply` still forces
        # the flush for the stale-cache case where the resolver exists but *.dory.local went stale).
        if not resolver.exists():
            return {
                "target": "dns",
                "status": "skip",
                "detail": detail,
                "next": "run scripts/enable-networking.sh to install the *.dory.local resolver; nothing to flush",
            }
        return {
            "target": "dns",
            "status": "pass",
            "detail": detail,
            "next": "run `dory repair dns --apply` to flush the macOS DNS cache if *.dory.local is stale",
        }
    flush = subprocess.run(["dscacheutil", "-flushcache"], text=True, capture_output=True, timeout=15)
    hup = subprocess.run(["killall", "-HUP", "mDNSResponder"], text=True, capture_output=True, timeout=15)
    if flush.returncode != 0:
        return {"target": "dns", "status": "fail", "detail": compact(flush.stderr or flush.stdout)}
    if hup.returncode != 0:
        return {"target": "dns", "status": "warn", "detail": f"DNS cache flushed; mDNSResponder HUP failed: {compact(hup.stderr or hup.stdout)}"}
    return {"target": "dns", "status": "pass", "detail": "macOS DNS cache flushed"}


def repair_domains(apply: bool) -> dict[str, Any]:
    table = route_table()
    if table.get("error"):
        return {"target": "domains", "status": "fail", "detail": table["error"]}
    domains = len(table.get("domains", []))
    resolver = Path(f"/etc/resolver/{DOMAIN_SUFFIX}")
    if apply:
        dns = repair_dns(True)
        return {
            "target": "domains",
            "status": dns.get("status", "warn"),
            "detail": f"{domains} inferred domain route(s); {dns.get('detail')}",
            "next": "restart Dory if the reverse proxy listener itself is wedged",
        }
    return {
        "target": "domains",
        "status": "pass" if resolver.exists() else "warn",
        "detail": f"{domains} inferred domain route(s); resolver_exists={resolver.exists()}",
        "next": "would flush DNS cache; restart Dory only if the local reverse proxy listener is wedged",
    }


def repair_ports(apply: bool) -> dict[str, Any]:
    table = route_table()
    if table.get("error"):
        return {"target": "ports", "status": "fail", "detail": table["error"]}
    conflicts = [row for row in table.get("ports", []) if row.get("conflict")]
    if conflicts:
        return {
            "target": "ports",
            "status": "warn",
            "detail": f"{len(conflicts)} conflicting published port route(s)",
            "next": "stop one of the conflicting containers; Dory will reconcile route ownership automatically",
        }
    return {"target": "ports", "status": "pass", "detail": f"{len(table.get('ports', []))} published port route(s) readable; no conflicts"}


def repair_dockerd(apply: bool, restart_engine: bool = False, allow_engine_escalation: bool = True) -> dict[str, Any]:
    try:
        # Give a busy or still-booting dockerd time to answer before declaring it wedged and
        # escalating to a disruptive engine bounce.
        status_code, _, body = unix_http(socket_path(), "GET", "/_ping", timeout=10)
        if status_code == 200 and body.strip() == b"OK":
            return {"target": "dockerd", "status": "pass", "detail": "Docker API is reachable"}
    except Exception as exc:
        if not apply:
            return {
                "target": "dockerd",
                "status": "warn",
                "detail": f"Docker API unreachable: {exc}",
                "next": "would restart the headless engine when available; app-managed engines should be restarted from Dory",
            }
    if apply and not allow_engine_escalation:
        # `repair all` must stay data-plane safe: never bounce the engine as an automatic escalation.
        return {
            "target": "dockerd",
            "status": "warn",
            "detail": "Docker API unreachable; `repair all` will not restart the engine (that stops running containers)",
            "next": "run `dory repair engine --restart-engine` to bounce the engine",
            "dataPlaneDisruptive": True,
        }
    return repair_engine(apply, restart_engine=restart_engine)


def repair_guest_agent(apply: bool) -> dict[str, Any]:
    pid = shared_engine_pid()
    if not pid:
        return {
            "target": "guest-agent",
            "status": "skip",
            "detail": "shared engine helper PID not found",
            "next": "start Dory's engine before repairing guest-agent-backed features",
        }
    if not apply:
        return {
            "target": "guest-agent",
            "status": "warn",
            "detail": f"shared engine helper pid={pid}",
            "next": "would send SIGUSR1 wake/clock resync signal; restart engine if agent RPC remains unavailable",
        }
    try:
        os.kill(pid, signal.SIGUSR1)
    except Exception as exc:
        return {"target": "guest-agent", "status": "fail", "detail": str(exc)}
    return {"target": "guest-agent", "status": "pass", "detail": f"sent wake/clock resync signal to helper pid={pid}"}


def shared_engine_pid() -> int | None:
    for path in [HOME / ".dory" / "engine.pid", HOME / ".dory" / "engine-cli.pid"]:
        try:
            pid = int(path.read_text(encoding="utf-8").strip())
        except Exception:
            continue
        try:
            os.kill(pid, 0)
        except OSError:
            continue
        return pid
    return None


def cmd_mode(args: argparse.Namespace) -> int:
    config = load_config()
    if args.mode != "show":
        config["runtimeMode"] = args.mode
        save_config(config)
    if args.json:
        print(json.dumps({"config_path": str(config_path()), **config}, indent=2, sort_keys=True))
    else:
        print(f"Runtime mode: {config.get('runtimeMode')}")
        print(f"Config: {config_path()}")
        idle = config.get("idle") or {}
        print(f"Sleep after idle: {idle.get('sleepAfterMinutes')} minutes")
        print(f"Keep published ports awake: {idle.get('keepPublishedPortsAwake')}")
        print(f"Keep Kubernetes awake: {idle.get('keepKubernetesAwake')}")
    return 0


IDLE_INT_KEYS = {"sleepAfterMinutes"}
IDLE_BOOL_KEYS = {"keepPublishedPortsAwake", "keepKubernetesAwake", "keepPinnedProjectsAwake", "showWakeNotifications"}


def parse_bool_arg(value: str) -> bool | None:
    lowered = str(value).strip().lower()
    if lowered in {"on", "true", "1", "yes", "y"}:
        return True
    if lowered in {"off", "false", "0", "no", "n"}:
        return False
    return None


def idle_set(key: str | None, value: str | None, as_json: bool) -> int:
    if not key or value is None:
        print(f"usage: dory idle set KEY VALUE  (keys: {', '.join(sorted(IDLE_INT_KEYS | IDLE_BOOL_KEYS))})", file=sys.stderr)
        return 2
    if key in IDLE_INT_KEYS:
        try:
            parsed: Any = max(0, int(value))
        except ValueError:
            print(f"{key} expects a non-negative integer", file=sys.stderr)
            return 2
    elif key in IDLE_BOOL_KEYS:
        parsed = parse_bool_arg(value)
        if parsed is None:
            print(f"{key} expects on/off (true/false)", file=sys.stderr)
            return 2
    else:
        print(f"unknown idle key '{key}'; known: {', '.join(sorted(IDLE_INT_KEYS | IDLE_BOOL_KEYS))}", file=sys.stderr)
        return 2
    config = load_config()
    idle = dict(config.get("idle") or {})
    idle[key] = parsed
    config["idle"] = idle
    save_config(config)
    if as_json:
        print(json.dumps({"config_path": str(config_path()), "idle": idle}, indent=2, sort_keys=True))
    else:
        print(f"Set idle.{key} = {parsed}")
    return 0


def cmd_idle(args: argparse.Namespace) -> int:
    if args.action == "set":
        return idle_set(args.key, args.value, args.json)
    if args.action != "status":
        raise SystemExit("usage: dory idle status|set KEY VALUE [--json]")
    status = idle_status()
    print_idle(status, args.json)
    return 0


def cmd_incidents(args: argparse.Namespace) -> int:
    records = list(reversed(read_incidents(args.limit)))
    if args.json:
        print(json.dumps({"generated_at": now_iso(), "incidents": records}, indent=2, sort_keys=True))
        return 0
    if not records:
        print("No incidents recorded yet.")
        return 0
    for record in records:
        print(f"{record.get('at', '?'):20} {record.get('type', '?'):16} {record.get('detail', '')}")
    return 0


def cmd_compat(args: argparse.Namespace) -> int:
    if args.recipe is not None:
        tool = args.recipe or None
        return print_compat_recipe(tool, args.json)
    tools = set(args.only.split(",")) if args.only else None
    results = run_compat(tools)
    print_compat(results, args.json)
    return exit_code(results)


def cmd_bundle(args: argparse.Namespace) -> int:
    path = Path(args.path).expanduser() if args.path else None
    print(bundle(path, active=args.active))
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="dory-doctor")
    sub = parser.add_subparsers(dest="command", required=True)

    doctor = sub.add_parser("doctor", help="Run P0 diagnostics")
    doctor.add_argument("--json", action="store_true")
    doctor.add_argument("--active", action="store_true", help="Run active container probes")
    doctor.add_argument("--timeout", type=float, default=5.0)
    doctor.add_argument("--only", help="Comma-separated groups: socket,api,docker,context,registry,proxy,exposure,network,ports,domains,mounts,filelock,watch,clock,disk,memory,helpers")
    doctor.add_argument("--bundle", nargs="?", const="", help="Also write a redacted diagnostic bundle")
    doctor.add_argument("--diff", action="store_true", help="Show what changed since the last healthy run")
    doctor.set_defaults(func=cmd_doctor)

    network = sub.add_parser("network", help="Run network diagnostics")
    network.add_argument("--json", action="store_true")
    network.add_argument("--active", action="store_true")
    network.add_argument("--timeout", type=float, default=5.0)
    network.add_argument("--probe", action="append", default=[], metavar="HOST[:PORT]", help="Run an extra one-time safe network probe")
    network.add_argument("--save-probe", metavar="HOST[:PORT]", help="Persist a safe host/port probe for future network checks")
    network.add_argument("--remove-probe", metavar="HOST[:PORT]", help="Remove a persisted network probe")
    network.add_argument("--list-probes", action="store_true", help="List default and configured safe network probes")
    network.add_argument("--lan-visible", metavar="on|off", help="Publish ports to the local network (on) or restrict to localhost (off)")
    network.set_defaults(func=cmd_network)

    mount = sub.add_parser("mount", help="Run active bind-mount diagnostics")
    mount.add_argument("--json", action="store_true")
    mount.add_argument("--timeout", type=float, default=5.0)
    mount.set_defaults(func=cmd_mount)

    disk = sub.add_parser("disk", help="Show disk guardrails")
    disk.add_argument("--json", action="store_true")
    disk.set_defaults(func=cmd_disk)

    cleanup = sub.add_parser("cleanup", help="Show or apply safe cleanup actions")
    cleanup.add_argument("--json", action="store_true")
    cleanup.add_argument("--apply", action="store_true")
    cleanup.add_argument("--include-volumes", action="store_true", help="Include destructive unused-volume pruning")
    cleanup.add_argument("--log-max-bytes", type=int, default=5_000_000, help="Trim each Dory log file to this many trailing bytes")
    cleanup.set_defaults(func=cmd_cleanup)

    routes = sub.add_parser("routes", help="Show published ports and dory.local routes")
    routes.add_argument("--json", action="store_true")
    routes.set_defaults(func=cmd_routes)

    repair = sub.add_parser("repair", help="Run non-destructive repair actions")
    repair.add_argument(
        "target",
        choices=["all", "socket", "context", "engine", "routes", "dns", "domains", "ports", "dockerd", "guest-agent"],
        nargs="?",
        default="all",
    )
    repair.add_argument("--apply", action="store_true")
    repair.add_argument(
        "--restart-engine",
        action="store_true",
        help="Allow `repair engine`/`repair dockerd` --apply to bounce the engine (stops running containers)",
    )
    repair.add_argument("--json", action="store_true")
    repair.set_defaults(func=cmd_repair)

    mode = sub.add_parser("mode", help="Show or set runtime mode")
    mode.add_argument("mode", choices=["show", "manual", "auto-idle", "always-on", "battery-saver"], nargs="?", default="show")
    mode.add_argument("--json", action="store_true")
    mode.set_defaults(func=cmd_mode)

    idle = sub.add_parser("idle", help="Inspect Auto-Idle readiness or set idle policy")
    idle.add_argument("action", choices=["status", "set"], nargs="?", default="status")
    idle.add_argument("key", nargs="?", help="idle policy key for `set`")
    idle.add_argument("value", nargs="?", help="idle policy value for `set`")
    idle.add_argument("--json", action="store_true")
    idle.set_defaults(func=cmd_idle)

    incidents = sub.add_parser("incidents", help="Show the local incident timeline (starts, sleeps, wakes, repairs)")
    incidents.add_argument("--json", action="store_true")
    incidents.add_argument("--limit", type=int, default=50)
    incidents.set_defaults(func=cmd_incidents)

    compat = sub.add_parser("compat", help="Check tool compatibility and show recipes")
    compat.add_argument("--json", action="store_true")
    compat.add_argument("--only", help="Comma-separated tools: " + ",".join(entry["tool"] for entry in COMPAT_TOOLS))
    compat.add_argument("--recipe", nargs="?", const="", help="Show a copy-paste recipe (optionally for one tool)")
    compat.set_defaults(func=cmd_compat)

    bundle_parser = sub.add_parser("bundle", help="Write a redacted diagnostic bundle")
    bundle_parser.add_argument("path", nargs="?")
    bundle_parser.add_argument("--active", action="store_true")
    bundle_parser.set_defaults(func=cmd_bundle)
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except KeyboardInterrupt:
        return 130
    except (OSError, ValueError) as exc:
        print(f"dory-doctor: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
