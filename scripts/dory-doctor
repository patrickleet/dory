#!/usr/bin/env python3
"""Dory P0 diagnostics and recovery helper.

This script backs `dory doctor`, `dory disk`, `dory routes`, `dory cleanup`,
`dory repair`, `dory mode`, and `dory idle`. It intentionally depends only on Python's
standard library plus the Docker CLI when CLI-specific checks are requested.
"""

from __future__ import annotations

import argparse
import datetime as dt
import fcntl
import fnmatch
import http.client
import json
import os
import re
import shutil
import signal
import socket
import ssl
import stat
import subprocess
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
import zipfile
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any


HOME = Path.home()
DEFAULT_SOCK = HOME / ".dory" / "dory.sock"
DEFAULT_ENGINE_SOCK = HOME / ".dory" / "engine.sock"
DEFAULT_CONFIG = HOME / ".dory" / "config.json"
DEFAULT_KUBECONFIG = HOME / ".kube" / "dory-config"
DEFAULT_IDLE_STATE = HOME / ".dory" / "idle-state.json"
DEFAULT_INCIDENTS = HOME / ".dory" / "incidents.jsonl"
STATE_ROOT = HOME / ".dory"
SCRIPT_DIR = Path(__file__).resolve().parent
DOMAIN_SUFFIX = os.environ.get("DORY_DOMAIN_SUFFIX", "dory.local")
DOMAIN_PROXY_PORT = int(os.environ.get("DORY_DOMAIN_PROXY_PORT", "8080"))
HTTPS_PROXY_PORT = int(os.environ.get("DORY_HTTPS_PROXY_PORT", "8443"))
DOCKER_IMAGE = os.environ.get("DORY_DOCTOR_IMAGE", "alpine:latest")
RUN_LABEL_KEY = "dev.dory.doctor"
LOG_HARD_MAX_BYTES = int(os.environ.get("DORY_LOG_HARD_MAX_BYTES", str(64 * 1024 * 1024)))
SUPPORT_LOG_TAIL_BYTES = int(os.environ.get("DORY_SUPPORT_LOG_TAIL_BYTES", "300000"))
SUPPORT_SYSTEM_LOG_BYTES = int(os.environ.get("DORY_SUPPORT_SYSTEM_LOG_BYTES", "300000"))
SUPPORT_UNIFIED_LOG_LAST = os.environ.get("DORY_SUPPORT_UNIFIED_LOG_LAST", "15m")
SECRET_KEY_RE = re.compile(r"(token|secret|password|passwd|authorization|auth|credential|key)", re.I)
BEARER_RE = re.compile(r"Bearer\s+[A-Za-z0-9._~+/-]+=*", re.I)
BASIC_RE = re.compile(r"Basic\s+[A-Za-z0-9._~+/-]+=*", re.I)
# scheme://user:pass@ — keeps the scheme+user, drops the ':password@'.
URL_CREDENTIAL_RE = re.compile(r"([a-z][a-z0-9+.-]*://[^\s:/@]+:)[^\s:/@]+@", re.I)


def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def socket_path() -> Path:
    return Path(os.environ.get("DORY_SOCK", str(DEFAULT_SOCK))).expanduser()


def config_path() -> Path:
    return Path(os.environ.get("DORY_CONFIG", str(DEFAULT_CONFIG))).expanduser()


def idle_state_path() -> Path:
    return Path(os.environ.get("DORY_IDLE_STATE", str(DEFAULT_IDLE_STATE))).expanduser()


def incidents_path() -> Path:
    return Path(os.environ.get("DORY_INCIDENTS", str(DEFAULT_INCIDENTS))).expanduser()


def record_incident(kind: str, detail: str, **extra: Any) -> None:
    path = incidents_path()
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        line = json.dumps({"at": now_iso(), "type": kind, "detail": detail, **extra}, sort_keys=True) + "\n"
        # Serialize append+trim against the Swift writer and other CLI processes via an exclusive
        # flock on a stable sibling lock file (the JSONL inode is swapped by the trim, so we cannot
        # lock the data file itself). O_APPEND keeps each write atomic even under the lock.
        lock_fd = os.open(str(path) + ".lock", os.O_WRONLY | os.O_CREAT, 0o600)
        try:
            fcntl.flock(lock_fd, fcntl.LOCK_EX)
            fd = os.open(str(path), os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
            try:
                os.write(fd, line.encode("utf-8"))
            finally:
                os.close(fd)
            _trim_incidents(path, 500)
        finally:
            fcntl.flock(lock_fd, fcntl.LOCK_UN)
            os.close(lock_fd)
    except OSError:
        pass


def _trim_incidents(path: Path, max_lines: int) -> None:
    try:
        lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
    except OSError:
        return
    if len(lines) <= max_lines:
        return
    tmp = path.with_suffix(f".{os.getpid()}.trim")
    try:
        fd = os.open(str(tmp), os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.writelines(lines[-max_lines:])
        os.replace(tmp, path)
    except OSError:
        try:
            tmp.unlink()
        except OSError:
            pass


def read_incidents(limit: int = 50) -> list[dict[str, Any]]:
    if limit <= 0:
        return []
    path = incidents_path()
    if not path.exists():
        return []
    records: list[dict[str, Any]] = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except ValueError:
                    continue
    except OSError:
        return []
    return records[-limit:]


def last_good_path() -> Path:
    return Path(os.environ.get("DORY_LAST_GOOD", str(HOME / ".dory" / "doctor-last-good.json"))).expanduser()


STATUS_RANK = {"pass": 0, "skip": 1, "warn": 2, "fail": 3}


def save_last_good(results: list["CheckResult"]) -> None:
    # Only snapshot a genuinely healthy full run (no failures), so `--diff` always compares against a
    # known-good baseline rather than a previously-broken state.
    if any(r.status == "fail" for r in results):
        return
    snapshot = {
        "saved_at": now_iso(),
        "checks": {r.id: {"status": r.status, "code": r.code, "title": r.title} for r in results},
    }
    path = last_good_path()
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp = path.with_suffix(f".{os.getpid()}.tmp")
        tmp.write_text(json.dumps(snapshot, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        os.replace(tmp, path)
    except OSError:
        pass


def load_last_good() -> dict[str, Any] | None:
    path = last_good_path()
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else None
    except (OSError, ValueError):
        return None


def diff_last_good(results: list["CheckResult"]) -> dict[str, Any]:
    baseline = load_last_good()
    current = {r.id: {"status": r.status, "code": r.code, "title": r.title} for r in results}
    if not baseline:
        return {"baseline_saved_at": None, "regressions": [], "resolved": [], "new": []}
    base_checks = baseline.get("checks") or {}
    regressions: list[dict[str, Any]] = []
    resolved: list[dict[str, Any]] = []
    new: list[dict[str, Any]] = []
    for check_id, cur in current.items():
        prev = base_checks.get(check_id)
        if prev is None:
            new.append({"id": check_id, "status": cur["status"], "title": cur["title"]})
            continue
        cur_rank = STATUS_RANK.get(cur["status"], 0)
        prev_rank = STATUS_RANK.get(prev.get("status", "pass"), 0)
        if cur_rank > prev_rank:
            regressions.append({"id": check_id, "from": prev.get("status"), "to": cur["status"], "title": cur["title"]})
        elif cur_rank < prev_rank:
            resolved.append({"id": check_id, "from": prev.get("status"), "to": cur["status"], "title": cur["title"]})
    return {"baseline_saved_at": baseline.get("saved_at"), "regressions": regressions, "resolved": resolved, "new": new}


def docker_bin() -> str | None:
    configured = os.environ.get("DORY_DOCKER_BIN")
    if configured:
        return configured
    return shutil.which("docker")


def kubectl_bin() -> str | None:
    configured = os.environ.get("DORY_KUBECTL_BIN")
    if configured:
        return configured
    return shutil.which("kubectl")


def docker_cli(args: list[str], timeout: float = 60) -> subprocess.CompletedProcess[str]:
    binary = docker_bin()
    if not binary:
        raise FileNotFoundError("docker CLI not found")
    env = os.environ.copy()
    env["DOCKER_HOST"] = f"unix://{socket_path()}"
    return subprocess.run([binary, *args], env=env, text=True, capture_output=True, timeout=timeout)


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def dory_engine_script() -> Path:
    return repo_root() / "scripts" / "runtime" / "dory-engine"


@dataclass
class CheckResult:
    id: str
    status: str
    code: str
    title: str
    detail: str
    action: str = ""
    data: dict[str, Any] = field(default_factory=dict)

    def as_dict(self) -> dict[str, Any]:
        out = {
            "id": self.id,
            "status": self.status,
            "code": self.code,
            "title": self.title,
            "detail": self.detail,
        }
        if self.action:
            out["action"] = self.action
        if self.data:
            out["data"] = self.data
        return out


class Doctor:
    def __init__(
        self,
        sock: Path | None = None,
        timeout: float = 5.0,
        active: bool = False,
        network_probes: list[str] | None = None,
    ):
        self.sock = sock or socket_path()
        self.timeout = timeout
        self.active = active
        self.extra_network_probes = network_probes or []
        self.run_id = f"{int(time.time())}-{os.getpid()}"
        self.label = f"{RUN_LABEL_KEY}={self.run_id}"
        self.results: list[CheckResult] = []
        self.created_containers: list[str] = []

    def add(
        self,
        check_id: str,
        status: str,
        code: str,
        title: str,
        detail: str,
        action: str = "",
        **data: Any,
    ) -> None:
        self.results.append(CheckResult(check_id, status, code, title, detail, action, data))

    def run_all(self, only: set[str] | None = None) -> list[CheckResult]:
        checks = [
            ("socket", self.check_socket),
            ("api", self.check_api_ping),
            ("docker", self.check_docker_cli),
            ("context", self.check_docker_context),
            ("registry", self.check_registry),
            ("proxy", self.check_proxy),
            ("exposure", self.check_lan_exposure),
            ("network", self.check_dns_compare),
            ("ports", self.check_port_publish),
            ("domains", self.check_domain_route),
            ("mounts", self.check_mount),
            ("filelock", self.check_file_lock),
            ("watch", self.check_watch_visibility),
            ("clock", self.check_vm_clock),
            ("disk", self.check_disk),
            ("memory", self.check_memory),
            ("helpers", self.check_helpers),
        ]
        try:
            for group, fn in checks:
                if only and group not in only:
                    continue
                try:
                    fn()
                except Exception as exc:  # keep doctor useful even when one probe breaks
                    self.add(group, "fail", f"{group}.probe_exception", group, str(exc))
            return self.results
        finally:
            self.cleanup()

    def docker(self, args: list[str], timeout: float | None = None) -> subprocess.CompletedProcess[str]:
        binary = docker_bin()
        if not binary:
            raise FileNotFoundError("docker CLI not found")
        env = os.environ.copy()
        env["DOCKER_HOST"] = f"unix://{self.sock}"
        return subprocess.run(
            [binary, *args],
            env=env,
            text=True,
            capture_output=True,
            timeout=timeout or max(self.timeout, 20),
        )

    def api(self, method: str, path: str, body: bytes | None = None) -> tuple[int, dict[str, str], bytes]:
        return unix_http(self.sock, method, path, body=body, timeout=self.timeout)

    def api_json(self, path: str) -> Any:
        status_code, _, body = self.api("GET", path)
        if status_code < 200 or status_code >= 300:
            raise RuntimeError(f"Docker API {path} returned HTTP {status_code}")
        return json.loads(body.decode("utf-8") or "null")

    def check_socket(self) -> None:
        path = self.sock
        if not path.exists():
            fallback = DEFAULT_ENGINE_SOCK if DEFAULT_ENGINE_SOCK.exists() else None
            detail = f"{path} does not exist"
            action = "Start Dory, or set DORY_SOCK to a running Docker-compatible unix socket."
            if fallback:
                detail += f"; headless engine socket exists at {fallback}"
                action = f"Set DORY_SOCK={fallback} or start the Dory app socket."
            self.add("socket.exists", "fail", "socket.missing", "Docker socket missing", detail, action)
            return
        mode = path.stat().st_mode
        if not stat.S_ISSOCK(mode):
            self.add(
                "socket.exists",
                "fail",
                "socket.not_socket",
                "Docker socket path is not a socket",
                f"{path} exists but is not a unix socket",
                "Run `dory repair socket` to move the stale path aside.",
            )
            return
        self.add("socket.exists", "pass", "socket.ok", "Docker socket exists", str(path))

    def check_api_ping(self) -> None:
        try:
            status_code, _, body = self.api("GET", "/_ping")
            text = body.decode("utf-8", "replace").strip()
        except Exception as exc:
            self.add(
                "socket.ping",
                "fail",
                "socket.unreachable",
                "Docker API is not reachable",
                str(exc),
                "Start Dory or run `dory repair socket` if the socket path is stale.",
            )
            return
        if status_code == 200 and text == "OK":
            self.add("socket.ping", "pass", "socket.ping_ok", "Docker API ping passed", "Docker API returned OK")
        else:
            self.add(
                "socket.ping",
                "fail",
                "socket.bad_ping",
                "Docker API ping failed",
                f"HTTP {status_code}: {text[:120]}",
            )

    def check_docker_cli(self) -> None:
        binary = docker_bin()
        if not binary:
            self.add(
                "docker.cli",
                "fail",
                "docker.cli_missing",
                "Docker CLI missing",
                "No docker executable found in PATH or DORY_DOCKER_BIN.",
                "doryd repairs Dory terminal integration automatically while it is running; restart Dory/doryd, or use `dory install` only as manual recovery.",
            )
            return
        self.add("docker.cli", "pass", "docker.cli_found", "Docker CLI found", binary)
        try:
            version = self.docker(["version", "--format", "{{json .Server}}"], timeout=12)
        except Exception as exc:
            self.add("docker.version", "fail", "docker.version_exception", "Docker CLI version failed", str(exc))
            return
        if version.returncode == 0:
            self.add("docker.version", "pass", "docker.version_ok", "Docker CLI can reach Dory", version.stdout.strip()[:300])
        else:
            self.add(
                "docker.version",
                "fail",
                "docker.version_failed",
                "Docker CLI cannot reach Dory",
                compact(version.stderr or version.stdout),
                "Check DOCKER_HOST and the Dory Docker context.",
            )
        compose = subprocess.run([binary, "compose", "version"], text=True, capture_output=True, timeout=12)
        if compose.returncode == 0:
            self.add("docker.compose", "pass", "docker.compose_ok", "Docker Compose plugin works", compose.stdout.strip())
        else:
            self.add(
                "docker.compose",
                "warn",
                "docker.compose_missing",
                "Docker Compose plugin not available",
                compact(compose.stderr or compose.stdout),
                "doryd installs the bundled Compose plugin automatically while it is running; restart Dory/doryd, or use `dory install` only as manual recovery.",
            )

    def check_docker_context(self) -> None:
        binary = docker_bin()
        if not binary:
            self.add("docker.context", "skip", "docker.cli_missing", "Docker context skipped", "Docker CLI is missing.")
            return
        env_host = os.environ.get("DOCKER_HOST", "")
        expected = f"unix://{self.sock}"
        if env_host and env_host != expected:
            self.add(
                "docker.host_env",
                "warn",
                "socket.docker_host_conflict",
                "DOCKER_HOST points away from Dory",
                f"DOCKER_HOST={env_host}",
                f"Unset DOCKER_HOST or set it to {expected}.",
            )
        elif env_host == expected:
            self.add("docker.host_env", "pass", "socket.docker_host_ok", "DOCKER_HOST points at Dory", env_host)
        else:
            self.add("docker.host_env", "pass", "socket.docker_host_unset", "DOCKER_HOST is not overriding context", "unset")

        current = subprocess.run([binary, "context", "show"], text=True, capture_output=True, timeout=8)
        if current.returncode == 0:
            name = current.stdout.strip()
            status = "pass" if name == "dory" else "warn"
            code = "context.active" if name == "dory" else "context.not_active"
            action = "" if name == "dory" else "Run `dory repair context` to create and activate the Dory context."
            self.add("docker.context.current", status, code, "Active Docker context", name or "unknown", action)
        else:
            self.add("docker.context.current", "warn", "context.show_failed", "Could not read Docker context", compact(current.stderr))

        inspect = subprocess.run(
            [binary, "context", "inspect", "dory", "--format", "{{json .Endpoints.docker.Host}}"],
            text=True,
            capture_output=True,
            timeout=8,
        )
        if inspect.returncode != 0:
            self.add(
                "docker.context.dory",
                "warn",
                "context.missing",
                "Dory Docker context missing",
                compact(inspect.stderr or inspect.stdout),
                "Run `dory repair context`.",
            )
            return
        host = inspect.stdout.strip().strip('"')
        if host == expected:
            self.add("docker.context.dory", "pass", "context.dory_ok", "Dory context targets this socket", host)
        else:
            self.add(
                "docker.context.dory",
                "warn",
                "context.wrong_socket",
                "Dory context targets another socket",
                host,
                "Run `dory repair context` to update it.",
            )

    def check_proxy(self) -> None:
        report = proxy_report(self.sock)
        host_env = report["host_env"]
        system = report["system"]
        daemon = report["daemon"]
        containers = report["containers"]
        host_has_proxy = bool(
            host_env.get("HTTPS_PROXY") or host_env.get("HTTP_PROXY") or host_env.get("ALL_PROXY")
            or system.get("https_proxy") or system.get("http_proxy") or system.get("pac")
        )
        containers_have_proxy = bool(containers.get("https_proxy") or containers.get("http_proxy"))
        daemon_has_proxy = bool(daemon.get("https_proxy") or daemon.get("http_proxy"))
        layers = []
        if host_env:
            layers.append("host env")
        if system:
            layers.append("macOS system")
        if daemon:
            layers.append("daemon")
        if containers:
            layers.append("containers")
        detail = ("proxy set at: " + ", ".join(layers)) if layers else "no proxy configured at any layer"
        if host_has_proxy and not containers_have_proxy:
            self.add(
                "network.proxy",
                "warn",
                "network.proxy_not_propagated",
                "Host is behind a proxy that containers do not use",
                detail + " — image pulls and container internet can fail with EOF/timeout behind a corporate proxy",
                "Add a `proxies.default` block (httpProxy/httpsProxy/noProxy) to ~/.docker/config.json so Docker injects the proxy into builds and containers.",
                **report,
            )
        elif host_has_proxy and not daemon_has_proxy:
            self.add(
                "network.proxy",
                "warn",
                "network.proxy_daemon_missing",
                "Containers use a proxy but the daemon does not",
                detail + " — `docker pull` from the engine may fail even though container runtime env is set",
                "Configure the engine/daemon proxy (HTTP_PROXY/HTTPS_PROXY in the engine environment) to match the container proxy.",
                **report,
            )
        else:
            self.add("network.proxy", "pass", "network.proxy_ok", "Proxy configuration consistent", detail, **report)

    def check_lan_exposure(self) -> None:
        # Strict `is True` so a stray 1/"true"/null in the config does not read as exposed here while
        # the engine (which requires a genuine boolean) keeps ports on loopback.
        lan_visible = (load_config().get("network") or {}).get("lanVisible") is True
        table = route_table(self.sock)
        published = [] if table.get("error") else [row for row in table.get("ports", []) if row.get("state") == "running"]
        count = len(published)
        if lan_visible:
            self.add(
                "network.lan_exposure",
                "warn",
                "network.lan_exposed",
                "Published ports are LAN-visible",
                f"LAN visibility is ON — {count} published port(s) reachable from your local network, not just this Mac",
                "Run `dory network --lan-visible off` (or Settings -> Network) to restrict published ports to localhost.",
                lan_visible=True,
                published_ports=count,
            )
        else:
            self.add(
                "network.lan_exposure",
                "pass",
                "network.lan_localhost_only",
                "Published ports are localhost-only",
                f"localhost-only — {count} published port(s) reachable only from this Mac",
                lan_visible=False,
                published_ports=count,
            )

    def check_registry(self) -> None:
        for index, probe in enumerate(network_probes(self.extra_network_probes)):
            self.check_registry_probe(probe, default=(index == 0))

    def check_registry_probe(self, probe: dict[str, Any], default: bool) -> None:
        host = str(probe["host"])
        port = int(probe.get("port") or 443)
        slug = slugify(str(probe.get("name") or host))
        dns_id = "network.registry_dns" if default else f"network.registry_dns.{slug}"
        tls_id = "network.registry_https" if default else f"network.registry_https.{slug}"
        tcp_id = "network.registry_tcp" if default else f"network.registry_tcp.{slug}"
        try:
            infos = socket.getaddrinfo(host, port, type=socket.SOCK_STREAM)
            ips = sorted({info[4][0] for info in infos})
        except socket.gaierror as exc:
            self.add(
                dns_id,
                "fail",
                "network.registry_dns_failed",
                "Host cannot resolve network probe",
                f"{host}:{port}: {exc}",
                "Check DNS, VPN, or proxy settings.",
                probe=probe,
            )
            return
        self.add(dns_id, "pass", "network.registry_dns_ok", "Host resolves network probe", f"{host}:{port}", ips=ips[:8], probe=probe)
        try:
            context = ssl.create_default_context()
            conn = http.client.HTTPSConnection(host, port, timeout=self.timeout, context=context)
            conn.request("GET", "/v2/", headers={"User-Agent": "dory-doctor"})
            response = conn.getresponse()
            body = response.read(512)
            conn.close()
        except ssl.SSLError as exc:
            self.add(tls_id, "fail", "network.registry_tls_failed", "Network probe TLS failed", str(exc), probe=probe)
            return
        except TimeoutError as exc:
            self.add(tcp_id, "fail", "network.registry_timeout", "Network probe connection timed out", str(exc), probe=probe)
            return
        except OSError as exc:
            self.add(tcp_id, "fail", "network.registry_tcp_failed", "Network probe TCP connection failed", str(exc), probe=probe)
            return
        if response.status in (200, 401):
            self.add(
                tls_id,
                "pass",
                "network.registry_https_ok",
                "Network probe HTTPS path works",
                f"HTTP {response.status}; auth challenge is expected for Docker Hub",
                probe=probe,
            )
        else:
            self.add(
                tls_id,
                "warn",
                "network.registry_unexpected_status",
                "Network probe returned unexpected status",
                f"HTTP {response.status}: {body.decode('utf-8', 'replace')[:120]}",
                probe=probe,
            )

    def check_dns_compare(self) -> None:
        if not self.active:
            self.add(
                "network.container_dns",
                "skip",
                "network.active_probe_skipped",
                "Container DNS comparison skipped",
                "Run `dory doctor --active` to compare host DNS with container DNS.",
            )
            return
        if not self.engine_available():
            self.add("network.container_dns", "skip", "socket.unreachable", "Container DNS skipped", "Docker API is not reachable.")
            return
        for index, probe in enumerate(network_probes(self.extra_network_probes)):
            self.check_dns_probe(probe, default=(index == 0))

    def check_dns_probe(self, probe: dict[str, Any], default: bool) -> None:
        host = str(probe["host"])
        port = int(probe.get("port") or 443)
        slug = slugify(str(probe.get("name") or host))
        check_id = "network.container_dns" if default else f"network.container_dns.{slug}"
        try:
            host_ips = sorted({info[4][0] for info in socket.getaddrinfo(host, port, type=socket.SOCK_STREAM)})
        except socket.gaierror:
            host_ips = []
        probe_root = HOME / ".dory" / "doctor"
        probe_root.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="dory-dns-", dir=str(probe_root)) as tmp:
            output_path = Path(tmp) / "dns.txt"
            command = (
                "nslookup \"$1\" 2>/dev/null | "
                "awk '/^Address[[:space:]]*[0-9]*:/ {print $NF}' | tail -n 8 > /work/dns.txt"
            )
            result = self.docker(
                [
                    "run",
                    "--rm",
                    "--pull=missing",
                    "--label",
                    self.label,
                    "-v",
                    f"{tmp}:/work",
                    DOCKER_IMAGE,
                    "sh",
                    "-c",
                    command,
                    "dory-dns",
                    host,
                ],
                timeout=60,
            )
            dns_output = output_path.read_text(encoding="utf-8", errors="replace") if output_path.exists() else ""
        if result.returncode != 0:
            self.add(
                check_id,
                "fail",
                "network.container_dns_failed",
                "Container cannot resolve network probe",
                compact(result.stderr or result.stdout or dns_output),
                "Check Dory VM DNS, VPN split DNS, and proxy settings.",
                probe=probe,
            )
            return
        container_ips = sorted({line.strip() for line in dns_output.splitlines() if line.strip()})
        if not container_ips:
            self.add(check_id, "fail", "network.container_dns_empty", "Container DNS returned no addresses", dns_output, probe=probe)
            return
        status = "pass" if not host_ips or set(host_ips).intersection(container_ips) else "warn"
        code = "network.container_dns_ok" if status == "pass" else "network.vpn_dns_mismatch"
        detail = f"host={','.join(host_ips[:8]) or 'unknown'} container={','.join(container_ips[:8])}"
        action = "" if status == "pass" else "Container DNS differs from host DNS; check VPN split-DNS forwarding."
        self.add(check_id, status, code, "Host/container DNS comparison", detail, action, probe=probe)

    def check_port_publish(self) -> None:
        if not self.active:
            table = route_table(self.sock)
            if table.get("error"):
                self.add(
                    "network.published_ports",
                    "fail",
                    "network.port_table_unreadable",
                    "Published port table could not be read",
                    table["error"],
                    "The Docker API did not return the container list; run `dory doctor` again once the engine is healthy.",
                )
                return
            count = len(table.get("ports", []))
            self.add(
                "network.published_ports",
                "pass",
                "network.port_table_ok",
                "Published port table readable",
                f"{count} published port route(s) found",
                ports=count,
            )
            return
        name, port = self.start_http_container()
        if not name or not port:
            return
        body, error = wait_http(f"http://127.0.0.1:{port}", timeout=self.timeout, attempts=30)
        if error:
            self.add(
                "network.port_publish",
                "fail",
                "network.port_unreachable",
                "Published localhost port is not reachable",
                error,
                "Check Dory port forwarding and local firewall/VPN software.",
                port=port,
            )
            return
        if "dory-doctor-ok" in body:
            self.add("network.port_publish", "pass", "network.port_ok", "Published localhost port works", f"127.0.0.1:{port}")
        else:
            self.add("network.port_publish", "fail", "network.port_bad_response", "Published port returned wrong body", body[:120])

    def check_domain_route(self) -> None:
        table = route_table(self.sock)
        domain_count = len(table.get("domains", []))
        if not self.active:
            if table.get("error"):
                self.add(
                    "network.domain_table",
                    "fail",
                    "network.domain_table_unreadable",
                    "Domain route table could not be read",
                    table["error"],
                    "The Docker API did not return the container list; run `dory doctor` again once the engine is healthy.",
                )
                return
            self.add(
                "network.domain_table",
                "pass",
                "network.domain_table_ok",
                "Domain route table readable",
                f"{domain_count} domain route(s) inferred from containers",
                domains=domain_count,
            )
            return
        name, _ = self.start_http_container(reuse=True)
        if not name:
            return
        host = f"{name}.{DOMAIN_SUFFIX}"
        response_status = 0
        body = ""
        last_error = ""
        for _ in range(30):
            try:
                conn = http.client.HTTPConnection("127.0.0.1", DOMAIN_PROXY_PORT, timeout=self.timeout)
                conn.request("GET", "/", headers={"Host": host, "User-Agent": "dory-doctor"})
                response = conn.getresponse()
                response_status = response.status
                body = response.read(2048).decode("utf-8", "replace")
                conn.close()
                if response_status == 200 and "dory-doctor-ok" in body:
                    break
            except OSError as exc:
                last_error = str(exc)
            time.sleep(0.3)
        if response_status == 0:
            self.add(
                "network.domain_route",
                "warn",
                "network.domain_proxy_unreachable",
                "Local domain proxy not reachable",
                f"127.0.0.1:{DOMAIN_PROXY_PORT}: {last_error}",
                "Enable Dory local domains or check the configured HTTP proxy port.",
                host=host,
            )
            return
        if response_status == 200 and "dory-doctor-ok" in body:
            self.add("network.domain_route", "pass", "network.domain_ok", "Local domain route works", host)
        else:
            self.add(
                "network.domain_route",
                "warn",
                "network.domain_bad_response",
                "Local domain route did not return the expected service",
                f"HTTP {response_status}: {body[:120]}",
                "Check whether the Dory app route table has reconciled this container.",
                host=host,
            )

    def check_mount(self) -> None:
        if not self.active:
            self.add(
                "mount.basic",
                "skip",
                "mount.active_probe_skipped",
                "Bind mount probe skipped",
                "Run `dory doctor --active` to validate bind mount read/write/path-with-spaces behavior.",
            )
            return
        if not self.engine_available():
            self.add("mount.basic", "skip", "socket.unreachable", "Bind mount skipped", "Docker API is not reachable.")
            return
        probe_root = HOME / ".dory" / "doctor"
        probe_root.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="path with spaces ", dir=str(probe_root)) as tmp:
            root = Path(tmp)
            (root / "host.txt").write_text("host-ok\n", encoding="utf-8")
            (root / "truncate.txt").write_text("truncate-me\n", encoding="utf-8")
            script = (
                "set -eu; "
                "grep -q host-ok /work/host.txt; "
                "printf container-ok > /work/container.txt; "
                ": > /work/truncate.txt"
            )
            result = self.docker(
                [
                    "run",
                    "--rm",
                    "--pull=missing",
                    "--label",
                    self.label,
                    "-v",
                    f"{root}:/work",
                    DOCKER_IMAGE,
                    "sh",
                    "-c",
                    script,
                ],
                timeout=60,
            )
            if result.returncode != 0:
                self.add(
                    "mount.basic",
                    "fail",
                    "mount.read_write_failed",
                    "Bind mount read/write failed",
                    compact(result.stderr or result.stdout),
                    "Check file sharing permissions and path handling.",
                    path=str(root),
                )
                return
            ok = (root / "container.txt").read_text(encoding="utf-8") == "container-ok"
            truncated = (root / "truncate.txt").stat().st_size == 0
            if ok and truncated:
                self.add("mount.basic", "pass", "mount.read_write_ok", "Bind mount read/write works", "path with spaces passed")
            else:
                self.add(
                    "mount.basic",
                    "fail",
                    "mount.host_visibility_failed",
                    "Bind mount changes were not visible on host",
                    f"container_file={ok} truncated={truncated}",
                )
            link_result = self.docker(
                [
                    "run",
                    "--rm",
                    "--pull=missing",
                    "--label",
                    self.label,
                    "-v",
                    f"{root}:/work",
                    DOCKER_IMAGE,
                    "sh",
                    "-c",
                    "ln -sf host.txt /work/link.txt && test -L /work/link.txt",
                ],
                timeout=60,
            )
            link = (root / "link.txt").is_symlink()
            if link_result.returncode == 0 and link:
                self.add("mount.symlink", "pass", "mount.symlink_ok", "Bind mount symlink creation works", "ln -s propagated to host")
            else:
                self.add(
                    "mount.symlink",
                    "fail",
                    "mount.symlink_failed",
                    "Bind mount symlink creation failed",
                    compact(link_result.stderr or link_result.stdout),
                    "Update the Dory engine so virtio-fs handles FUSE symlink/readlink operations.",
                    host_link_seen=link,
                )

    def check_file_lock(self) -> None:
        if not self.active:
            self.add("mount.lock", "skip", "mount.active_probe_skipped", "File-lock probe skipped",
                     "Run `dory doctor --active` to verify exclusive lock behavior across processes.")
            return
        if not self.engine_available():
            self.add("mount.lock", "skip", "socket.unreachable", "File-lock probe skipped", "Docker API is not reachable.")
            return
        probe_root = HOME / ".dory" / "doctor"
        probe_root.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="lock-", dir=str(probe_root)) as tmp:
            root = Path(tmp)
            # One process holds an exclusive flock on a bind-mounted file (BusyBox flock's FILE PROG
            # form) while a second, non-blocking exclusive lock on the same file must fail. If it
            # succeeds, virtio-fs is not honoring locks — the Docker VirtioFS correctness regression
            # class that corrupts SQLite et al. The whole thing runs under an in-container `timeout`
            # so a misbehaving flock can never hang the probe (and never wedge dockerd).
            script = (
                "command -v flock >/dev/null 2>&1 || { echo LOCK_NO_FLOCK; exit 0; }; "
                "flock -x /work/lock sleep 2 & "
                "sleep 0.5; "
                "if flock -nx /work/lock true; then echo LOCK_NOT_HONORED; else echo LOCK_HONORED; fi; "
                "wait"
            )
            result = self.docker(
                ["run", "--rm", "--pull=missing", "--label", self.label, "-v", f"{root}:/work", DOCKER_IMAGE,
                 "timeout", "12", "sh", "-c", script],
                timeout=45,
            )
            out = result.stdout or ""
            if "LOCK_NO_FLOCK" in out:
                self.add("mount.lock", "skip", "mount.lock_no_tool", "File-lock probe skipped",
                         "the probe image has no flock; install util-linux to test lock behavior")
            elif "LOCK_HONORED" in out:
                self.add("mount.lock", "pass", "mount.lock_ok", "Exclusive file locks are honored",
                         "flock across processes on the bind mount is exclusive")
            elif "LOCK_NOT_HONORED" in out:
                self.add("mount.lock", "warn", "mount.lock_not_honored", "Exclusive file locks are NOT honored",
                         "a second process took an exclusive lock while one was held — apps relying on flock (SQLite, Prisma, etc.) can corrupt data",
                         "Run lock-dependent writers on a named volume instead of a bind mount, or update the engine's virtio-fs.")
            else:
                self.add("mount.lock", "warn", "mount.lock_inconclusive", "File-lock probe inconclusive",
                         compact(result.stderr or out) or "no flock result")

    def check_watch_visibility(self) -> None:
        if not self.active:
            self.add(
                "mount.watch",
                "skip",
                "mount.active_probe_skipped",
                "Watch visibility probe skipped",
                "Run `dory doctor --active` to validate host edits becoming visible inside a mounted container.",
            )
            return
        binary = docker_bin()
        if not binary:
            self.add(
                "mount.watch",
                "fail",
                "docker.cli_missing",
                "Watch visibility probe needs Docker CLI",
                "No docker executable found in PATH or DORY_DOCKER_BIN.",
            )
            return
        probe_root = HOME / ".dory" / "doctor"
        probe_root.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="watch ", dir=str(probe_root)) as tmp:
            root = Path(tmp)
            watch_file = root / "watch.txt"
            watch_file.write_text("initial\n", encoding="utf-8")
            name = f"dory-doctor-watch-{self.run_id}"
            self.created_containers.append(name)
            command = (
                "for i in $(seq 1 80); do "
                "test \"$(cat /work/watch.txt 2>/dev/null || true)\" = changed && exit 0; "
                "sleep 0.1; "
                "done; exit 1"
            )
            proc = subprocess.Popen(
                [
                    binary,
                    "-H",
                    f"unix://{self.sock}",
                    "run",
                    "--name",
                    name,
                    "--rm",
                    "--label",
                    self.label,
                    "-v",
                    f"{root}:/work",
                    DOCKER_IMAGE,
                    "sh",
                    "-c",
                    command,
                ],
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            time.sleep(0.8)
            watch_file.write_text("changed", encoding="utf-8")
            try:
                stdout, stderr = proc.communicate(timeout=15)
            except subprocess.TimeoutExpired:
                proc.kill()
                stdout, stderr = proc.communicate()
            if proc.returncode == 0:
                self.add("mount.watch", "pass", "mount.watch_visible", "Host edits are visible in mounted container", "polling visibility probe passed")
            else:
                self.add(
                    "mount.watch",
                    "fail",
                    "mount.watch_stale",
                    "Host edits did not become visible in mounted container",
                    compact(stderr or stdout),
                    "Check virtiofs/file-sharing health and watcher-heavy project behavior.",
                )

    def check_vm_clock(self) -> None:
        if not self.active:
            self.add("vm.clock", "skip", "vm.active_probe_skipped", "VM clock probe skipped", "Run `dory doctor --active` to compare guest and host clocks.")
            return
        result = self.docker(
            ["run", "--rm", "--pull=missing", "--label", self.label, DOCKER_IMAGE, "date", "+%s"],
            timeout=60,
        )
        if result.returncode != 0:
            self.add("vm.clock", "fail", "vm.clock_failed", "Could not read guest clock", compact(result.stderr or result.stdout))
            return
        try:
            guest = int(result.stdout.strip().splitlines()[-1])
        except Exception:
            self.add("vm.clock", "fail", "vm.clock_parse_failed", "Could not parse guest clock", result.stdout)
            return
        host = int(time.time())
        drift = abs(host - guest)
        status = "pass" if drift <= 5 else "warn"
        code = "vm.clock_ok" if status == "pass" else "vm.clock_drift"
        action = "" if status == "pass" else "Restart the Dory engine if this persists after laptop sleep/wake."
        self.add("vm.clock", status, code, "Host/guest clock drift", f"{drift}s", action, host=host, guest=guest)

    def check_disk(self) -> None:
        report = disk_report(self.sock)
        host = report["host"]
        free = host.get("free_bytes", 0)
        total = host.get("total_bytes", 0)
        pct_free = (free / total * 100) if total else 0
        if total and pct_free < 5:
            status, code = "fail", "disk.host_critical"
            action = "Free host disk space before pulling or building images."
        elif total and pct_free < 15:
            status, code = "warn", "disk.host_low"
            action = "Consider pruning images/build cache or freeing host disk space."
        else:
            status, code = "pass", "disk.host_ok"
            action = ""
        self.add("disk.host", status, code, "Host disk space", f"{format_bytes(free)} free of {format_bytes(total)}", action, **host)
        docker = report.get("docker", {})
        if docker.get("available"):
            self.add(
                "disk.docker",
                "pass",
                "disk.docker_df_ok",
                "Docker disk usage readable",
                docker_summary(docker),
                **docker,
            )
        else:
            self.add(
                "disk.docker",
                "warn",
                "disk.docker_df_unavailable",
                "Docker disk usage unavailable",
                docker.get("error", "Docker API did not return /system/df"),
            )
        state = report.get("state", {})
        log_bytes = int(state.get("log_bytes", 0) or 0)
        state_status = "warn" if log_bytes > 100_000_000 else "pass"
        state_code = "disk.dory_logs_large" if state_status == "warn" else "disk.dory_state_ok"
        state_action = "Run `dory cleanup --logs --apply` to trim old log data while preserving recent tails." if state_status == "warn" else ""
        self.add(
            "disk.dory_state",
            state_status,
            state_code,
            "Dory state disk usage estimated",
            f"state={format_bytes(state.get('total_bytes', 0))} logs={format_bytes(state.get('log_bytes', 0))} vm={format_bytes(state.get('vm_disk_bytes', 0))}",
            state_action,
            **state,
        )
        self.check_guest_disk()
        largest_log = state.get("largest_log") or {}
        largest_bytes = int(largest_log.get("bytes", 0) or 0)
        if largest_bytes > LOG_HARD_MAX_BYTES:
            self.add(
                "disk.dory_logs",
                "warn",
                "disk.dory_log_uncapped",
                "A Dory log exceeds the size cap",
                f"{largest_log.get('path', 'a log')} is {format_bytes(largest_bytes)} (cap {format_bytes(LOG_HARD_MAX_BYTES)})",
                "Run `dory cleanup --logs --apply`; automatic caps apply on the next engine start or while Auto-Idle runs.",
                largest_log=largest_log,
            )
        else:
            self.add(
                "disk.dory_logs",
                "pass",
                "disk.dory_logs_capped",
                "Dory logs are within the size cap",
                f"largest {format_bytes(largest_bytes)} of {format_bytes(LOG_HARD_MAX_BYTES)} cap",
                largest_log=largest_log,
            )

    def check_guest_disk(self) -> None:
        if not self.active:
            self.add(
                "disk.guest",
                "skip",
                "disk.active_probe_skipped",
                "Guest disk probe skipped",
                "Run `dory doctor --active` to measure free space inside the engine VM.",
            )
            return
        if not self.engine_available():
            self.add("disk.guest", "skip", "socket.unreachable", "Guest disk probe skipped", "Docker API is not reachable.")
            return
        try:
            run = self.docker(["run", "--rm", "--pull=missing", "--label", self.label, DOCKER_IMAGE, "df", "-Pk", "/"], timeout=90)
        except Exception as exc:
            self.add("disk.guest", "warn", "disk.guest_probe_failed", "Guest disk probe failed", str(exc))
            return
        if run.returncode != 0:
            self.add("disk.guest", "warn", "disk.guest_probe_failed", "Guest disk probe failed", compact(run.stderr or run.stdout))
            return
        rows = [line for line in run.stdout.splitlines() if line.strip()]
        fields = rows[1].split() if len(rows) >= 2 else []
        try:
            total_bytes = int(fields[1]) * 1024
            free_bytes = int(fields[3]) * 1024
            pct_used = int(fields[4].rstrip("%"))
        except (IndexError, ValueError):
            self.add("disk.guest", "warn", "disk.guest_parse_failed", "Guest disk output unreadable", compact(run.stdout))
            return
        if pct_used >= 95:
            status, code, action = "fail", "disk.guest_critical", "Free guest disk space now (prune images/build cache) before pulls or builds fail."
        elif pct_used >= 85:
            status, code, action = "warn", "disk.guest_low", "Guest disk is filling up; prune images/build cache before it blocks builds."
        else:
            status, code, action = "pass", "disk.guest_ok", ""
        self.add(
            "disk.guest",
            status,
            code,
            "Guest disk space",
            f"{format_bytes(free_bytes)} free of {format_bytes(total_bytes)} ({pct_used}% used)",
            action,
            free_bytes=free_bytes,
            total_bytes=total_bytes,
            percent_used=pct_used,
        )

    def check_memory(self) -> None:
        report = memory_report()
        report.update(self.guest_memory())
        engine = int(report.get("engine_rss_bytes", 0) or 0)
        app = int(report.get("app_rss_bytes", 0) or 0)
        guest_total = int(report.get("guest_total_bytes", 0) or 0)
        detail = (
            f"host RSS {format_bytes(report.get('rss_bytes', 0))} "
            f"(engine {format_bytes(engine)}, app {format_bytes(app)})"
        )
        if guest_total:
            detail += f"; guest RAM ceiling {format_bytes(guest_total)}"
            if engine:
                reclaimed = max(0, guest_total - engine)
                report["reclaimed_bytes"] = reclaimed
                report["reclaim_ratio"] = round(reclaimed / guest_total, 3)
                detail += f", ~{format_bytes(reclaimed)} reclaimed to macOS"
        self.add(
            "memory.footprint",
            "pass",
            "memory.footprint_ok",
            "Dory memory footprint",
            detail,
            **report,
        )

    def guest_memory(self) -> dict[str, Any]:
        try:
            info = self.api_json("/info")
        except Exception:
            return {}
        if not isinstance(info, dict):
            return {}
        return {
            "guest_total_bytes": int(info.get("MemTotal") or 0),
            "containers_running": int(info.get("ContainersRunning") or 0),
            "containers_total": int(info.get("Containers") or 0),
        }

    def check_helpers(self) -> None:
        resolver = Path(f"/etc/resolver/{DOMAIN_SUFFIX}")
        ca = HOME / "Library" / "Application Support" / "Dory" / "LocalCA"
        data = {"resolver": str(resolver), "resolver_exists": resolver.exists(), "local_ca_dir": str(ca), "local_ca_exists": ca.exists()}
        if resolver.exists():
            self.add("helpers.resolver", "pass", "helpers.resolver_ok", "Local domain resolver file exists", str(resolver), **data)
        else:
            self.add(
                "helpers.resolver",
                "warn",
                "helpers.resolver_missing",
                "Local domain resolver file missing",
                str(resolver),
                "Run `scripts/enable-networking.sh` if you want system-wide *.dory.local resolution.",
                **data,
            )

    def engine_available(self) -> bool:
        try:
            status_code, _, body = self.api("GET", "/_ping")
            return status_code == 200 and body.strip() == b"OK"
        except Exception:
            return False

    def start_http_container(self, reuse: bool = False) -> tuple[str | None, int | None]:
        existing = getattr(self, "_http_container", None)
        if reuse and existing:
            return existing
        if not self.engine_available():
            self.add("network.http_probe", "skip", "socket.unreachable", "HTTP probe skipped", "Docker API is not reachable.")
            return None, None
        name = f"dory-doctor-http-{self.run_id}"
        self.created_containers.append(name)
        _ = self.docker(["rm", "-f", name], timeout=15)
        host_port = free_tcp_port()
        command = (
            "while true; do "
            "printf 'HTTP/1.1 200 OK\\r\\nContent-Length: 14\\r\\n\\r\\ndory-doctor-ok' "
            "| nc -l -p 8080; "
            "done"
        )
        run = self.docker(
            [
                "run",
                "-d",
                "--pull=missing",
                "--name",
                name,
                "--label",
                self.label,
                "-p",
                f"127.0.0.1:{host_port}:8080",
                DOCKER_IMAGE,
                "sh",
                "-c",
                command,
            ],
            timeout=90,
        )
        if run.returncode != 0:
            self.add(
                "network.http_probe",
                "fail",
                "network.http_probe_start_failed",
                "Could not start HTTP probe container",
                compact(run.stderr or run.stdout),
            )
            return None, None
        port = None
        for _ in range(30):
            port_cmd = self.docker(["port", name, "8080/tcp"], timeout=8)
            if port_cmd.returncode == 0:
                port = parse_port(port_cmd.stdout)
                if port:
                    break
            time.sleep(0.2)
        if not port:
            self.add("network.http_probe", "fail", "network.port_missing", "HTTP probe has no published port", compact(port_cmd.stderr or port_cmd.stdout))
            return name, None
        self._http_container = (name, port)
        return name, port

    def cleanup(self) -> None:
        if not self.created_containers or not docker_bin():
            return
        names = sorted(set(self.created_containers))
        try:
            self.docker(["rm", "-f", *names], timeout=20)
        except Exception:
            pass


def unix_http(sock: Path, method: str, path: str, body: bytes | None = None, timeout: float = 5.0) -> tuple[int, dict[str, str], bytes]:
    body = body or b""
    request = (
        f"{method} {path} HTTP/1.1\r\n"
        "Host: dory\r\n"
        "User-Agent: dory-doctor\r\n"
        "Connection: close\r\n"
        f"Content-Length: {len(body)}\r\n"
        "\r\n"
    ).encode("utf-8") + body
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(timeout)
        client.connect(str(sock))
        client.sendall(request)
        chunks: list[bytes] = []
        while True:
            try:
                chunk = client.recv(65536)
            except socket.timeout as exc:
                # A read timeout is a real failure, not end-of-response: returning the partial bytes
                # would let a slow-but-healthy Docker API look like a malformed/short reply. The
                # `Connection: close` request means a healthy server closes the socket (recv -> b"")
                # when done, so the only way we reach here is a genuine stall.
                raise TimeoutError(f"Docker socket read timed out after {timeout}s") from exc
            if not chunk:
                break
            chunks.append(chunk)
    raw = b"".join(chunks)
    head, _, payload = raw.partition(b"\r\n\r\n")
    lines = head.decode("iso-8859-1", "replace").split("\r\n")
    if not lines or not lines[0].startswith("HTTP/"):
        raise RuntimeError("invalid HTTP response from Docker socket")
    parts = lines[0].split(" ", 2)
    status_code = int(parts[1])
    headers: dict[str, str] = {}
    for line in lines[1:]:
        if ":" in line:
            key, value = line.split(":", 1)
            headers[key.strip().lower()] = value.strip()
    if headers.get("transfer-encoding", "").lower() == "chunked":
        payload = decode_chunked(payload)
    return status_code, headers, payload


def decode_chunked(data: bytes) -> bytes:
    out = bytearray()
    index = 0
    while True:
        end = data.find(b"\r\n", index)
        if end < 0:
            break
        size_text = data[index:end].split(b";", 1)[0]
        try:
            size = int(size_text, 16)
        except ValueError:
            break
        index = end + 2
        if size == 0:
            break
        out += data[index : index + size]
        index += size + 2
    return bytes(out)


def compact(text: str, limit: int = 700) -> str:
    return re.sub(r"\s+", " ", text or "").strip()[:limit]


def http_get(url: str, timeout: float = 5.0) -> str:
    with urllib.request.urlopen(url, timeout=timeout) as response:
        return response.read(4096).decode("utf-8", "replace")


def wait_http(url: str, timeout: float = 5.0, attempts: int = 20) -> tuple[str, str]:
    last_error = ""
    for _ in range(attempts):
        try:
            return http_get(url, timeout=timeout), ""
        except Exception as exc:
            last_error = str(exc)
            time.sleep(0.25)
    return "", last_error


def parse_port(output: str) -> int | None:
    for token in re.split(r"\s+", output.strip()):
        if ":" in token:
            candidate = token.rsplit(":", 1)[-1]
            if candidate.isdigit():
                return int(candidate)
    return None


def slugify(value: str) -> str:
    slug = re.sub(r"[^A-Za-z0-9_.-]+", "-", value.strip().lower()).strip("-")
    return slug[:80] or "probe"


def parse_network_probe(value: str) -> dict[str, Any]:
    raw = value.strip()
    if not raw:
        raise ValueError("probe cannot be empty")
    name = ""
    if "=" in raw and "://" not in raw.split("=", 1)[0]:
        name, raw = raw.split("=", 1)
        name = name.strip()
        raw = raw.strip()
    if "://" in raw:
        parsed = urllib.parse.urlparse(raw)
        if parsed.username or parsed.password:
            raise ValueError("network probes must not contain credentials")
        host = parsed.hostname or ""
        port = parsed.port or (443 if parsed.scheme == "https" else 80)
    else:
        if "/" in raw or "@" in raw:
            raise ValueError("network probes must be host[:port] without paths or credentials")
        host = raw
        port = 443
        if raw.count(":") == 1:
            left, right = raw.rsplit(":", 1)
            if right.isdigit():
                host = left
                port = int(right)
    host = host.strip().strip("[]").lower()
    if not host or not re.match(r"^[A-Za-z0-9_.:-]+$", host):
        raise ValueError(f"invalid probe host: {host or value}")
    if port < 1 or port > 65535:
        raise ValueError(f"invalid probe port: {port}")
    return {
        "name": slugify(name or host),
        "host": host,
        "port": port,
    }


def network_probes(extra: list[str] | None = None) -> list[dict[str, Any]]:
    probes = [parse_network_probe(f"docker-hub={os.environ.get('DORY_REGISTRY_PROBE', 'registry-1.docker.io')}:443")]
    for item in (load_config().get("network") or {}).get("probes", []):
        try:
            if isinstance(item, str):
                probes.append(parse_network_probe(item))
            elif isinstance(item, dict):
                probes.append(parse_network_probe(f"{item.get('name') or item.get('host')}={item.get('host')}:{item.get('port', 443)}"))
        except Exception:
            continue
    for item in extra or []:
        probes.append(parse_network_probe(item))
    seen: set[tuple[str, int]] = set()
    deduped: list[dict[str, Any]] = []
    for probe in probes:
        key = (str(probe["host"]), int(probe["port"]))
        if key in seen:
            continue
        seen.add(key)
        deduped.append(probe)
    return deduped


def save_network_probe(value: str) -> dict[str, Any]:
    probe = parse_network_probe(value)
    config = load_config()
    network = dict(config.get("network") or {})
    probes = [p for p in network.get("probes", []) if not (isinstance(p, dict) and p.get("host") == probe["host"] and int(p.get("port", 443)) == probe["port"])]
    probes.append(probe)
    network["probes"] = sorted(probes, key=lambda item: (str(item.get("host")), int(item.get("port", 443))))
    config["network"] = network
    save_config(config)
    return probe


def remove_network_probe(value: str) -> bool:
    target = parse_network_probe(value)
    config = load_config()
    network = dict(config.get("network") or {})
    original = list(network.get("probes", []))
    kept = [
        item for item in original
        if not (isinstance(item, dict) and item.get("host") == target["host"] and int(item.get("port", 443)) == target["port"])
    ]
    network["probes"] = kept
    config["network"] = network
    save_config(config)
    return len(kept) != len(original)


def free_tcp_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        s.bind(("127.0.0.1", 0))
        return int(s.getsockname()[1])


def docker_summary(report: dict[str, Any]) -> str:
    return (
        f"images={format_bytes(report.get('images_bytes', 0))} "
        f"containers={format_bytes(report.get('containers_bytes', 0))} "
        f"volumes={format_bytes(report.get('volumes_bytes', 0))} "
        f"build_cache={format_bytes(report.get('build_cache_bytes', 0))}"
    )


def disk_report(sock: Path | None = None) -> dict[str, Any]:
    sock = sock or socket_path()
    target = HOME
    try:
        usage = shutil.disk_usage(target)
        host = {
            "path": str(target),
            "total_bytes": usage.total,
            "used_bytes": usage.used,
            "free_bytes": usage.free,
        }
    except Exception as exc:
        host = {"path": str(target), "error": str(exc)}

    docker: dict[str, Any] = {"available": False}
    try:
        status_code, _, body = unix_http(sock, "GET", "/system/df", timeout=5)
        if 200 <= status_code < 300:
            raw = json.loads(body.decode("utf-8") or "{}")
            images = raw.get("Images") or []
            containers = raw.get("Containers") or []
            volumes = raw.get("Volumes") or []
            build_cache = raw.get("BuildCache") or []
            docker = {
                "available": True,
                "images_count": len(images),
                "containers_count": len(containers),
                "volumes_count": len(volumes),
                "build_cache_count": len(build_cache),
                "images_bytes": sum_int(item.get("Size") for item in images),
                "containers_bytes": sum_int((item.get("SizeRw") or item.get("SizeRootFs")) for item in containers),
                "volumes_bytes": sum_int(((item.get("UsageData") or {}).get("Size")) for item in volumes),
                "build_cache_bytes": sum_int(item.get("Size") for item in build_cache),
            }
        else:
            docker["error"] = f"HTTP {status_code}"
    except Exception as exc:
        docker["error"] = str(exc)

    state_root = HOME / ".dory"
    state = {
        "path": str(state_root),
        "total_bytes": directory_size(state_root),
        "log_bytes": matched_size(state_root, ["*.log", "*.log.*", "*.err.log"]),
        "largest_log": largest_matching_file(state_root, ["*.log", "*.log.*", "*.err.log"]),
        "vm_disk_bytes": matched_size(state_root, ["*.raw", "*.qcow2", "*.img", "*.ext4", "*.vhd", "*.vhdx"]),
    }
    return {"generated_at": now_iso(), "socket": str(sock), "host": host, "docker": docker, "state": state}


def cleanup_report(apply: bool = False, include_volumes: bool = False, log_max_bytes: int = 5_000_000) -> dict[str, Any]:
    actions: list[dict[str, Any]] = []
    report = disk_report()
    docker = report.get("docker", {})
    if docker.get("available"):
        containers = docker_containers_for_cleanup()
        stopped = [c for c in containers if (c.get("State") or "") != "running"]
        actions.append(cleanup_action(
            target="stopped-containers",
            apply=apply,
            count=len(stopped),
            bytes_reclaimable=sum_int((c.get("SizeRw") or c.get("SizeRootFs")) for c in stopped),
            command=["container", "prune", "-f"],
            detail=f"{len(stopped)} stopped container(s)",
        ))
        dangling_images = docker_image_ids(["images", "-f", "dangling=true", "-q"])
        actions.append(cleanup_action(
            target="dangling-images",
            apply=apply,
            count=len(dangling_images),
            bytes_reclaimable=0,
            command=["image", "prune", "-f"],
            detail=f"{len(dangling_images)} dangling image(s)",
        ))
        build_cache_bytes = int(docker.get("build_cache_bytes") or 0)
        actions.append(cleanup_action(
            target="build-cache",
            apply=apply,
            count=int(docker.get("build_cache_count") or 0),
            bytes_reclaimable=build_cache_bytes,
            command=["builder", "prune", "-f"],
            detail=f"{format_bytes(build_cache_bytes)} build cache",
        ))
        if include_volumes:
            volume_bytes = int(docker.get("volumes_bytes") or 0)
            actions.append(cleanup_action(
                target="unused-volumes",
                apply=apply,
                count=int(docker.get("volumes_count") or 0),
                bytes_reclaimable=volume_bytes,
                command=["volume", "prune", "-f"],
                detail=f"{format_bytes(volume_bytes)} volume data; destructive",
            ))
        else:
            actions.append({
                "target": "unused-volumes",
                "status": "skip",
                "detail": "Volume cleanup skipped; pass --include-volumes to inspect this destructive cleanup action.",
                "risk": "high",
            })
    else:
        actions.append({
            "target": "docker",
            "status": "skip",
            "detail": docker.get("error", "Docker API unavailable"),
        })
    actions.append(cleanup_logs(apply=apply, max_bytes=log_max_bytes))
    return {
        "generated_at": now_iso(),
        "apply": apply,
        "include_volumes": include_volumes,
        "actions": actions,
    }


def docker_containers_for_cleanup() -> list[dict[str, Any]]:
    try:
        status_code, _, body = unix_http(socket_path(), "GET", "/containers/json?all=1&size=1", timeout=5)
        if 200 <= status_code < 300:
            data = json.loads(body.decode("utf-8") or "[]")
            return data if isinstance(data, list) else []
    except Exception:
        pass
    return []


def docker_image_ids(args: list[str]) -> list[str]:
    try:
        result = docker_cli(args, timeout=30)
    except Exception:
        return []
    if result.returncode != 0:
        return []
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def cleanup_action(
    target: str,
    apply: bool,
    count: int,
    bytes_reclaimable: int,
    command: list[str],
    detail: str,
) -> dict[str, Any]:
    action: dict[str, Any] = {
        "target": target,
        "status": "pass" if count == 0 and bytes_reclaimable == 0 else "warn",
        "detail": detail,
        "count": count,
        "bytes_reclaimable": bytes_reclaimable,
        "risk": "medium" if target == "build-cache" else "low",
        "command": ["docker", *command],
    }
    if not apply or (count == 0 and bytes_reclaimable == 0):
        action["applied"] = False
        return action
    try:
        result = docker_cli(command, timeout=120)
    except Exception as exc:
        action.update({"status": "fail", "applied": False, "detail": str(exc)})
        return action
    action["applied"] = result.returncode == 0
    if result.returncode != 0:
        action["status"] = "fail"
        action["detail"] = compact(result.stderr or result.stdout)
    else:
        action["status"] = "pass"
        action["detail"] = compact(result.stdout or detail)
    return action


def cleanup_logs(apply: bool, max_bytes: int) -> dict[str, Any]:
    state_root = HOME / ".dory"
    logs = []
    total_reclaimable = 0
    if state_root.exists():
        for path in sorted(state_root.glob("*.log*")):
            if not path.is_file():
                continue
            try:
                size = path.stat().st_size
            except OSError:
                continue
            reclaimable = max(0, size - max_bytes)
            if reclaimable:
                logs.append({"path": str(path), "size_bytes": size, "bytes_reclaimable": reclaimable})
                total_reclaimable += reclaimable
                if apply:
                    trim_file_tail(path, max_bytes)
    return {
        "target": "logs",
        "status": "pass" if total_reclaimable == 0 else "warn",
        "detail": f"{format_bytes(total_reclaimable)} log bytes above {format_bytes(max_bytes)} per file",
        "bytes_reclaimable": total_reclaimable,
        "applied": bool(apply and total_reclaimable),
        "risk": "low",
        "files": logs,
    }


def trim_file_tail(path: Path, max_bytes: int) -> None:
    with path.open("rb") as handle:
        handle.seek(0, os.SEEK_END)
        size = handle.tell()
        handle.seek(max(0, size - max_bytes))
        data = handle.read(max_bytes)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_bytes(data)
    os.replace(tmp, path)


def sum_int(values: Any) -> int:
    total = 0
    for value in values:
        if isinstance(value, int):
            total += max(0, value)
    return total


def directory_size(root: Path) -> int:
    if not root.exists():
        return 0
    total = 0
    for dirpath, dirnames, filenames in os.walk(root, onerror=lambda _: None):
        dirnames[:] = [d for d in dirnames if d not in {"Cache", "tmp"}]
        for name in filenames:
            path = Path(dirpath) / name
            try:
                st = path.stat()
            except OSError:
                continue
            if stat.S_ISREG(st.st_mode):
                total += st.st_size
    return total


def matched_size(root: Path, patterns: list[str]) -> int:
    if not root.exists():
        return 0
    total = 0
    for dirpath, _, filenames in os.walk(root, onerror=lambda _: None):
        for name in filenames:
            if any(fnmatch.fnmatch(name, pattern) for pattern in patterns):
                try:
                    total += (Path(dirpath) / name).stat().st_size
                except OSError:
                    pass
    return total


def largest_matching_file(root: Path, patterns: list[str]) -> dict[str, Any]:
    biggest = {"path": "", "bytes": 0}
    if not root.exists():
        return biggest
    for dirpath, _, filenames in os.walk(root, onerror=lambda _: None):
        for name in filenames:
            if any(fnmatch.fnmatch(name, pattern) for pattern in patterns):
                try:
                    size = (Path(dirpath) / name).stat().st_size
                except OSError:
                    continue
                if size > biggest["bytes"]:
                    biggest = {"path": str(Path(dirpath) / name), "bytes": size}
    return biggest


def memory_report() -> dict[str, Any]:
    patterns = [re.compile(p, re.I) for p in os.environ.get("DORY_PROCESS_PATTERN", "Dory|doryd|dory-hv|dory-vmm|gvproxy").split("|")]
    processes: list[dict[str, Any]] = []
    rss = 0
    try:
        result = subprocess.run(["ps", "-axo", "pid=,rss=,comm=,args="], text=True, capture_output=True, timeout=8)
        lines = result.stdout.splitlines() if result.returncode == 0 else []
    except Exception:
        lines = []
    for line in lines:
        parts = line.strip().split(None, 2)
        if len(parts) < 3:
            continue
        pid_text, rss_text, rest = parts
        if "dory-doctor" in rest:
            continue
        if not any(pattern.search(rest) for pattern in patterns):
            continue
        try:
            rss_bytes = int(rss_text) * 1024
        except ValueError:
            continue
        rss += rss_bytes
        lowered = rest.lower()
        if "dory-hv" in lowered or "dory-vmm" in lowered:
            role = "engine"
        elif "gvproxy" in lowered:
            role = "network"
        else:
            role = "app"
        processes.append({"pid": int(pid_text), "rss_bytes": rss_bytes, "role": role, "command": rest[:240]})
    engine_rss = sum(p["rss_bytes"] for p in processes if p["role"] == "engine")
    app_rss = sum(p["rss_bytes"] for p in processes if p["role"] == "app")
    helper_rss = sum(p["rss_bytes"] for p in processes if p["role"] == "network")
    return {
        "generated_at": now_iso(),
        "rss_bytes": rss,
        "engine_rss_bytes": engine_rss,
        "app_rss_bytes": app_rss,
        "helper_rss_bytes": helper_rss,
        "processes": processes,
    }


def capture_command(command: list[str], timeout: float = 5.0, max_bytes: int = SUPPORT_SYSTEM_LOG_BYTES) -> dict[str, Any]:
    tool = shutil.which(command[0]) if not command[0].startswith("/") else command[0]
    if not tool:
        return {"available": False, "ok": False, "command": command, "error": f"{command[0]} not found"}
    resolved = [tool, *command[1:]]
    try:
        result = subprocess.run(
            resolved,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return {"available": True, "ok": False, "command": command, "error": f"{command[0]} timed out"}
    except OSError as exc:
        return {"available": True, "ok": False, "command": command, "error": str(exc)}
    stdout = result.stdout or ""
    stderr = result.stderr or ""
    truncated_stdout = len(stdout.encode("utf-8", "replace")) > max_bytes
    truncated_stderr = len(stderr.encode("utf-8", "replace")) > max_bytes
    if truncated_stdout:
        stdout = stdout[-max_bytes:]
    if truncated_stderr:
        stderr = stderr[-max_bytes:]
    return {
        "available": True,
        "ok": result.returncode == 0,
        "command": command,
        "exit_code": result.returncode,
        "stdout": stdout,
        "stderr": stderr,
        "stdout_truncated": truncated_stdout,
        "stderr_truncated": truncated_stderr,
    }


def host_report() -> dict[str, Any]:
    uname = os.uname()
    return {
        "generated_at": now_iso(),
        "platform": sys.platform,
        "machine": uname.machine,
        "release": uname.release,
        "version": uname.version,
        "python": sys.version.split()[0],
        "uid": os.getuid() if hasattr(os, "getuid") else None,
        "state_root": str(STATE_ROOT),
        "sw_vers": capture_command(["sw_vers"], timeout=3, max_bytes=16_000) if sys.platform == "darwin" else None,
    }


def launchd_report() -> dict[str, Any]:
    if sys.platform != "darwin" or not hasattr(os, "getuid"):
        return {"available": False, "ok": False, "error": "launchd diagnostics are macOS-only"}
    return capture_command(
        ["launchctl", "print", f"gui/{os.getuid()}/dev.dory.doryd"],
        timeout=5,
        max_bytes=120_000,
    )


def unified_log_report() -> dict[str, Any]:
    if sys.platform != "darwin":
        return {"available": False, "ok": False, "error": "unified logs are macOS-only"}
    if os.environ.get("DORY_SUPPORT_UNIFIED_LOG", "1").lower() in {"0", "false", "no", "off"}:
        return {"available": False, "ok": False, "error": "disabled by DORY_SUPPORT_UNIFIED_LOG"}
    predicate = (
        'process == "Dory" OR process == "doryd" OR process == "dory-hv" OR '
        'process == "dory-vmm" OR process == "gvproxy" OR process == "dory-network-helper"'
    )
    return capture_command(
        ["log", "show", "--style", "compact", "--last", SUPPORT_UNIFIED_LOG_LAST, "--predicate", predicate],
        timeout=8,
        max_bytes=SUPPORT_SYSTEM_LOG_BYTES,
    )


def parse_scutil_proxy(text: str) -> dict[str, Any]:
    fields: dict[str, str] = {}
    for line in text.splitlines():
        if " : " in line:
            key, value = line.split(" : ", 1)
            fields[key.strip()] = value.strip()
    out: dict[str, str] = {}
    if fields.get("HTTPEnable") == "1" and fields.get("HTTPProxy"):
        out["http_proxy"] = redact_str(f"{fields['HTTPProxy']}:{fields.get('HTTPPort', '')}".rstrip(":"))
    if fields.get("HTTPSEnable") == "1" and fields.get("HTTPSProxy"):
        out["https_proxy"] = redact_str(f"{fields['HTTPSProxy']}:{fields.get('HTTPSPort', '')}".rstrip(":"))
    if fields.get("ProxyAutoConfigEnable") == "1" and fields.get("ProxyAutoConfigURLString"):
        out["pac"] = redact_str(fields["ProxyAutoConfigURLString"])
    return out


def proxy_report(sock: Path | None = None) -> dict[str, Any]:
    sock = sock or socket_path()
    host_env: dict[str, str] = {}
    for key in ["HTTP_PROXY", "HTTPS_PROXY", "NO_PROXY", "ALL_PROXY"]:
        value = os.environ.get(key) or os.environ.get(key.lower())
        if value:
            host_env[key] = redact_str(value)

    system: dict[str, Any] = {}
    try:
        result = subprocess.run(["scutil", "--proxy"], text=True, capture_output=True, timeout=5)
        if result.returncode == 0:
            system = parse_scutil_proxy(result.stdout)
    except Exception:
        pass

    daemon: dict[str, str] = {}
    try:
        status_code, _, body = unix_http(sock, "GET", "/info", timeout=5)
        if 200 <= status_code < 300:
            info = json.loads(body.decode("utf-8") or "{}")
            for out_key, info_key in [("http_proxy", "HTTPProxy"), ("https_proxy", "HTTPSProxy"), ("no_proxy", "NoProxy")]:
                value = info.get(info_key)
                if value:
                    daemon[out_key] = redact_str(str(value))
    except Exception:
        pass

    containers: dict[str, str] = {}
    docker_cfg = HOME / ".docker" / "config.json"
    if docker_cfg.exists():
        try:
            cfg = json.loads(docker_cfg.read_text(encoding="utf-8") or "{}")
            default = ((cfg.get("proxies") or {}).get("default")) or {}
            for out_key, cfg_key in [("http_proxy", "httpProxy"), ("https_proxy", "httpsProxy"), ("no_proxy", "noProxy")]:
                value = default.get(cfg_key)
                if value:
                    containers[out_key] = redact_str(str(value))
        except Exception:
            pass

    return {"generated_at": now_iso(), "host_env": host_env, "system": system, "daemon": daemon, "containers": containers}


SENSITIVE_SHARE_NAMES = [
    ".ssh", ".aws", ".gcloud", ".azure", ".kube", ".docker", ".gnupg", ".config",
    ".zsh_history", ".bash_history", ".netrc", ".npmrc", ".pypirc", "Library",
]


def mount_report() -> dict[str, Any]:
    # Dory shares the user's home at its identical guest path (the OrbStack "just works" default),
    # read-write, with the `:safe` policy that hides credential stores and shell rc files. This is a
    # fixed engine default, so the file-sharing dashboard can report it without querying the guest.
    home = str(HOME)
    return {
        "generated_at": now_iso(),
        "shares": [
            {
                "host_path": home,
                "guest_path": home,
                "mode": "rw",
                "policy": "safe",
                "hidden": SENSITIVE_SHARE_NAMES,
                "backend": "virtio-fs",
            }
        ],
        "policy_note": "Credential stores and shell rc files (~/.ssh, ~/.aws, ~/.kube, Library, …) are hidden from every container as defense-in-depth.",
    }


def route_table(sock: Path | None = None) -> dict[str, Any]:
    sock = sock or socket_path()
    out: dict[str, Any] = {"generated_at": now_iso(), "socket": str(sock), "ports": [], "domains": [], "error": ""}
    try:
        status_code, _, body = unix_http(sock, "GET", "/containers/json?all=1", timeout=5)
        if not (200 <= status_code < 300):
            out["error"] = f"Docker API returned HTTP {status_code}"
            return out
        containers = json.loads(body.decode("utf-8") or "[]")
    except Exception as exc:
        out["error"] = str(exc)
        return out

    host_port_counts: dict[tuple[str, int], int] = {}
    for container in containers:
        for port in container.get("Ports") or []:
            public = port.get("PublicPort")
            if public:
                host_ip = port.get("IP") or "0.0.0.0"
                host_port_counts[(host_ip, int(public))] = host_port_counts.get((host_ip, int(public)), 0) + 1

    for container in containers:
        names = [n[1:] if n.startswith("/") else n for n in (container.get("Names") or [])]
        name = names[0] if names else (container.get("Id") or "")[:12]
        state = container.get("State") or ""
        status = container.get("Status") or ""
        labels = container.get("Labels") or {}
        project = labels.get("com.docker.compose.project") or labels.get("dev.dory.project") or ""
        public_ports: list[int] = []
        for port in container.get("Ports") or []:
            private = port.get("PrivatePort")
            public = port.get("PublicPort")
            if public:
                host_ip = port.get("IP") or "0.0.0.0"
                conflict = host_port_counts.get((host_ip, int(public)), 0) > 1
                row = {
                    "container": name,
                    "container_id": (container.get("Id") or "")[:12],
                    "state": state,
                    "status": status,
                    "project": project,
                    "host_ip": host_ip,
                    "host_port": int(public),
                    "container_port": int(private) if private else None,
                    "protocol": port.get("Type") or "tcp",
                    "conflict": conflict,
                }
                out["ports"].append(row)
                public_ports.append(int(public))
        if public_ports and state == "running":
            domain = f"{name}.{DOMAIN_SUFFIX}".lower()
            out["domains"].append(
                {
                    "domain": domain,
                    "container": name,
                    "project": project,
                    "host_port": min(public_ports),
                    "http_proxy": f"http://127.0.0.1:{DOMAIN_PROXY_PORT}",
                    "https_proxy": f"https://127.0.0.1:{HTTPS_PROXY_PORT}",
                    "target": f"http://127.0.0.1:{min(public_ports)}",
                }
            )
    out["ports"].sort(key=lambda row: (row["host_port"], row["container"]))
    out["domains"].sort(key=lambda row: row["domain"])
    return out


def idle_status(sock: Path | None = None) -> dict[str, Any]:
    config = load_config()
    table = route_table(sock)
    blockers: list[dict[str, Any]] = []
    if table.get("error"):
        blockers.append({"type": "engine", "reason": table["error"]})
    running_names = set()
    for row in table.get("ports", []):
        if row.get("state") == "running":
            running_names.add(row["container"])
            blockers.append({"type": "published-port", "container": row["container"], "port": row["host_port"]})
    try:
        status_code, _, body = unix_http(sock or socket_path(), "GET", "/containers/json?all=1", timeout=5)
        containers = json.loads(body.decode("utf-8") or "[]") if 200 <= status_code < 300 else []
        for container in containers:
            name = ((container.get("Names") or [""])[0]).lstrip("/") or (container.get("Id") or "")[:12]
            if container.get("State") == "running" and name not in running_names:
                blockers.append({"type": "running-container", "container": name})
            labels = container.get("Labels") or {}
            if labels.get("io.dory.keep-awake") == "true" or labels.get("dev.dory.keep-awake") == "true":
                blockers.append({"type": "pinned", "container": name})
    except Exception:
        pass
    if DEFAULT_KUBECONFIG.exists():
        blockers.append({"type": "kubernetes-config", "path": str(DEFAULT_KUBECONFIG)})
    mode = config.get("runtimeMode", "manual")
    policy = config.get("idle") or {}
    return {
        "generated_at": now_iso(),
        "mode": mode,
        "auto_idle_enabled": mode in {"auto-idle", "battery-saver"},
        "sleep_after_minutes": policy.get("sleepAfterMinutes"),
        "can_sleep": len(blockers) == 0,
        "blockers": blockers,
        "proxy_state": read_idle_proxy_state(),
        "policy": policy,
    }


def read_idle_proxy_state() -> dict[str, Any]:
    path = idle_state_path()
    if not path.exists():
        return {
            "available": False,
            "path": str(path),
            "state": "unknown",
            "detail": "doryd has not written idle state yet",
        }
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        return {
            "available": False,
            "path": str(path),
            "state": "unknown",
            "detail": f"could not read state: {exc}",
        }
    data["available"] = True
    data.setdefault("path", str(path))
    return data


def load_config() -> dict[str, Any]:
    path = config_path()
    if not path.exists():
        return default_config()
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default_config()
    return merge_config(default_config(), raw)


def default_config() -> dict[str, Any]:
    return {
        "runtimeMode": "manual",
        "idle": {
            "sleepAfterMinutes": 15,
            "keepPublishedPortsAwake": True,
            "keepKubernetesAwake": True,
            "keepPinnedProjectsAwake": True,
            "showWakeNotifications": True,
        },
        "network": {
            "probes": [],
            "lanVisible": False,
        },
    }


def merge_config(base: dict[str, Any], override: dict[str, Any]) -> dict[str, Any]:
    out = dict(base)
    for key, value in override.items():
        if isinstance(value, dict) and isinstance(out.get(key), dict):
            nested = dict(out[key])
            nested.update(value)
            out[key] = nested
        else:
            out[key] = value
    return out


def save_config(config: dict[str, Any]) -> None:
    path = config_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    # Per-process temp name: two concurrent writers (a `dory mode` and a `dory idle set`) must not
    # share one `.tmp` and truncate each other's in-flight write before the atomic replace.
    tmp = path.with_suffix(f"{path.suffix}.{os.getpid()}.tmp")
    try:
        tmp.write_text(json.dumps(config, indent=2, sort_keys=True) + "\n", encoding="utf-8")
        os.replace(tmp, path)
    except OSError:
        try:
            tmp.unlink()
        except OSError:
            pass
        raise


def format_bytes(value: int | float | None) -> str:
    if not value:
        return "0 B"
    value = float(value)
    for unit in ["B", "KB", "MB", "GB", "TB"]:
        if value < 1024 or unit == "TB":
            if unit == "B":
                return f"{int(value)} {unit}"
            return f"{value:.1f} {unit}"
        value /= 1024
    return f"{value:.1f} TB"


def redact(value: Any) -> Any:
    if isinstance(value, dict):
        out = {}
        for key, item in value.items():
            if SECRET_KEY_RE.search(str(key)):
                out[key] = "[redacted]"
            else:
                out[key] = redact(item)
        return out
    if isinstance(value, list):
        return [redact(item) for item in value]
    if isinstance(value, str):
        return redact_str(value)
    return value


def redact_str(value: str) -> str:
    value = BEARER_RE.sub("Bearer [redacted]", value)
    value = BASIC_RE.sub("Basic [redacted]", value)
    # user:pass@host credentials embedded in URLs (e.g. HTTPS_PROXY=http://user:secret@proxy:8080).
    value = URL_CREDENTIAL_RE.sub(r"\1[redacted]@", value)
    # Schemeless user:pass@host (e.g. ALL_PROXY=user:secret@proxy:8080). The lookbehind skips values
    # already handled by the URL rule above (their creds follow `//`).
    value = re.sub(r"(?<![/\w@])([^\s:/@]+:)[^\s:/@]+@", r"\1[redacted]@", value)
    # token/secret/password/access_token/... in both `key=value` and `key: value` forms, covering
    # log lines and query strings alike.
    value = re.sub(
        r"(?i)((?:access[_-]?|refresh[_-]?)?(?:password|passwd|token|secret|apikey|api[_-]?key))(\s*[=:]\s*)([^&\s\"']+)",
        lambda m: f"{m.group(1)}{m.group(2)}[redacted]",
        value,
    )
    # base64-ish X-Registry-Auth / long opaque credential blobs.
    value = re.sub(r"(?i)(x-registry-auth\s*[=:]\s*)[A-Za-z0-9+/=_-]{16,}", r"\1[redacted]", value)
    return value


def first_executable(candidates: list[str | None]) -> Path | None:
    for raw in candidates:
        if not raw:
            continue
        candidate = Path(raw).expanduser()
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return candidate
    return None


def dorydctl_bin() -> Path | None:
    return first_executable([
        os.environ.get("DORYDCTL_BIN"),
        str(SCRIPT_DIR / "dorydctl"),
        str(SCRIPT_DIR / "../Helpers/dorydctl"),
        str(HOME / ".dory" / "bin" / "dorydctl"),
        shutil.which("dorydctl"),
    ])


def dorydctl_json(args: list[str], timeout: float = 4.0) -> dict[str, Any]:
    tool = dorydctl_bin()
    if tool is None:
        return {"available": False, "ok": False, "error": "dorydctl not found"}
    command = [str(tool), "--timeout", str(max(1, int(timeout))), *args]
    try:
        result = subprocess.run(command, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout + 1)
    except subprocess.TimeoutExpired:
        return {"available": True, "ok": False, "command": args, "error": "dorydctl timed out"}
    except OSError as exc:
        return {"available": True, "ok": False, "command": args, "error": str(exc)}
    if result.returncode != 0:
        return {
            "available": True,
            "ok": False,
            "command": args,
            "exit_code": result.returncode,
            "error": compact(result.stderr or result.stdout),
        }
    try:
        payload = json.loads(result.stdout or "null")
    except json.JSONDecodeError as exc:
        return {
            "available": True,
            "ok": False,
            "command": args,
            "error": f"invalid JSON from dorydctl: {exc}",
            "stdout": compact(result.stdout),
        }
    return {"available": True, "ok": True, "command": args, "body": payload}


def doryd_support_snapshot() -> dict[str, Any]:
    return {
        "doctor": dorydctl_json(["doctor-json"]),
        "health": dorydctl_json(["health"]),
        "engine": dorydctl_json(["engine", "status"]),
        "ports": dorydctl_json(["docker", "ports"]),
        "machines": dorydctl_json(["machine", "list"]),
        "idle": dorydctl_json(["idle", "status"]),
        "idle_history": dorydctl_json(["idle", "history", "--limit", "80"]),
        "incidents": dorydctl_json(["incidents", "--limit", "200"]),
    }


def safe_archive_name_part(value: str) -> str:
    return re.sub(r"[^A-Za-z0-9._-]+", "_", value).strip("._") or "log"


def unique_archive_name(name: str, used: set[str]) -> str:
    if name not in used:
        used.add(name)
        return name
    path = Path(name)
    stem = path.stem or "log"
    suffix = "".join(path.suffixes)
    parent = "" if str(path.parent) == "." else f"{path.parent}/"
    index = 2
    while True:
        candidate = f"{parent}{stem}-{index}{suffix}"
        if candidate not in used:
            used.add(candidate)
            return candidate
        index += 1


def recent_files(root: Path, patterns: list[str], limit: int) -> list[Path]:
    if not root.is_dir():
        return []
    matched: list[Path] = []
    for pattern in patterns:
        matched.extend(path for path in root.glob(pattern) if path.is_file())
    unique: dict[Path, Path] = {}
    for path in matched:
        try:
            unique[path.resolve()] = path
        except OSError:
            continue
    return sorted(
        unique.values(),
        key=lambda item: item.stat().st_mtime if item.exists() else 0,
        reverse=True,
    )[:limit]


def unique_log_sources() -> list[tuple[Path, str]]:
    candidates: list[tuple[Path, str]] = []

    for pattern in ("*.log", "*.err.log", "*.log.*"):
        for path in sorted(STATE_ROOT.glob(pattern)):
            candidates.append((path, f"logs/{path.name}"))

    nested_roots = [
        (STATE_ROOT / "hv", "logs/hv", 20),
        (STATE_ROOT / "machines" / "logs", "logs/machines", 40),
    ]
    for root, archive_root, limit in nested_roots:
        if not root.is_dir():
            continue
        paths = sorted(
            [path for path in root.glob("*.log*") if path.is_file()],
            key=lambda item: item.stat().st_mtime if item.exists() else 0,
            reverse=True,
        )[:limit]
        for path in paths:
            candidates.append((path, f"{archive_root}/{path.name}"))

    app_log_roots = [
        HOME / "Library" / "Logs",
        HOME / "Library" / "Logs" / "Dory",
        HOME / "Library" / "Containers" / "com.pythonxi.Dory" / "Data" / "Library" / "Logs",
    ]
    app_patterns = ["Dory*.log*", "dory*.log*", "com.pythonxi.Dory*.log*", "dev.dory*.log*"]
    for root in app_log_roots:
        for path in recent_files(root, app_patterns, 20):
            candidates.append((path, f"logs/app/{safe_archive_name_part(path.name)}"))

    crash_root = HOME / "Library" / "Logs" / "DiagnosticReports"
    crash_patterns = [
        "Dory*.crash", "Dory*.ips", "Dory*.diag",
        "dory*.crash", "dory*.ips", "dory*.diag",
        "doryd*.crash", "doryd*.ips",
        "dory-hv*.crash", "dory-hv*.ips",
        "dory-vmm*.crash", "dory-vmm*.ips",
        "gvproxy*.crash", "gvproxy*.ips",
    ]
    for path in recent_files(crash_root, crash_patterns, 20):
        candidates.append((path, f"logs/crash/{safe_archive_name_part(path.name)}"))

    seen: set[Path] = set()
    used_names: set[str] = set()
    result: list[tuple[Path, str]] = []
    for path, archive_name in candidates:
        try:
            resolved = path.resolve()
        except OSError:
            continue
        if resolved in seen or not path.is_file():
            continue
        seen.add(resolved)
        result.append((path, unique_archive_name(archive_name, used_names)))
    return result


def bundle(path: Path | None, active: bool = False) -> Path:
    if path is None:
        stamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
        path = HOME / ".dory" / "diagnostics" / f"dory-diagnostics-{stamp}.zip"
    path.parent.mkdir(parents=True, exist_ok=True)
    doctor = Doctor(active=active)
    results = doctor.run_all()
    payload = {
        "support": {
            "schema": "dev.dory.support.bundle",
            "version": 1,
            "redacted": True,
            "active_probes": active,
            "log_tail_bytes": SUPPORT_LOG_TAIL_BYTES,
            "unified_log_last": SUPPORT_UNIFIED_LOG_LAST,
        },
        "generated_at": now_iso(),
        "host": host_report(),
        "process_memory": memory_report(),
        "launchd": launchd_report(),
        "doctor": [result.as_dict() for result in results],
        "routes": route_table(),
        "proxy": proxy_report(),
        "mounts": mount_report(),
        "disk": disk_report(),
        "idle": idle_status(),
        "incidents": read_incidents(200),
        "doryd": doryd_support_snapshot(),
        "config": load_config(),
        "environment": safe_environment(),
    }
    unified_log = unified_log_report()
    payload["unified_log"] = {
        key: value for key, value in unified_log.items() if key not in {"stdout", "stderr"}
    }
    written: list[str] = []
    with zipfile.ZipFile(path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        def write_text(name: str, text: str) -> None:
            zf.writestr(name, redact_str(text))
            written.append(name)

        write_text("doctor.json", json.dumps(redact(payload), indent=2, sort_keys=True) + "\n")
        if payload["launchd"].get("available"):
            write_text(
                "system/launchctl-dev.dory.doryd.txt",
                (payload["launchd"].get("stdout") or payload["launchd"].get("stderr") or "") + "\n",
            )
        if unified_log.get("available"):
            write_text(
                "system/unified-log-dory.txt",
                (unified_log.get("stdout") or unified_log.get("stderr") or "") + "\n",
            )
        for source, name in unique_log_sources():
            if source.exists() and source.is_file():
                write_text(name, tail_text(source, SUPPORT_LOG_TAIL_BYTES))
        manifest = {
            "schema": "dev.dory.support.bundle.manifest",
            "version": 1,
            "generated_at": payload["generated_at"],
            "redacted": True,
            "entries": sorted(written),
        }
        zf.writestr("manifest.json", json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    return path


def safe_environment() -> dict[str, str]:
    keep = {}
    for key, value in os.environ.items():
        if key.startswith("DORY_") or key in {"DOCKER_HOST", "DOCKER_CONTEXT", "HTTP_PROXY", "HTTPS_PROXY", "NO_PROXY"}:
            keep[key] = value
    return keep


def tail_text(path: Path, max_bytes: int) -> str:
    with path.open("rb") as handle:
        try:
            handle.seek(0, os.SEEK_END)
            size = handle.tell()
            handle.seek(max(0, size - max_bytes))
        except OSError:
            pass
        return handle.read(max_bytes).decode("utf-8", "replace")


def print_results(results: list[CheckResult], as_json: bool) -> None:
    if as_json:
        print(json.dumps({"generated_at": now_iso(), "results": [r.as_dict() for r in results]}, indent=2, sort_keys=True))
        return
    widths = {"pass": 0, "warn": 0, "fail": 0, "skip": 0}
    for result in results:
        widths[result.status] = widths.get(result.status, 0) + 1
        label = result.status.upper().ljust(4)
        print(f"{label} {result.id}: {result.title}")
        print(f"     {result.detail}")
        if result.action:
            print(f"     action: {result.action}")
    print("")
    print("Summary: " + ", ".join(f"{status}={count}" for status, count in widths.items() if count))


def print_routes(table: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(table, indent=2, sort_keys=True))
        return
    if table.get("error"):
        print(f"Could not read routes: {table['error']}")
        return
    print("Published ports")
    if not table["ports"]:
        print("  none")
    for row in table["ports"]:
        conflict = " conflict" if row.get("conflict") else ""
        print(f"  {row['host_ip']}:{row['host_port']} -> {row['container']}:{row['container_port']}/{row['protocol']} ({row['state']}){conflict}")
    print("")
    print(f"Domains (*.{DOMAIN_SUFFIX})")
    if not table["domains"]:
        print("  none")
    for row in table["domains"]:
        print(f"  {row['domain']} -> {row['target']} via {row['http_proxy']}")


def print_disk(report: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(report, indent=2, sort_keys=True))
        return
    host = report["host"]
    print(f"Host: {format_bytes(host.get('free_bytes', 0))} free of {format_bytes(host.get('total_bytes', 0))} at {host.get('path')}")
    docker = report["docker"]
    if docker.get("available"):
        print("Docker: " + docker_summary(docker))
        print(f"        images={docker.get('images_count', 0)} containers={docker.get('containers_count', 0)} volumes={docker.get('volumes_count', 0)} build_cache={docker.get('build_cache_count', 0)}")
    else:
        print(f"Docker: unavailable ({docker.get('error', 'unknown')})")
    state = report["state"]
    print(f"Dory state: {format_bytes(state.get('total_bytes', 0))} total, {format_bytes(state.get('log_bytes', 0))} logs, {format_bytes(state.get('vm_disk_bytes', 0))} VM disks")


def print_cleanup(report: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(report, indent=2, sort_keys=True))
        return
    print("Cleanup plan" + (" (applied)" if report.get("apply") else " (dry run)"))
    for action in report.get("actions", []):
        status = str(action.get("status", "info")).upper()
        detail = action.get("detail", "")
        target = action.get("target", "unknown")
        print(f"{status} {target}: {detail}")
        if action.get("bytes_reclaimable"):
            print(f"     reclaimable: {format_bytes(action['bytes_reclaimable'])}")
        if action.get("command") and not report.get("apply"):
            print("     command: " + " ".join(action["command"]))
    if not report.get("apply"):
        print("Dry run. Re-run with --apply for actions that change local state.")


def print_idle(status: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(status, indent=2, sort_keys=True))
        return
    print(f"Mode: {status['mode']}")
    print(f"Auto-Idle enabled: {'yes' if status['auto_idle_enabled'] else 'no'}")
    print(f"Can sleep now: {'yes' if status['can_sleep'] else 'no'}")
    proxy = status.get("proxy_state") or {}
    print(f"Doryd idle state: {proxy.get('state', 'unknown')} ({proxy.get('detail', 'no state')})")
    if status["blockers"]:
        print("Sleep blockers:")
        for blocker in status["blockers"]:
            detail = ", ".join(f"{k}={v}" for k, v in blocker.items())
            print(f"  {detail}")


def exit_code(results: list[CheckResult]) -> int:
    return 1 if any(result.status == "fail" for result in results) else 0


# ----- Compatibility center (Track 4) -------------------------------------------------------------
# "Docker-compatible" breaks at the edges: tools assume Docker Desktop or /var/run/docker.sock, read
# DOCKER_HOST, or need Ryuk/socket bind mounts. These checks measure real workflows, name the exact
# env/config mismatch, and each ships a copy-paste recipe with a verification command.

VAR_RUN_DOCKER_SOCK = Path("/var/run/docker.sock")


def socket_reachable(path: Path, timeout: float = 2.0) -> bool:
    try:
        status_code, _, body = unix_http(path, "GET", "/_ping", timeout=timeout)
        return status_code == 200 and body.strip() == b"OK"
    except Exception:
        return False


def compat_socket_state() -> dict[str, Any]:
    dory = socket_path()
    dory_resolved = dory.resolve() if dory.exists() else dory
    env_host = os.environ.get("DOCKER_HOST", "").strip()
    env_target: Path | None = None
    if env_host.startswith("unix://"):
        env_target = Path(env_host[len("unix://"):]).expanduser()
    var_run_target: Path | None = None
    if VAR_RUN_DOCKER_SOCK.exists():
        try:
            var_run_target = VAR_RUN_DOCKER_SOCK.resolve()
        except OSError:
            var_run_target = None
    return {
        "dory_socket": str(dory),
        "dory_reachable": socket_reachable(dory),
        "docker_host": env_host,
        "docker_host_points_at_dory": bool(env_target) and env_target.resolve() == dory_resolved,
        "docker_context": os.environ.get("DOCKER_CONTEXT", "").strip(),
        "var_run_exists": VAR_RUN_DOCKER_SOCK.exists(),
        "var_run_is_dory": var_run_target == dory_resolved,
    }


def tool_on_path(*names: str) -> str | None:
    for name in names:
        found = shutil.which(name)
        if found:
            return found
    return None


def app_installed(*bundle_names: str) -> bool:
    roots = [Path("/Applications"), HOME / "Applications"]
    return any((root / name).exists() for root in roots for name in bundle_names)


def check_compat_docker(state: dict[str, Any]) -> list[CheckResult]:
    out: list[CheckResult] = []
    binary = docker_bin()
    if not binary:
        out.append(CheckResult(
            "compat.docker.cli", "fail", "compat.docker.cli_missing",
            "Docker CLI missing",
            "No docker executable on PATH or DORY_DOCKER_BIN.",
            "doryd keeps the bundled docker CLI on PATH automatically while it is running; restart Dory/doryd, or use `dory install` only as manual recovery.",
        ))
        return out
    out.append(CheckResult("compat.docker.cli", "pass", "compat.docker.cli_ok", "Docker CLI found", binary))
    if not state["dory_reachable"]:
        out.append(CheckResult(
            "compat.docker.reach", "fail", "compat.docker.unreachable",
            "Docker socket is not answering",
            f"{state['dory_socket']} did not answer /_ping.",
            "Start Dory (or `dory engine wake`) and re-run `dory compat`.",
        ))
        return out
    if state["docker_host_points_at_dory"] or state["docker_context"] == "dory":
        out.append(CheckResult(
            "compat.docker.route", "pass", "compat.docker.route_ok",
            "docker targets Dory",
            f"DOCKER_HOST={state['docker_host'] or 'unset'} context={state['docker_context'] or 'default'}",
        ))
    else:
        out.append(CheckResult(
            "compat.docker.route", "warn", "compat.docker.route_default",
            "docker relies on the default context",
            "Neither DOCKER_HOST nor DOCKER_CONTEXT names Dory; the CLI works only if the `dory` context is the active default.",
            f"Run `docker context use dory` or export DOCKER_HOST=unix://{state['dory_socket']}.",
        ))
    return out


def check_compat_compose(state: dict[str, Any]) -> list[CheckResult]:
    binary = docker_bin()
    if not binary:
        return [CheckResult(
            "compat.compose", "skip", "compat.compose.no_docker",
            "Docker Compose not checked", "docker CLI missing.",
        )]
    try:
        result = subprocess.run([binary, "compose", "version"], text=True, capture_output=True, timeout=15)
    except Exception as exc:
        return [CheckResult("compat.compose", "fail", "compat.compose.exception", "Docker Compose check failed", str(exc))]
    if result.returncode == 0:
        return [CheckResult("compat.compose", "pass", "compat.compose.ok", "Docker Compose v2 plugin works", result.stdout.strip())]
    return [CheckResult(
        "compat.compose", "warn", "compat.compose.missing",
        "Docker Compose plugin not available",
        compact(result.stderr or result.stdout),
        "doryd keeps the bundled Compose plugin on PATH automatically while it is running; restart Dory/doryd, or use `dory install` only as manual recovery.",
    )]


def check_compat_ide(state: dict[str, Any], tool: str, title: str, bundles: list[str]) -> list[CheckResult]:
    installed = app_installed(*bundles) or bool(tool_on_path(tool))
    if not installed:
        return [CheckResult(
            f"compat.{tool}", "skip", f"compat.{tool}.absent",
            f"{title} not installed", f"{title} was not found; recipe available via `dory compat recipe {tool}`.",
        )]
    if not docker_bin():
        return [CheckResult(
            f"compat.{tool}", "fail", f"compat.{tool}.no_docker",
            f"{title}: docker CLI missing",
            "Dev Containers shells out to `docker`, which is not on PATH.",
            "doryd keeps `docker` on the login-shell PATH while it is running; restart Dory/doryd, or use `dory install` only as manual recovery.",
        )]
    if not (state["docker_host_points_at_dory"] or state["docker_context"] == "dory" or state["dory_reachable"]):
        return [CheckResult(
            f"compat.{tool}", "warn", f"compat.{tool}.route",
            f"{title}: engine route unverified",
            "The Dev Containers extension uses the active docker context; Dory's socket is not the default target.",
            f"Set `\"dev.containers.dockerPath\": \"docker\"` and run `docker context use dory` (see `dory compat recipe {tool}`).",
        )]
    return [CheckResult(
        f"compat.{tool}", "pass", f"compat.{tool}.ok",
        f"{title} can reach Dory",
        f"docker CLI present, Dory socket reachable at {state['dory_socket']}.",
    )]


def check_compat_testcontainers(state: dict[str, Any]) -> list[CheckResult]:
    # Testcontainers resolves the host from DOCKER_HOST, then the docker context, then
    # /var/run/docker.sock. Ryuk (its reaper) also bind-mounts the docker socket, so a reachable,
    # named socket matters more here than anywhere else.
    if state["docker_host_points_at_dory"]:
        detail = f"DOCKER_HOST={state['docker_host']} resolves to Dory."
        return [CheckResult("compat.testcontainers", "pass", "compat.testcontainers.env_ok", "Testcontainers is pointed at Dory", detail)]
    if state["var_run_is_dory"]:
        return [CheckResult(
            "compat.testcontainers", "pass", "compat.testcontainers.varrun_ok",
            "Testcontainers finds Dory via /var/run/docker.sock",
            "/var/run/docker.sock resolves to Dory's socket; Ryuk and the default host detection work.",
        )]
    action = (
        f"export DOCKER_HOST=unix://{state['dory_socket']} (and TESTCONTAINERS_RYUK_DISABLED=true "
        "only if Ryuk cannot bind-mount the socket)."
    )
    return [CheckResult(
        "compat.testcontainers", "fail", "compat.testcontainers.unresolved",
        "Testcontainers cannot find the Docker host",
        "DOCKER_HOST does not point at Dory and /var/run/docker.sock is not linked to it, so host auto-detection falls back to a socket that does not exist.",
        action,
    )]


def check_compat_act(state: dict[str, Any]) -> list[CheckResult]:
    installed = tool_on_path("act")
    if state["var_run_is_dory"]:
        return [CheckResult("compat.act", "pass", "compat.act.varrun_ok", "act finds Dory via /var/run/docker.sock", "/var/run/docker.sock resolves to Dory.")]
    if state["docker_host"]:
        return [CheckResult("compat.act", "pass", "compat.act.env_ok", "act will use DOCKER_HOST", f"DOCKER_HOST={state['docker_host']}")]
    status = "warn" if installed else "skip"
    return [CheckResult(
        "compat.act", status, "compat.act.default_sock",
        "act defaults to /var/run/docker.sock",
        "act hard-codes /var/run/docker.sock unless told otherwise, and Dory does not create that path by default.",
        f"Run `act --container-daemon-socket unix://{state['dory_socket']}` or export DOCKER_HOST.",
    )]


def check_compat_cli_tool(state: dict[str, Any], tool: str, title: str, cli_names: list[str], note: str) -> list[CheckResult]:
    binary = tool_on_path(*cli_names)
    if not binary:
        return [CheckResult(
            f"compat.{tool}", "skip", f"compat.{tool}.absent",
            f"{title} not installed", f"{title} CLI not found; recipe available via `dory compat recipe {tool}`.",
        )]
    if not state["dory_reachable"]:
        return [CheckResult(
            f"compat.{tool}", "fail", f"compat.{tool}.unreachable",
            f"{title}: Docker socket not answering",
            f"{title} needs a reachable Docker engine; {state['dory_socket']} did not answer.",
            "Start Dory (or `dory engine wake`).",
        )]
    return [CheckResult(f"compat.{tool}", "pass", f"compat.{tool}.ok", f"{title} can reach Dory", f"{binary}; {note}")]


def check_compat_kubernetes(state: dict[str, Any]) -> list[CheckResult]:
    binary = kubectl_bin()
    if not binary:
        return [CheckResult("compat.kubernetes", "skip", "compat.kubernetes.absent", "kubectl not installed", "Skaffold/Tilt recipe available via `dory compat recipe kubernetes`.")]
    if not DEFAULT_KUBECONFIG.exists() and not (HOME / ".kube" / "config").exists():
        return [CheckResult(
            "compat.kubernetes", "warn", "compat.kubernetes.no_context",
            "No kubeconfig found",
            "Neither ~/.kube/config nor Dory's kubeconfig exists; Skaffold/Tilt need a cluster context.",
            "Enable Kubernetes in Dory, then `kubectl config use-context dory`.",
        )]
    return [CheckResult("compat.kubernetes", "pass", "compat.kubernetes.ok", "kubectl and a kubeconfig are present", binary)]


def check_compat_amd64(state: dict[str, Any]) -> list[CheckResult]:
    machine = os.uname().machine
    if machine == "x86_64":
        return [CheckResult(
            "compat.amd64", "pass", "compat.amd64.native_host",
            "amd64 images are native on this Mac",
            "This host is x86_64, so linux/amd64 containers do not need emulation.",
        )]
    if machine != "arm64" or sys.platform != "darwin":
        return [CheckResult(
            "compat.amd64", "skip", "compat.amd64.not_apple_silicon",
            "amd64 emulation check skipped",
            f"Host platform is {sys.platform}/{machine}; Dory's amd64 warning is specific to Apple silicon.",
        )]
    return [CheckResult(
        "compat.amd64", "warn", "compat.amd64.qemu_limited",
        "amd64 images use QEMU emulation",
        "On Apple silicon, Dory's shared engine runs linux/amd64 images through qemu-user binfmt. Alpine/Debian-class images work, but heavy SQL Server, Oracle, AVX, or threading-heavy amd64 images may segfault under qemu-user.",
        "Prefer native arm64 images when available; for one-off Rosetta-fast x86 runs use `dory vm --arch amd64 --rosetta -- <cmd>`. See COMPATIBILITY.md before adopting SQL Server or Oracle on Dory.",
    )]


COMPAT_TOOLS: list[dict[str, Any]] = [
    {"tool": "docker", "title": "Docker CLI", "check": check_compat_docker},
    {"tool": "compose", "title": "Docker Compose v2", "check": check_compat_compose},
    {"tool": "vscode", "title": "VS Code Dev Containers", "check": lambda s: check_compat_ide(s, "vscode", "VS Code Dev Containers", ["Visual Studio Code.app"])},
    {"tool": "cursor", "title": "Cursor Dev Containers", "check": lambda s: check_compat_ide(s, "cursor", "Cursor Dev Containers", ["Cursor.app"])},
    {"tool": "testcontainers", "title": "Testcontainers", "check": check_compat_testcontainers},
    {"tool": "act", "title": "GitHub Actions act", "check": check_compat_act},
    {"tool": "supabase", "title": "Supabase local", "check": lambda s: check_compat_cli_tool(s, "supabase", "Supabase local", ["supabase"], "run `supabase start` to bring up the stack.")},
    {"tool": "localstack", "title": "LocalStack", "check": lambda s: check_compat_cli_tool(s, "localstack", "LocalStack", ["localstack"], "publishes 4566; verify with `curl localhost:4566/_localstack/health`.")},
    {"tool": "kubernetes", "title": "Skaffold/Tilt (Kubernetes)", "check": check_compat_kubernetes},
    {"tool": "amd64", "title": "linux/amd64 images", "check": check_compat_amd64},
]


